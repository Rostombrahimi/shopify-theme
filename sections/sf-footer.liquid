<footer class="sf-stitch sf-footer">
  <style>
    /* Footer Illuminées - sf-footer-final.css */
    .sf-footer {
      background-color: var(--illu-bg-night);
      color: var(--illu-text-cream);
      padding: 80px 40px 40px 40px;
      font-family: 'Inter', sans-serif;
      border-top: 1px solid rgba(255, 255, 255, 0.05);
      /* Typography Smoothening */
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    .sf-footer * {
        box-sizing: border-box;
    }

    .sf-footer-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 40px;
      max-width: 1400px;
      margin: 0 auto;
    }

    .sf-footer-col-title {
      color: var(--illu-accent-amber);
      font-size: 0.875rem;
      font-weight: var(--fw-bold);
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin-bottom: 24px;
    }

    .sf-footer-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .sf-footer-link {
      color: var(--illu-text-cream);
      text-decoration: none;
      font-size: 1.16rem; /* Increased for better readability */
      opacity: 0.7;
      transition: all 0.3s ease;
      display: flex; /* Changed to flex to align icons if present */
      align-items: center;
      gap: 12px; /* Increased gap for SVGs */
      margin-bottom: 16px; /* Increased spacing between links */
    }

    .sf-footer-link:hover {
      opacity: 1;
      color: var(--illu-accent-amber);
      transform: translateX(4px);
    }
    
    .sf-footer-link svg {
        width: 18px;
        height: 18px;
        opacity: 0.7;
    }

    .sf-footer-subtext {
      font-size: 0.96rem;
      opacity: 0.6;
      margin-top: 4px;
      line-height: 1.4;
      display: block;
    }

    /* Newsletter Section */
    .sf-footer-newsletter {
      grid-column: span 4;
      background: rgba(255, 255, 255, 0.03);
      border-radius: var(--illu-radius-chubby);
      padding: 40px;
      margin: 60px auto;
      max-width: 1400px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      /* Backdrop Blur */
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      border: 1px solid rgba(255, 255, 255, 0.05);
    }
    
    .sf-newsletter-text h3 {
        color: var(--illu-text-cream);
        font-size: 1.65rem;
        font-weight: var(--fw-bold);
        margin: 0 0 8px 0;
    }
    
    .sf-newsletter-text p {
        color: var(--illu-text-cream);
        opacity: 0.7;
        margin: 0;
        font-size: 1.05rem;
        max-width: 400px;
    }

    .sf-newsletter-form {
      display: flex;
      gap: 16px;
    }

    .sf-newsletter-input {
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 99px;
      padding: 12px 24px;
      color: var(--illu-text-cream);
      width: 300px;
      font-family: inherit;
      outline: none;
      transition: border-color 0.3s ease;
    }
    
    .sf-newsletter-input:focus {
        border-color: var(--illu-accent-amber);
    }

    .sf-newsletter-btn {
      background: var(--illu-accent-amber);
      color: var(--illu-bg-night);
      padding: 12px 32px;
      border-radius: 99px;
      font-weight: var(--fw-bold);
      border: none;
      cursor: pointer;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    
    .sf-newsletter-btn:hover {
        transform: scale(1.02); /* Slight scale instead of Y translate for inline buttons */
        box-shadow: 0 0 20px rgba(232, 157, 70, 0.2);
    }

    /* Bottom Bar */
    .sf-footer-bottom {
      border-top: 1px solid rgba(255, 255, 255, 0.05);
      padding-top: 40px;
      max-width: 1400px;
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 0.96rem;
      opacity: 0.6;
    }
    
    .sf-footer-bottom-brand {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }
    
    .sf-footer-bottom-brand strong {
        font-weight: var(--fw-bold);
        color: var(--illu-text-cream);
    }
    
    .sf-footer-bottom-links {
        display: flex;
        gap: 24px;
    }
    
    .sf-footer-bottom-links a {
        color: var(--illu-text-cream);
        text-decoration: none;
        transition: color 0.3s ease;
    }
    
    .sf-footer-bottom-links a:hover {
        color: var(--illu-accent-amber);
    }
    
    .sf-social-icons {
        display: flex;
        gap: 12px;
        margin-top: 24px;
    }
    
    .sf-social-link {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.05);
        color: var(--illu-text-cream);
        text-decoration: none;
        transition: all 0.3s ease;
    }
    
    .sf-social-link:hover {
        background: var(--illu-accent-amber);
        color: var(--illu-bg-night);
        transform: translateY(-3px);
    }
    
    .sf-social-link svg {
        width: 16px;
        height: 16px;
    }

    /* Mobile Responsive */
    @media screen and (max-width: 990px) {
      .sf-footer {
        padding: 60px 20px 30px 20px;
      }
      .sf-footer-grid {
        grid-template-columns: 1fr;
        gap: 48px;
      }
      .sf-footer-newsletter {
        grid-column: span 1;
        flex-direction: column;
        text-align: center;
        gap: 24px;
        padding: 32px 20px;
      }
      .sf-newsletter-text p {
          margin: 0 auto;
      }
      .sf-newsletter-form {
          flex-direction: column;
          width: 100%;
      }
      .sf-newsletter-input {
          width: 100%;
      }
      .sf-newsletter-btn {
          width: 100%;
      }
      .sf-footer-bottom {
          flex-direction: column;
          text-align: center;
          gap: 24px;
      }
      .sf-footer-bottom-links {
          flex-wrap: wrap;
          justify-content: center;
      }
    }
    
    @media screen and (min-width: 768px) and (max-width: 1024px) {
        .sf-footer-grid {
            grid-template-columns: repeat(2, 1fr);
        }
        .sf-footer-newsletter {
            grid-column: span 2;
        }
    }
  </style>

  <div class="sf-footer-grid">
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'link_list' -%}
          <div class="sf-footer-col" {{ block.shopify_attributes }}>
            <h4 class="sf-footer-col-title">{{ block.settings.heading | escape }}</h4>
            <ul class="sf-footer-list">
              {%- for link in block.settings.menu.links -%}
                <li>
                  <a href="{{ link.url }}" class="sf-footer-link">
                    {%- case forloop.index -%}
                      {%- when 1 -%}{%- if block.settings.svg_1 != blank -%}{{ block.settings.svg_1 }}{%- endif -%}
                      {%- when 2 -%}{%- if block.settings.svg_2 != blank -%}{{ block.settings.svg_2 }}{%- endif -%}
                      {%- when 3 -%}{%- if block.settings.svg_3 != blank -%}{{ block.settings.svg_3 }}{%- endif -%}
                      {%- when 4 -%}{%- if block.settings.svg_4 != blank -%}{{ block.settings.svg_4 }}{%- endif -%}
                      {%- when 5 -%}{%- if block.settings.svg_5 != blank -%}{{ block.settings.svg_5 }}{%- endif -%}
                    {%- endcase -%}
                    {{ link.title }}
                  </a>
                </li>
              {%- endfor -%}
            </ul>
          </div>
          
        {%- when 'custom_list' -%}
          <div class="sf-footer-col" {{ block.shopify_attributes }}>
            <h4 class="sf-footer-col-title">{{ block.settings.heading | escape }}</h4>
            <ul class="sf-footer-list">
                <!-- Custom static items as per design -->
                {%- if block.settings.item_1_title != blank -%}
                <li>
                  <a href="{{ block.settings.item_1_link }}" class="sf-footer-link" style="align-items: flex-start; flex-direction: column; gap: 0;">
                    <div style="display: flex; align-items: center; gap: 8px;">
                      {%- if block.settings.item_1_icon != blank -%}
                         {{ block.settings.item_1_icon }}
                      {%- endif -%}
                      <span style="font-weight: var(--fw-bold);">{{ block.settings.item_1_title }}</span>
                    </div>
                    {%- if block.settings.item_1_sub != blank -%}
                        <span class="sf-footer-subtext">{{ block.settings.item_1_sub }}</span>
                    {%- endif -%}
                  </a>
                </li>
                {%- endif -%}
                
                {%- if block.settings.item_2_title != blank -%}
                <li>
                  <a href="{{ block.settings.item_2_link }}" class="sf-footer-link" style="align-items: flex-start; flex-direction: column; gap: 0; margin-top: 20px;">
                    <div style="display: flex; align-items: center; gap: 8px;">
                       {%- if block.settings.item_2_icon != blank -%}
                         {{ block.settings.item_2_icon }}
                      {%- endif -%}
                      <span style="font-weight: var(--fw-bold);">{{ block.settings.item_2_title }}</span>
                    </div>
                    {%- if block.settings.item_2_sub != blank -%}
                        <span class="sf-footer-subtext">{{ block.settings.item_2_sub }}</span>
                    {%- endif -%}
                  </a>
                </li>
                {%- endif -%}
                
                {%- if block.settings.item_3_title != blank -%}
                <li>
                  <a href="{{ block.settings.item_3_link }}" class="sf-footer-link" style="align-items: flex-start; flex-direction: column; gap: 0; margin-top: 20px;">
                    <div style="display: flex; align-items: center; gap: 8px;">
                       {%- if block.settings.item_3_icon != blank -%}
                         {{ block.settings.item_3_icon }}
                      {%- endif -%}
                      <span style="font-weight: var(--fw-bold);">{{ block.settings.item_3_title }}</span>
                    </div>
                    {%- if block.settings.item_3_sub != blank -%}
                        <span class="sf-footer-subtext">{{ block.settings.item_3_sub }}</span>
                    {%- endif -%}
                  </a>
                </li>
                {%- endif -%}

                {%- if block.settings.item_4_title != blank -%}
                <li>
                  <a href="{{ block.settings.item_4_link }}" class="sf-footer-link" style="align-items: flex-start; flex-direction: column; gap: 0; margin-top: 20px;">
                    <div style="display: flex; align-items: center; gap: 8px;">
                       {%- if block.settings.item_4_icon != blank -%}
                         {{ block.settings.item_4_icon }}
                      {%- endif -%}
                      <span style="font-weight: var(--fw-bold);">{{ block.settings.item_4_title }}</span>
                    </div>
                    {%- if block.settings.item_4_sub != blank -%}
                        <span class="sf-footer-subtext">{{ block.settings.item_4_sub }}</span>
                    {%- endif -%}
                  </a>
                </li>
                {%- endif -%}
            </ul>
          </div>
          
         {%- when 'contact_social' -%}
          <div class="sf-footer-col" {{ block.shopify_attributes }}>
            <h4 class="sf-footer-col-title">{{ block.settings.heading | escape }}</h4>
            <ul class="sf-footer-list">
              {%- for link in block.settings.menu.links -%}
                <li>
                  <a href="{{ link.url }}" class="sf-footer-link">
                    {{ link.title }}
                  </a>
                </li>
              {%- endfor -%}
            </ul>
            
            {%- if block.settings.show_social -%}
                <div class="sf-social-icons">
                    {%- if block.settings.social_instagram != blank -%}
                    <a href="{{ block.settings.social_instagram }}" class="sf-social-link" target="_blank">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
                    </a>
                    {%- endif -%}
                    {%- if block.settings.social_pinterest != blank -%}
                    <a href="{{ block.settings.social_pinterest }}" class="sf-social-link" target="_blank">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                    </a>
                    {%- endif -%}
                </div>
            {%- endif -%}
          </div>
      {%- endcase -%}
    {%- endfor -%}
  </div>

  {%- if section.settings.show_newsletter -%}
  <div class="sf-footer-newsletter">
    <div class="sf-newsletter-text">
        <h3>{{ section.settings.newsletter_heading }}</h3>
        <p>{{ section.settings.newsletter_text }}</p>
    </div>
    {%- form 'customer', id: 'sf-newsletter-form', class: 'sf-newsletter-form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <input
        id="NewsletterForm--{{ section.id }}"
        type="email"
        name="contact[email]"
        class="sf-newsletter-input"
        value="{{ form.email }}"
        aria-required="true"
        autocorrect="off"
        autocapitalize="off"
        autocomplete="email"
        {% if form.errors %}
          autofocus
          aria-invalid="true"
        {% endif %}
        placeholder="Votre email..."
        required
      >
      <button type="submit" class="sf-newsletter-btn" name="commit">
        {{ section.settings.newsletter_button_text }}
      </button>
    {%- endform -%}
  </div>
  {%- endif -%}

  <div class="sf-footer-bottom">
    <div class="sf-footer-bottom-brand">
        <strong>{{ shop.name }}</strong>
        <span>{{ section.settings.bottom_text }}</span>
    </div>
    
    <div class="sf-footer-bottom-links">
        {%- for link in section.settings.bottom_menu.links -%}
            <a href="{{ link.url }}">{{ link.title }}</a>
        {%- endfor -%}
    </div>
    
    <div class="sf-footer-copyright">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. Tous droits réservés.
    </div>
  </div>
</footer>


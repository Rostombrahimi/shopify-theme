{% schema %}
{
  "name": "Bénéfices Chill",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titre principal",
      "default": "Ce que cette ambiance apporte"
    },
    {
      "type": "text",
      "id": "footer_text",
      "label": "Texte du badge footer",
      "default": "Ici, la lumière s'efface pour laisser place au confort."
    }
  ],
  "blocks": [
    {
      "type": "benefit_card",
      "name": "Carte Bénéfice",
      "limit": 3,
      "settings": [
        {
          "type": "html",
          "id": "icon",
          "label": "Icône SVG"
        },
        {
          "type": "textarea",
          "id": "title",
          "label": "Titre du bénéfice",
          "default": "Titre du bénéfice"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Description du bénéfice apporté."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bénéfices Chill",
      "blocks": [
        {
          "type": "benefit_card",
          "settings": {
            "icon": "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"12\" cy=\"12\" r=\"4\"/><path d=\"M12 2v2\"/><path d=\"M12 20v2\"/><path d=\"m4.93 4.93 1.41 1.41\"/><path d=\"m17.66 17.66 1.41 1.41\"/><path d=\"M2 12h2\"/><path d=\"M20 12h2\"/><path d=\"m6.34 17.66-1.41 1.41\"/><path d=\"m19.07 4.93-1.41 1.41\"/></svg>",
            "title": "Lumière indirecte et enveloppante",
            "text": "Une diffusion douce pour une immersion totale, créant un cocon de lumière protecteur."
          }
        },
        {
          "type": "benefit_card",
          "settings": {
            "icon": "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M19 9V6a2 2 0 0 0-2-2H7a2 2 0 0 0-2 2v3\"/><path d=\"M3 11v5a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-5a2 2 0 0 0-4 0v2H7v-2a2 2 0 0 0-4 0Z\"/><path d=\"M5 18v2\"/><path d=\"M19 18v2\"/></svg>",
            "title": "Atmosphère calme",
            "text": "Le silence visuel nécessaire pour apaiser l'esprit après une longue journée."
          }
        },
        {
          "type": "benefit_card",
          "settings": {
            "icon": "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z\"/></svg>",
            "title": "Transition douce",
            "text": "Préparez naturellement votre cycle circadien au repos grâce à une intensité lumineuse étudiée."
          }
        }
      ]
    }
  ]
}
{% endschema %}

<style>
/* Section Bénéfices Chill - sf-chill-benefits.css */

#shopify-section-{{ section.id }} .chill-benefits-section {
  background-color: #081A32; /* illu-night */
  padding: 100px 0;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

/* En-tête */
#shopify-section-{{ section.id }} .chill-benefits-header {
  text-align: left;
  max-width: 1300px;
  margin: 0 auto 4rem auto;
  padding: 0 4rem;
}

#shopify-section-{{ section.id }} .chill-title {
  font-size: clamp(2.2rem, 4vw, 3.2rem);
  color: #F9F9F9;
  font-weight: 800;
  margin: 0;
  display: inline-block;
  position: relative;
  letter-spacing: -0.02em;
}

/* Soulignement Ambre (gauche) */
#shopify-section-{{ section.id }} .chill-title::after {
  content: '';
  position: absolute;
  bottom: -10px;
  left: 0;
  width: 60px;
  height: 4px;
  background-color: #E89D46; /* illu-amber */
  border-radius: 2px;
}

/* Grille */
#shopify-section-{{ section.id }} .chill-benefits-grid-wrapper {
  width: 100%;
}

#shopify-section-{{ section.id }} .chill-benefits-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 32px;
  max-width: 1300px;
  margin: 0 auto;
  padding: 0 4rem;
}

/* Carte */
#shopify-section-{{ section.id }} .chill-benefit-card {
  background: rgba(255, 255, 255, 0.02);
  border: 1px solid rgba(255, 255, 255, 0.05);
  border-radius: 32px; /* radius chubby (32px) */
  padding: 48px 32px;
  text-align: left;
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  display: flex;
  flex-direction: column;
}

#shopify-section-{{ section.id }} .chill-benefit-card:hover {
  transform: translateY(-8px);
  border-color: rgba(232, 157, 70, 0.3);
  background: rgba(255, 255, 255, 0.04);
}

/* Icônes */
#shopify-section-{{ section.id }} .chill-icon-wrapper {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 56px;
  height: 56px;
  background: rgba(255, 255, 255, 0.03); /* Rounded square inside the card */
  border: 1px solid rgba(255, 255, 255, 0.05);
  border-radius: 16px;
  color: #E89D46;
  margin-bottom: 2rem;
  transition: all 0.4s ease;
  filter: drop-shadow(0 0 10px rgba(232, 157, 70, 0.15));
}

#shopify-section-{{ section.id }} .chill-icon-wrapper svg {
  width: 28px !important;
  height: 28px !important;
  min-width: 28px;
  min-height: 28px;
  display: block;
  flex-shrink: 0;
}

#shopify-section-{{ section.id }} .chill-benefit-card:hover .chill-icon-wrapper {
  background: #E89D46;
  color: #fff;
  filter: drop-shadow(0 0 15px rgba(232, 157, 70, 0.4));
  transform: scale(1.05);
}

/* Textes des cartes */
#shopify-section-{{ section.id }} .chill-benefit-title {
  color: #F9F9F9;
  font-size: 1.25rem;
  font-weight: 700;
  margin: 0 0 1rem 0;
  line-height: 1.3;
  white-space: pre-line;
}

#shopify-section-{{ section.id }} .chill-benefit-desc {
  color: #9CA3AF; /* Gris clair */
  font-size: 0.95rem;
  line-height: 1.6;
  margin: 0;
}

/* Footer Badge */
#shopify-section-{{ section.id }} .chill-footer-badge-wrapper {
  display: flex;
  justify-content: center;
  margin-top: 4rem;
  padding: 0 2rem;
}

#shopify-section-{{ section.id }} .chill-footer-badge {
  display: inline-flex;
  align-items: center;
  gap: 12px;
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 99px;
  padding: 16px 32px;
  color: #F9F9F9;
  font-size: 1.05rem;
  font-weight: 500;
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  transition: all 0.3s ease;
}

#shopify-section-{{ section.id }} .chill-footer-badge:hover {
  background: rgba(255, 255, 255, 0.05);
  border-color: rgba(232, 157, 70, 0.3);
  transform: translateY(-2px);
}

/* MOBILE RESPONSIVE - SNAP CAROUSEL */
@media screen and (max-width: 1024px) {
  #shopify-section-{{ section.id }} .chill-benefits-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media screen and (max-width: 768px) {
  #shopify-section-{{ section.id }} .chill-benefits-section {
    padding: 80px 0;
  }
  
  #shopify-section-{{ section.id }} .chill-benefits-header {
    padding: 0 1.5rem;
    margin-bottom: 3rem;
  }
  
  #shopify-section-{{ section.id }} .chill-title {
    font-size: 2.2rem;
  }

  /* Slider Snap Logic */
  #shopify-section-{{ section.id }} .chill-benefits-grid-wrapper {
    width: 100vw;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding-bottom: 2rem;
  }

  #shopify-section-{{ section.id }} .chill-benefits-grid-wrapper::-webkit-scrollbar {
    display: none;
  }

  #shopify-section-{{ section.id }} .chill-benefits-grid {
    display: flex;
    flex-direction: row;
    width: max-content;
    padding: 0 1.5rem;
    margin: 0;
    gap: 1.25rem;
  }
  
  #shopify-section-{{ section.id }} .chill-benefit-card {
    scroll-snap-align: center;
    width: 85vw;
    max-width: 320px;
    padding: 32px 24px;
    flex-shrink: 0;
    transition: transform 0.3s ease, background 0.3s ease, border-color 0.3s ease;
  }

  #shopify-section-{{ section.id }} .chill-benefit-card:active {
    transform: translateY(-4px);
  }
  
  #shopify-section-{{ section.id }} .chill-footer-badge {
    font-size: 0.95rem;
    padding: 12px 24px;
    text-align: center;
  }
}
</style>

<section class="chill-benefits-section sf-stitch">
  
  <div class="chill-benefits-header">
    {% if section.settings.title != blank %}
      <h2 class="chill-title">{{ section.settings.title }}</h2>
    {% endif %}
  </div>

  {% if section.blocks.size > 0 %}
    <div class="chill-benefits-grid-wrapper">
      <div class="chill-benefits-grid">
        {% for block in section.blocks %}
          <div class="chill-benefit-card" {{ block.shopify_attributes }}>
            <div class="chill-icon-wrapper">
              {% if block.settings.icon != blank %}
                {{ block.settings.icon }}
              {% endif %}
            </div>
            <h3 class="chill-benefit-title">{{ block.settings.title | newline_to_br }}</h3>
            <p class="chill-benefit-desc">{{ block.settings.text }}</p>
          </div>
        {% endfor %}
      </div>
    </div>
  {% endif %}

  {% if section.settings.footer_text != blank %}
    <div class="chill-footer-badge-wrapper">
      <div class="chill-footer-badge">
        👉 {{ section.settings.footer_text }}
      </div>
    </div>
  {% endif %}

</section>

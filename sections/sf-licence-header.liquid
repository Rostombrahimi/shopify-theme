{% schema %}
{
  "name": "Banderole Cinématique",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Image de fond (Desktop)"
    },
    {
      "type": "image_picker",
      "id": "background_image_mobile",
      "label": "Image de fond (Mobile) - Optionnel",
      "info": "Si laissée vide, l'image Desktop sera utilisée sur mobile."
    },
    {
      "type": "text",
      "id": "overline",
      "label": "Texte au-dessus (Surtitre)",
      "default": "COLLECTION EXCLUSIVE"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titre Principal",
      "default": "KONOHA"
    }
  ],
  "presets": [
    {
      "name": "Banderole Cinématique (Licence)",
      "category": "Image"
    }
  ]
}
{% endschema %}

<style>
/* Banderole Cinématique - Licence Header */
#shopify-section-{{ section.id }} .vibe-header-section {
  padding: 40px 4rem 20px;
  background-color: var(--illu-night, #081A32);
}

#shopify-section-{{ section.id }} .vibe-header-container {
  position: relative;
  height: 35vh; /* Environ 30-35% de l'écran */
  min-height: 250px;
  max-height: 400px;
  border-radius: 32px;
  overflow: hidden; /* Cache le débordement de l'image parallaxe */
  display: flex;
  align-items: center;
  justify-content: flex-start; /* Aligné à gauche d'après la maquette */
  padding-left: 60px; /* Espace à gauche */
  background: #000;
}

/* Le "Scanline" ou "Light Sweep" */
#shopify-section-{{ section.id }} .vibe-scanline {
  position: absolute;
  top: 0;
  left: 0;
  width: 25%;
  height: 100%;
  background: linear-gradient(to right, transparent, rgba(255, 255, 255, 0.1), rgba(255, 255, 255, 0.4), rgba(255, 255, 255, 0.1), transparent);
  transform: skewX(-25deg) translateX(-300%);
  z-index: 1; /* Devant l'image, derrière le gradient vignette/texte */
  pointer-events: none;
  animation: scanlineSweep 12s infinite cubic-bezier(0.1, 0, 0.3, 1);
  will-change: transform;
}

@keyframes scanlineSweep {
  0%, 85% { transform: skewX(-25deg) translateX(-300%); }
  95%, 100% { transform: skewX(-25deg) translateX(500%); }
}

/* Vignettage pour focaliser l'oeil sur le centre/gauche */
#shopify-section-{{ section.id }} .vibe-header-container::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at 30% 50%, transparent 0%, rgba(8, 26, 50, 0.3) 100%);
  z-index: 1;
  pointer-events: none;
}

/* Ombre interne pour fonder les bords dans l'obscurité */
#shopify-section-{{ section.id }} .vibe-header-container::after {
  content: '';
  position: absolute;
  inset: 0;
  box-shadow: inset 0 0 40px rgba(8, 26, 50, 0.5);
  z-index: 1;
  pointer-events: none;
}

/* Styles Communs pour les images */
.vibe-header-parallax-img,
.vibe-header-mobile-img {
  position: absolute;
  top: -20%; /* Décentré vers le haut avec une plus grande marge */
  left: -5%;
  width: 110%; /* Plus large pour le parallaxe */
  height: 140%; /* Plus haut pour compenser le mouvement horizontal et vertical sans montrer le fond Noir */
  object-fit: cover;
  filter: brightness(0.9) saturate(1.1); /* Moins assombri, couleurs plus vives */
  will-change: transform;
  z-index: 0;
}

/* Masquer l'image mobile par défaut (sur Desktop) */
.vibe-header-mobile-img {
  display: none;
}

#shopify-section-{{ section.id }} .vibe-header-content {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

#shopify-section-{{ section.id }} .vibe-header-overline {
  font-family: 'Inter', sans-serif;
  font-size: 0.83rem;
  font-weight: 700;
  color: #E89D46;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  margin: 0;
  text-shadow: 0 2px 4px rgba(0,0,0,0.5);
}

#shopify-section-{{ section.id }} .vibe-header-title {
  font-family: 'Inter', sans-serif;
  font-size: clamp(3rem, 5vw, 4.5rem);
  font-weight: 900;
  color: #F9F9F9;
  text-transform: uppercase;
  letter-spacing: 0.05em; /* Un peu plus resserré que 0.2em pour Konoha */
  margin: 0;
  text-shadow: 0 2px 15px rgba(0,0,0,0.8), 0 0 20px rgba(232, 157, 70, 0.4);
  animation: pulseGlow 4s infinite alternate;
}

/* Lueur Réactive (Pulse) */
@keyframes pulseGlow {
  0% { text-shadow: 0 0 15px rgba(232, 157, 70, 0.2); }
  100% { text-shadow: 0 0 30px rgba(232, 157, 70, 0.6); }
}

/* Séparateur ambre sous le titre (d'après l'image) */
#shopify-section-{{ section.id }} .vibe-header-line {
  width: 60px;
  height: 3px;
  background-color: #E89D46;
  margin-top: 12px;
  border-radius: 2px;
  box-shadow: 0 0 10px rgba(232, 157, 70, 0.5);
}

@media (max-width: 768px) {
  #shopify-section-{{ section.id }} .vibe-header-section {
    padding: 20px 1.5rem 20px;
  }
  
  #shopify-section-{{ section.id }} .vibe-header-container {
    height: 30vh;
    padding-left: 30px;
    border-radius: 24px;
  }
}

/* Media Query pour basculer les images */
@media (max-width: 768px) {
  /* Si l'image mobile existe, on masque la desktop et on affiche la mobile */
  .has-mobile-image .vibe-header-parallax-img {
    display: none !important;
  }
  .has-mobile-image .vibe-header-mobile-img {
    display: block !important;
  }
}
</style>

{%- assign has_mobile_image = false -%}
{%- if section.settings.background_image_mobile != blank -%}
  {%- assign has_mobile_image = true -%}
{%- endif -%}

<div class="sf-stitch vibe-header-section {% if has_mobile_image %}has-mobile-image{% endif %}">
  <div class="vibe-header-container" id="vibe-parallax-{{ section.id }}">
    
    <!-- Injection du Scanline Effect -->
    <div class="vibe-scanline"></div>

    {%- if section.settings.background_image != blank -%}
      {{ section.settings.background_image | image_url: width: 2200 | image_tag: class: 'vibe-header-parallax-img', loading: 'eager' }}
      
      {%- if has_mobile_image -%}
        {{ section.settings.background_image_mobile | image_url: width: 800 | image_tag: class: 'vibe-header-mobile-img', loading: 'eager' }}
      {%- endif -%}
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'vibe-header-parallax-img' }}
    {%- endif -%}

    <div class="vibe-header-content">
      {%- if section.settings.overline != blank -%}
        <p class="vibe-header-overline">{{ section.settings.overline }}</p>
      {%- endif -%}
      
      {%- if section.settings.title != blank -%}
        <h1 class="vibe-header-title">{{ section.settings.title }}</h1>
        <div class="vibe-header-line"></div>
      {%- endif -%}
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Basic Parallax Effect logic
    const imgDesktop = document.querySelector('#shopify-section-{{ section.id }} .vibe-header-parallax-img');
    const imgMobile = document.querySelector('#shopify-section-{{ section.id }} .vibe-header-mobile-img');
    const container = document.querySelector('#shopify-section-{{ section.id }} .vibe-header-container');
    
    if (container) {
      window.addEventListener('scroll', function() {
        // ... (rest of scroll logic)
        const scrolled = window.pageYOffset;
        const containerTop = container.offsetTop;
        const containerHeight = container.offsetHeight;
        
        // Execute only if section is in viewport to save performance
        if (scrolled + window.innerHeight > containerTop && scrolled < containerTop + containerHeight) {
          const distance = scrolled - containerTop;
          // Slowly move the image down as user scrolls down, using a safe multiplier
          if (imgDesktop) imgDesktop.style.transform = `translateY(${distance * 0.10}px)`; 
          if (imgMobile) imgMobile.style.transform = `translateY(${distance * 0.10}px)`; 
        }
      });
    }
  });
</script>

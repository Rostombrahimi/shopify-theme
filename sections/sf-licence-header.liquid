{% schema %}
{
  "name": "Banderole Cinématique",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Image de fond (Parallaxe)"
    },
    {
      "type": "text",
      "id": "overline",
      "label": "Texte au-dessus (Surtitre)",
      "default": "COLLECTION EXCLUSIVE"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titre Principal",
      "default": "KONOHA"
    },
    {
      "type": "color",
      "id": "glow_color",
      "label": "Couleur de l'Aura (Glow)",
      "default": "#E89D46",
      "info": "Définit la couleur vibrante du halo externe et des accents (ligne, surtitre). Parfait pour teinter selon l'univers."
    }
  ],
  "presets": [
    {
      "name": "Banderole Cinématique (Licence)",
      "category": "Image"
    }
  ]
}
{% endschema %}

<style>
/* Banderole Cinématique - Licence Header */
#shopify-section-{{ section.id }} .vibe-header-section {
  padding: 40px 4rem 20px;
  background-color: var(--illu-night, #081A32);
}

#shopify-section-{{ section.id }} .vibe-header-container {
  position: relative;
  height: 35vh; /* Environ 30-35% de l'écran */
  min-height: 250px;
  max-height: 400px;
  border-radius: 32px;
  overflow: hidden; /* Cache le débordement de l'image parallaxe */
  display: flex;
  align-items: center;
  justify-content: flex-start; /* Aligné à gauche d'après la maquette */
  padding-left: 60px; /* Espace à gauche */
  background: #000;
  /* Lueur Ambiante (Glow) & Micro-Flicker */
  box-shadow: 0 0 100px -20px var(--header-glow);
  animation: organicBoxFlicker 3s infinite alternate;
}

@keyframes organicBoxFlicker {
  0%, 100% { box-shadow: 0 0 100px -20px var(--header-glow); }
  5% { box-shadow: 0 0 110px -15px var(--header-glow); }
  10% { box-shadow: 0 0 90px -25px var(--header-glow); }
  15% { box-shadow: 0 0 105px -18px var(--header-glow); }
  50% { box-shadow: 0 0 85px -30px var(--header-glow); }
  75% { box-shadow: 0 0 115px -10px var(--header-glow); }
  90% { box-shadow: 0 0 95px -22px var(--header-glow); }
}

/* Le "Scanline" ou "Light Sweep" */
#shopify-section-{{ section.id }} .vibe-scanline {
  position: absolute;
  top: 0;
  left: 0;
  width: 25%;
  height: 100%;
  background: linear-gradient(to right, transparent, rgba(255, 255, 255, 0.1), rgba(255, 255, 255, 0.4), rgba(255, 255, 255, 0.1), transparent);
  transform: skewX(-25deg) translateX(-300%);
  z-index: 1; /* Devant l'image, derrière le gradient vignette/texte */
  pointer-events: none;
  animation: scanlineSweep 12s infinite cubic-bezier(0.1, 0, 0.3, 1);
  will-change: transform;
}

@keyframes scanlineSweep {
  0%, 85% { transform: skewX(-25deg) translateX(-300%); }
  95%, 100% { transform: skewX(-25deg) translateX(500%); }
}

/* Vignettage pour focaliser l'oeil sur le centre/gauche */
#shopify-section-{{ section.id }} .vibe-header-container::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at 30% 50%, transparent 0%, rgba(8, 26, 50, 0.7) 100%);
  z-index: 1;
  pointer-events: none;
}

/* Ombre interne pour fonder les bords dans l'obscurité */
#shopify-section-{{ section.id }} .vibe-header-container::after {
  content: '';
  position: absolute;
  inset: 0;
  box-shadow: inset 0 0 60px rgba(8, 26, 50, 0.9);
  z-index: 1;
  pointer-events: none;
}

#shopify-section-{{ section.id }} .vibe-header-parallax-img {
  position: absolute;
  top: -10%; /* Décentré vers le haut pour permettre le défilement */
  left: -5%;
  width: 110%; /* Plus large pour le parallaxe */
  height: 120%; /* Plus haut pour le parallaxe */
  object-fit: cover;
  filter: brightness(0.6) saturate(0.8);
  will-change: transform;
  z-index: 0;
}

#shopify-section-{{ section.id }} .vibe-header-content {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

#shopify-section-{{ section.id }} .vibe-header-overline {
  font-family: 'Inter', sans-serif;
  font-size: 0.83rem;
  font-weight: 700;
  color: var(--header-glow); /* Imprégnation de la vibe couleur */
  text-transform: uppercase;
  letter-spacing: 0.15em;
  margin: 0;
  text-shadow: 0 2px 4px rgba(0,0,0,0.5);
}

#shopify-section-{{ section.id }} .vibe-header-title {
  font-family: 'Inter', sans-serif;
  font-size: clamp(3rem, 5vw, 4.5rem);
  font-weight: 900;
  color: #F9F9F9;
  text-transform: uppercase;
  letter-spacing: 0.05em; /* Un peu plus resserré que 0.2em pour Konoha */
  margin: 0;
  text-shadow: 0 0 20px var(--header-glow-alpha); /* Lueur dynamique discrète */
  animation: pulseTextGlow 4s infinite alternate;
}

/* Lueur Réactive (Pulse) */
@keyframes pulseTextGlow {
  0% { text-shadow: 0 0 15px var(--header-glow-alpha); }
  100% { text-shadow: 0 0 30px var(--header-glow); }
}

/* Séparateur coloré sous le titre */
#shopify-section-{{ section.id }} .vibe-header-line {
  width: 60px;
  height: 3px;
  background-color: var(--header-glow);
  margin-top: 12px;
  border-radius: 2px;
  box-shadow: 0 0 10px var(--header-glow-alpha);
}

@media (max-width: 768px) {
  #shopify-section-{{ section.id }} .vibe-header-section {
    padding: 20px 1.5rem 20px;
  }
  
  #shopify-section-{{ section.id }} .vibe-header-container {
    height: 30vh;
    padding-left: 30px;
    border-radius: 24px;
  }
}
</style>

{%- assign theme_glow = section.settings.glow_color | default: '#E89D46' -%}
{%- assign theme_glow_alpha = theme_glow | color_modify: 'alpha', 0.4 -%}

<div class="sf-stitch vibe-header-section" style="--header-glow: {{ theme_glow }}; --header-glow-alpha: {{ theme_glow_alpha }};">
  <div class="vibe-header-container" id="vibe-parallax-{{ section.id }}">
    
    <!-- Injection du Scanline Effect -->
    <div class="vibe-scanline"></div>

    {%- if section.settings.background_image != blank -%}
      {{ section.settings.background_image | image_url: width: 2200 | image_tag: class: 'vibe-header-parallax-img', loading: 'eager' }}
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'vibe-header-parallax-img' }}
    {%- endif -%}

    <div class="vibe-header-content">
      {%- if section.settings.overline != blank -%}
        <p class="vibe-header-overline">{{ section.settings.overline }}</p>
      {%- endif -%}
      
      {%- if section.settings.title != blank -%}
        <h1 class="vibe-header-title">{{ section.settings.title }}</h1>
        <div class="vibe-header-line"></div>
      {%- endif -%}
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Basic Parallax Effect logic
    const img = document.querySelector('#shopify-section-{{ section.id }} .vibe-header-parallax-img');
    const container = document.querySelector('#shopify-section-{{ section.id }} .vibe-header-container');
    
    if (img && container) {
      window.addEventListener('scroll', function() {
        const scrolled = window.pageYOffset;
        const containerTop = container.offsetTop;
        const containerHeight = container.offsetHeight;
        
        // Execute only if section is in viewport to save performance
        if (scrolled + window.innerHeight > containerTop && scrolled < containerTop + containerHeight) {
          const distance = scrolled - containerTop;
          // Slowly move the image down as user scrolls down
          img.style.transform = `translateY(${distance * 0.15}px)`; 
        }
      });
    }
  });
</script>

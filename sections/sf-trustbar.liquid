<div class="sf-stitch sf-trustbar trustbar-section">
  <style>
    /* Trust Bar Haute Tension - sf-trustbar.css */
    .trustbar-section {
      background-color: var(--illu-bg-night);
      padding: 3rem 4rem;
      border-bottom: 1px solid rgba(255, 255, 255, 0.03);
    }

    .trustbar-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 2rem;
      max-width: 1200px;
      margin: 0 auto;
    }

    .trust-item {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 1rem;
    }

    .trust-icon-container {
      width: 54px; /* +12.5% scale for harmony */
      height: 54px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--illu-accent-amber);
      transition: var(--illu-transition-soft);
    }

    .trust-icon-container svg {
      width: 100%;
      height: 100%;
      vector-effect: non-scaling-stroke;
      filter: drop-shadow(0 0 5px rgba(232, 157, 70, 0.2));
      transition: var(--illu-transition-soft);
    }

    .trust-item:hover .trust-icon-container svg {
      filter: drop-shadow(0 0 8px rgba(232, 157, 70, 0.4));
    }

    .trust-text {
      color: var(--illu-text-cream);
      font-size: 1.06rem; /* +10% */
      font-weight: var(--fw-medium);
      letter-spacing: 0.03em;
      opacity: 0.9;
      margin: 0;
    }

    .trust-subtitle {
      color: var(--illu-text-cream);
      font-size: 0.91rem; /* +10% */
      opacity: 0.5;
      font-weight: var(--fw-light);
      margin-top: -0.5rem; /* remonte légèrement vers le titre */
    }

    .trust-seo-line {
      position: relative;
      margin-top: 3.5rem;
      padding-top: 1.5rem;
      text-align: center;
      color: var(--illu-text-cream);
      font-size: 1.1rem;
      font-weight: var(--fw-light);
      opacity: 0.85;
      letter-spacing: 0.01em;
    }

    .trust-seo-line::before {
      content: '';
      position: absolute;
      top: 0;
      left: 50%;
      transform: translateX(-50%);
      width: 150px;
      height: 1px;
      background: linear-gradient(90deg, rgba(255,255,255,0) 0%, rgba(255,255,255,0.6) 50%, rgba(255,255,255,0) 100%);
      box-shadow: 0 0 8px rgba(255, 255, 255, 0.3);
    }

    /* Mobile Responsive */
    @media screen and (max-width: 768px) {
      .trustbar-section {
        padding: 2.5rem 1.5rem;
      }
      .trustbar-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;
      }
    }

    @media screen and (max-width: 480px) {
      .trustbar-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <div class="sf-container">
    <div class="trustbar-grid">
      {%- for block in section.blocks -%}
        <div class="trust-item" {{ block.shopify_attributes }}>
          {%- if block.settings.icon != blank -%}
             <div class="trust-icon-container">
                {{ block.settings.icon }}
             </div>
          {%- endif -%}
          {%- if block.settings.title != blank -%}
            <h4 class="trust-text h5">{{ block.settings.title | escape }}</h4>
          {%- endif -%}
          {%- if block.settings.subtitle != blank -%}
            <div class="trust-subtitle">{{ block.settings.subtitle | escape }}</div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

    {%- if section.settings.seo_text != blank -%}
      <div class="trust-seo-line">
        {{ section.settings.seo_text }}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "SF Trust Bar",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "seo_text",
      "label": "Ligne SEO (Texte de bas de section)",
      "default": "Des créations uniques pour les setups, bureaux pro et coins cocons."
    }
  ],
  "blocks": [

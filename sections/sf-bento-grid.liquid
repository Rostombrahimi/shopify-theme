<div class="sf-stitch sf-bento-grid bento-section">
  <style>
    /* Bento des Univers - sf-bento-grid.css */
    .bento-section {
      background-color: var(--illu-bg-night);
      padding: 80px 40px;
    }

    .bento-header {
      text-align: center;
      max-width: 800px;
      margin: 0 auto 60px auto;
    }

    .bento-subtitle {
      color: var(--illu-accent-amber);
      font-size: 1.24rem; /* ~18px for better PC visibility matched with story section */
      font-weight: var(--fw-bold);
      text-transform: uppercase;
      letter-spacing: 0.15em;
      margin-bottom: 1.5rem;
    }

    .bento-title {
      font-size: clamp(2.5rem, 4vw, 3.5rem);
      color: var(--illu-text-cream);
      line-height: 1.1;
      margin-bottom: 1.5rem;
    }

    .bento-title em {
      font-style: normal;
      color: var(--illu-accent-amber);
    }

    .bento-desc {
      font-size: 1.24rem;
      color: var(--illu-text-cream);
      opacity: 0.75;
      line-height: 1.6;
    }

    .bento-grid {
      display: grid;
      grid-template-columns: repeat(12, 1fr);
      grid-template-rows: repeat(2, 400px);
      gap: 24px;
      max-width: 1400px;
      margin: 0 auto;
    }

    .bento-card {
      position: relative;
      border-radius: var(--illu-radius-chubby);
      overflow: hidden;
      background-color: var(--illu-bg-night-light);
      transition: var(--illu-transition-soft);
      display: block; /* Make it clickable if there's a link */
      text-decoration: none;
      isolation: isolate; /* Create new stacking context */
    }

    /* Spécificités de la grille */
    .card-quotidien { grid-column: span 7; grid-row: span 2; }
    .card-visuel { grid-column: span 5; grid-row: span 1; }
    .card-cocon { grid-column: span 5; grid-row: span 1; }

    /* Globals & Resets applied to bento */
    .bento-card * {
      min-width: 0;
      min-height: 0;
    }

    .bento-image {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.8s ease, filter 0.8s ease;
      /* Image Filter base */
      filter: saturate(0.9) brightness(0.8);
      z-index: 1;
    }

    .bento-card:hover .bento-image {
      transform: scale(1.05);
      /* Hover "Allumage" filter */
      filter: saturate(1.1) brightness(1);
    }

    .bento-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(8, 26, 50, 0.95) 0%, rgba(8, 26, 50, 0.4) 50%, rgba(8, 26, 50, 0) 100%);
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      padding: 40px;
      z-index: 2;
    }

    /* Lueur de Profondeur */
    .bento-card::after {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at 50% 100%, rgba(232, 157, 70, 0.15) 0%, rgba(232, 157, 70, 0) 60%);
      mix-blend-mode: overlay;
      z-index: 3;
      pointer-events: none;
      transition: opacity 0.8s ease;
      opacity: 0.5;
    }

    .bento-card:hover::after {
      opacity: 1; /* S'intensifie au survol */
    }

    .bento-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      align-self: flex-start;
      padding: 6px 16px;
      /* Glassmorphism */
      background: rgba(255, 255, 255, 0.1);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid rgba(255, 255, 255, 0.15);
      border-radius: 99px;
      font-size: 0.83rem;
      font-weight: var(--fw-bold);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 16px;
      color: var(--illu-accent-amber);
    }

    .bento-badge svg {
      width: 16px;
      height: 16px;
    }

    .bento-card-content {
      position: relative;
      z-index: 4; /* Above everything */
    }

    .bento-card h3 {
      font-size: 2.75rem;
      color: var(--illu-text-cream);
      margin: 0 0 1rem 0;
      line-height:  1.1;
    }
    
    .card-visuel h3, .card-cocon h3 {
      font-size: 2.2rem; /* slightly smaller headers for the side cards */
    }

    .bento-card p {
      font-size: 1.1rem;
      color: var(--illu-text-cream);
      opacity: 0.85;
      margin: 0 0 2rem 0;
      line-height: 1.5;
    }

    .bento-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.75rem;
      color: var(--illu-text-cream);
      font-weight: var(--fw-bold);
      font-size: 0.99rem;
      transition: color 0.3s ease, background 0.3s ease, border-color 0.3s ease;
      /* Base pill style for smaller cards */
      padding: 0.6rem 1.25rem;
      border: 1px solid rgba(255, 255, 255, 0.4);
      border-radius: var(--illu-radius-pill);
    }

    .card-quotidien .bento-btn {
      background: var(--illu-accent-amber);
      color: var(--illu-bg-night);
      padding: 0.8rem 2rem; /* Allongé pour l'effet Pill parfait */
      border: 1px solid var(--illu-accent-amber);
      box-shadow: var(--illu-glow-amber);
    }

    /* Animation de la flèche au survol de la carte */
    .bento-btn svg {
      transition: transform 0.3s ease, color 0.3s ease;
    }

    .bento-card:hover .bento-btn {
      color: var(--illu-accent-amber);
      border-color: var(--illu-accent-amber);
    }
    
    .card-quotidien:hover .bento-btn {
      color: var(--illu-bg-night); /* Keep text dark on the solid orange button */
    }

    .bento-card:hover .bento-btn svg {
      transform: translateX(4px);
    }

    /* Mobile Responsive */
    @media screen and (max-width: 990px) {
      .bento-section {
        padding: 60px 20px;
      }
      .bento-grid {
        grid-template-columns: 1fr;
        grid-template-rows: auto auto auto;
        gap: 20px;
      }
      .card-quotidien, .card-visuel, .card-cocon {
        grid-column: span 1;
        grid-row: span 1;
        min-height: 400px;
      }
      .bento-overlay {
        padding: 30px;
      }
      .bento-card h3 {
        font-size: 2.2rem;
      }
      .card-visuel h3, .card-cocon h3 {
        font-size: 1.93rem; 
      }
    }
  </style>

  <div class="bento-header">
    {%- if section.settings.subtitle != blank -%}
      <div class="bento-subtitle">{{ section.settings.subtitle | escape }}</div>
    {%- endif -%}
    {%- if section.settings.title != blank -%}
      <h2 class="bento-title">
        {{ section.settings.title | replace: '<em>', '<em>' | replace: '</em>', '</em>' }}
      </h2>
    {%- endif -%}
    {%- if section.settings.description != blank -%}
      <div class="bento-desc">
        {{ section.settings.description }}
      </div>
    {%- endif -%}
  </div>

  <div class="bento-grid">
    {%- for block in section.blocks -%}
      {%- liquid
        case forloop.index
          when 1
            assign card_class = 'card-quotidien'
          when 2
            assign card_class = 'card-visuel'
          when 3
            assign card_class = 'card-cocon'
        endcase
      -%}

      <a href="{{ block.settings.link | default: '#' }}" class="bento-card {{ card_class }}" {{ block.shopify_attributes }}>
        {%- if block.settings.image != blank -%}
          <img
            src="{{ block.settings.image | image_url: width: 1200 }}"
            alt="{{ block.settings.image.alt | escape }}"
            class="bento-image"
            loading="lazy"
            width="{{ block.settings.image.width }}"
            height="{{ block.settings.image.height }}"
          >
        {%- else -%}
          {{ 'image' | placeholder_svg_tag: 'bento-image placeholder-svg' }}
        {%- endif -%}

        <div class="bento-overlay">
          <div class="bento-card-content">
            {%- if block.settings.badge_text != blank -%}
              <div class="bento-badge">
                {%- if block.settings.badge_icon != blank -%}
                  {{ block.settings.badge_icon }}
                {%- endif -%}
                {{ block.settings.badge_text | escape }}
              </div>
            {%- endif -%}
            
            {%- if block.settings.title != blank -%}
              <h3>{{ block.settings.title | escape }}</h3>
            {%- endif -%}
            
            {%- if block.settings.text != blank -%}
              <p>{{ block.settings.text | escape }}</p>
            {%- endif -%}
            
            {%- if block.settings.btn_text != blank -%}
              <span class="bento-btn">
                {{ block.settings.btn_text | escape }}
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            {%- endif -%}
          </div>
        </div>
      </a>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "SF Bento Univers",
  "tag": "section",
  "class": "section",
  "max_blocks": 3,
  "settings": [
    {
      "type": "text",

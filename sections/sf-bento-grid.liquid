      "info": "Utilisez <em>mot</em> pour la couleur ambre"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Explorez nos trois univers distincts, conçus pour sublimer chaque moment de votre vie, du travail à la détente.</p>"
    }
  ],
  "blocks": [
    {
      "type": "universe_card",
      "name": "Carte Univers",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image de fond"
        },
        {
          "type": "html",
          "id": "badge_icon",
          "label": "Badge Icon SVG (Optionnel)"
        },
        {
          "type": "text",
          "id": "badge_text",
          "label": "Texte du Badge",
          "default": "Catégorie"
        },
        {
          "type": "text",
          "id": "title",

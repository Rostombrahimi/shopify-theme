    }
  ],
  "presets": [
    {
      "name": "SF Bento Univers",
      "category": "Image",
      "blocks": [
        {
          "type": "universe_card",
          "settings": {
            "badge_icon": "<svg width='20' height='20' viewBox='0 0 24 24' fill='none' xmlns='http://www.w3.org/2000/svg'><path d='M7 21H17M12 21V18M12 18L8 8H16L12 18ZM12 8V3M12 3C10.3431 3 9 4.34315 9 6C9 7.65685 10.3431 9 12 9C13.6569 9 15 7.65685 15 6C15 4.34315 13.6569 3 12 3Z' stroke='currentColor' stroke-width='1.2' stroke-linecap='round' stroke-linejoin='round'/></svg>",
            "badge_text": "PRODUCTIVITÉ & CLARTÉ",
            "title": "Espace Quotidien",
            "text": "Des luminaires conçus pour l'efficacité. Une lumière pure qui accompagne votre concentration sans fatigue visuelle.",
            "btn_text": "Explorer l'Espace Quotidien"
          }
        },
        {
          "type": "universe_card",
          "settings": {
            "badge_icon": "<svg width='20' height='20' viewBox='0 0 24 24' fill='none' xmlns='http://www.w3.org/2000/svg'><path d='M6 12H8M7 11V13M15 11V11.01M18 13V13.01M15 16C15 16 14 14.5 12 14.5C10 14.5 9 16 9 16M18 9C18 7.34315 16.6569 6 15 6H9C7.34315 6 6 7.34315 6 9V15C6 16.6569 7.34315 18 9 18H15C16.6569 18 18 16.6569 18 15V9Z' stroke='currentColor' stroke-width='1.2' stroke-linecap='round' stroke-linejoin='round'/></svg>",
            "badge_text": "IMMERSION & GAMING",

{% schema %}
{
  "name": "Impact Quotidien",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "BÉNÉFICES QUOTIDIENS"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Impact au Quotidien"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Découvrez comment une lumière douce transforme vos nuits. Chaque détail est pensé pour créer une atmosphère de sérénité fonctionnelle."
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Benefit Card",
      "limit": 3,
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "bulb", "label": "Bulb/Intensité" },
            { "value": "eye", "label": "Eye/Visibilité" },
            { "value": "sunset", "label": "Sunset/Transition" }
          ],
          "default": "bulb"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Intensité Maîtrisée"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Intensité maîtrisée et non éblouissante pour une vision immédiate sans inconfort."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Impact Quotidien",
      "blocks": [
        { "type": "card", "settings": { "icon": "bulb", "title": "Intensité<br>Maîtrisée", "text": "Intensité maîtrisée et non éblouissante pour une vision immédiate sans inconfort." } },
        { "type": "card", "settings": { "icon": "eye", "title": "Visibilité sans<br>Stimulation", "text": "Visibilité suffisante pour les soins, sans stimuler ni réveiller complètement votre enfant." } },
        { "type": "card", "settings": { "icon": "sunset", "title": "Transition Douce", "text": "Une transition lumineuse infiniment douce qui préserve la mélatonine et le cycle du sommeil." } }
      ]
    }
  ]
}
{% endschema %}

<style>
.daily-impact-section {
  background-color: #081A32;
  padding: 100px 4rem;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

.daily-impact-header {
  max-width: 1300px;
  margin: 0 auto;
  margin-bottom: 4rem;
}

.daily-impact-badge {
  color: #E89D46;
  font-size: 0.83rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  margin-bottom: 1.5rem;
  display: block;
}

.daily-impact-h2 {
  font-size: clamp(2.75rem, 4.4vw, 3.85rem);
  color: #F9F9F9;
  font-weight: 600;
  line-height: 1.1;
  margin-bottom: 1.5rem;
  letter-spacing: -0.02em;
}

.daily-impact-desc {
  font-size: 1.26rem;
  color: rgba(249, 249, 249, 0.85); /* Plus clair d'après mockup */
  line-height: 1.6;
  max-width: 700px;
}

/* Grid & Cards */
.daily-impact-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 32px;
  max-width: 1300px;
  margin: 0 auto;
}

.impact-card {
  background: rgba(255, 255, 255, 0.02);
  border: 1px solid rgba(255, 255, 255, 0.05);
  border-radius: 32px;
  padding: 40px;
  display: flex;
  flex-direction: column;
  align-items: flex-start; /* Alignement à gauche sur mockup */
  text-align: left;
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px); /* Safari support */
  transition: all 0.4s ease;
}

.impact-card:hover {
  transform: translateY(-8px);
  border-color: rgba(232, 157, 70, 0.3);
  background: rgba(255, 255, 255, 0.04);
}

/* Icon Container & Glow */
.impact-icon-wrapper {
  position: relative;
  width: 56px;
  height: 56px;
  border-radius: 16px;
  background: rgba(255, 255, 255, 0.05);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 2rem;
}

/* Halo dynamique derrière l'icône */
.impact-icon-wrapper::before {
  content: '';
  position: absolute;
  inset: -10px;
  background: radial-gradient(circle, rgba(232, 157, 70, 0.3) 0%, transparent 70%);
  z-index: 0;
  opacity: 0;
  transition: opacity 0.4s ease;
  mix-blend-mode: plus-lighter;
}

.impact-card:hover .impact-icon-wrapper::before {
  opacity: 1;
}

.impact-icon {
  color: #E89D46;
  position: relative;
  z-index: 1;
  width: 24px;
  height: 24px;
  filter: drop-shadow(0 0 12px rgba(232, 157, 70, 0.25));
}

.impact-icon svg {
  width: 100%;
  height: 100%;
}

.impact-card h3 {
  color: #F9F9F9;
  font-size: 1.65rem;
  font-weight: 600;
  margin: 0 0 1rem 0;
  line-height: 1.3;
}

.impact-card p {
  color: rgba(249, 249, 249, 0.65);
  font-size: 1.1rem;
  line-height: 1.6;
  margin: 0;
}

@media screen and (max-width: 1024px) {
  .daily-impact-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media screen and (max-width: 768px) {
  .daily-impact-section {
    padding: 80px 2rem;
  }
  .daily-impact-grid {
    grid-template-columns: 1fr;
    gap: 24px;
  }
  .daily-impact-header {
    margin-bottom: 3rem;
  }
}
</style>

<section class="daily-impact-section">
  <div class="daily-impact-header">
    {% if section.settings.badge_text != blank %}
      <span class="daily-impact-badge">{{ section.settings.badge_text }}</span>
    {% endif %}
    
    {% if section.settings.title != blank %}
      <h2 class="daily-impact-h2">{{ section.settings.title }}</h2>
    {% endif %}
    
    {% if section.settings.description != blank %}
      <p class="daily-impact-desc">{{ section.settings.description }}</p>
    {% endif %}
  </div>

  <div class="daily-impact-grid">
    {% for block in section.blocks %}
      <div class="impact-card" {{ block.shopify_attributes }}>
        <div class="impact-icon-wrapper">
          <div class="impact-icon">
            {% case block.settings.icon %}
              {% when 'bulb' %}
                <!-- Lampe/Intensité -->
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M12 16V18" stroke="#E89D46" stroke-width="1.8" stroke-linecap="round"/>
                  <path d="M9 16H15" stroke="#E89D46" stroke-width="1.8" stroke-linecap="round"/>
                  <path d="M9 20H15" stroke="#E89D46" stroke-width="1.8" stroke-linecap="round"/>
                  <path d="M6 8C6 4.68629 8.68629 2 12 2C15.3137 2 18 4.68629 18 8C18 10.3698 16.626 12.4223 14.6151 13.3986" stroke="#E89D46" stroke-width="1.8" stroke-linecap="round"/>
                  <path d="M9.38491 13.3986C7.37397 12.4223 6 10.3698 6 8" stroke="#E89D46" stroke-width="1.8" stroke-linecap="round"/>
                  <path d="M1 8H3" stroke="#E89D46" stroke-width="1.8" stroke-linecap="round"/>
                  <path d="M21 8H23" stroke="#E89D46" stroke-width="1.8" stroke-linecap="round"/>
                  <path d="M4 15L5.5 13.5" stroke="#E89D46" stroke-width="1.8" stroke-linecap="round"/>
                  <path d="M20 15L18.5 13.5" stroke="#E89D46" stroke-width="1.8" stroke-linecap="round"/>
                </svg>
              {% when 'eye' %}
                <!-- Œil/Visibilité -->
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M2 12C2 12 5.5 5 12 5C18.5 5 22 12 22 12C22 12 18.5 19 12 19C5.5 19 2 12 2 12Z" stroke="#E89D46" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                  <circle cx="12" cy="12" r="3" stroke="#E89D46" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              {% when 'sunset' %}
                <!-- Soleil Couchant/Transition -->
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M17 18A5 5 0 0 0 7 18" stroke="#E89D46" stroke-width="1.8" stroke-linecap="round"/>
                  <path d="M12 2V4" stroke="#E89D46" stroke-width="1.8" stroke-linecap="round"/>
                  <path d="M4.22168 10.2217L5.63589 11.6359" stroke="#E89D46" stroke-width="1.8" stroke-linecap="round"/>
                  <path d="M19.7783 10.2217L18.3641 11.6359" stroke="#E89D46" stroke-width="1.8" stroke-linecap="round"/>
                  <path d="M1.5 18H22.5" stroke="#E89D46" stroke-width="1.8" stroke-linecap="round"/>
                </svg>
            {% endcase %}
          </div>
        </div>
        <h3>{{ block.settings.title }}</h3>
        <p>{{ block.settings.text }}</p>
      </div>
    {% endfor %}
  </div>
</section>

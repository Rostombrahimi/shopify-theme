{% schema %}
{
  "name": "Footer Petit Cocon",
  "settings": [
    {
      "type": "text",
      "id": "logo_text",
      "label": "Texte du Logo",
      "default": "Illuminées"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Slogan (Signature)",
      "default": "\"Parce que chaque nuit est une promesse de douceur.\""
    },
    {
      "type": "text",
      "id": "newsletter_title",
      "label": "Titre Newsletter",
      "default": "Recevoir nos conseils bienveillants"
    },
    {
      "type": "text",
      "id": "newsletter_button",
      "label": "Bouton Newsletter",
      "default": "S'inscrire"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Texte Copyright",
      "default": "© 2024 Illuminées - Petit Cocon. Tous droits réservés."
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Menu (Colonne)",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Titre de la colonne",
          "default": "Liens"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu de navigation"
        }
      ]
    },
    {
      "type": "link_list_with_icons",
      "name": "Menu avec Icônes",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Titre de la colonne",
          "default": "Sécurité & Engagement"
        },
        {
          "type": "text",
          "id": "link_1_text",
          "label": "Lien 1 - Texte",
          "default": "Normes CE"
        },
        {
          "type": "url",
          "id": "link_1_url",
          "label": "Lien 1 - URL"
        },
        {
          "type": "html",
          "id": "link_1_icon",
          "label": "Lien 1 - SVG Icon"
        },
        {
          "type": "text",
          "id": "link_2_text",
          "label": "Lien 2 - Texte",
          "default": "Matériaux sains"
        },
        {
          "type": "url",
          "id": "link_2_url",
          "label": "Lien 2 - URL"
        },
        {
          "type": "html",
          "id": "link_2_icon",
          "label": "Lien 2 - SVG Icon"
        },
        {
          "type": "text",
          "id": "link_3_text",
          "label": "Lien 3 - Texte",
          "default": "Tests labo"
        },
        {
          "type": "url",
          "id": "link_3_url",
          "label": "Lien 3 - URL"
        },
        {
          "type": "html",
          "id": "link_3_icon",
          "label": "Lien 3 - SVG Icon"
        }
      ]
    },
    {
      "type": "bottom_links",
      "name": "Liens du bas",
      "limit": 1,
      "settings": [
        {
          "type": "link_list",
          "id": "bottom_menu",
          "label": "Menu des liens légaux (Mentions, CGV, etc.)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer Cocon Signature",
      "blocks": [
        {
          "type": "link_list",
          "settings": {
            "title": "Univers Petit Cocon"
          }
        },
        {
          "type": "link_list",
          "settings": {
            "title": "Conseils Parents"
          }
        },
        {
          "type": "link_list_with_icons",
          "settings": {
            "title": "Sécurité & Engagement",
            "link_1_text": "Normes CE",
            "link_1_icon": "<svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10\"/><path d=\"m9 12 2 2 4-4\"/></svg>",
            "link_2_text": "Matériaux sains",
            "link_2_icon": "<svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z\"/></svg>",
            "link_3_text": "Tests labo",
            "link_3_icon": "<svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M10 2v7.31\"/><path d=\"M14 9.3V1.99\"/><path d=\"M8.5 2h7\"/><path d=\"M14 9.3a6.5 6.5 0 1 1-4 0\"/><path d=\"M5.52 16h12.96\"/></svg>"
          }
        },
        {
          "type": "link_list",
          "settings": {
            "title": "Aide & Contact"
          }
        },
        {
          "type": "bottom_links"
        }
      ]
    }
  ]
}
{% endschema %}

<style>
/* Footer Cocon - sf-footer-cocon.liquid */
#shopify-section-{{ section.id }} .footer-cocon {
  background-color: var(--illu-night, #081A32);
  padding: 80px 5% 40px;
  border-top: 1px solid rgba(255, 255, 255, 0.05);
  position: relative;
  font-family: inherit;
  color: var(--illu-cream, #F9F9F9);
  overflow: hidden; /* Empêcher le glow de déborder */
}

/* Lien Reset & Hover State global pour le footer */
#shopify-section-{{ section.id }} .footer-cocon a {
  color: inherit;
  text-decoration: none;
  transition: opacity 0.3s ease, color 0.3s ease;
  opacity: 0.6; /* opacity-link-dim */
}

#shopify-section-{{ section.id }} .footer-cocon a:hover {
  opacity: 1;
  color: var(--illu-accent-amber, #E89D46);
}

/* Lueur de Fin (Lumière Résiduelle) */
#shopify-section-{{ section.id }} .footer-cocon-glow {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 80%;
  height: 300px;
  background: radial-gradient(circle, rgba(232, 157, 70, 0.08) 0%, transparent 60%);
  pointer-events: none;
  z-index: 0;
}

#shopify-section-{{ section.id }} .footer-cocon-inner {
  position: relative;
  z-index: 1;
  max-width: 1440px;
  margin: 0 auto;
}

/* Grille des menus */
#shopify-section-{{ section.id }} .footer-cocon-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 3rem; /* footer-gap */
  margin-bottom: 5rem;
}

#shopify-section-{{ section.id }} .footer-col-title {
  color: var(--illu-accent-amber, #E89D46);
  font-size: 1.1rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  font-weight: 700;
  margin-bottom: 2rem;
}

#shopify-section-{{ section.id }} .footer-menu-list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
}

#shopify-section-{{ section.id }} .footer-menu-list li {
  font-size: 1.26rem;
  font-weight: 400;
}

/* Menu avec Icônes spécifiquement */
#shopify-section-{{ section.id }} .footer-icon-link {
  display: flex;
  align-items: center;
  gap: 10px;
}

#shopify-section-{{ section.id }} .footer-icon-link svg {
  color: var(--illu-accent-amber, #E89D46); /* Toujours colorer les icônes */
}

#shopify-section-{{ section.id }} .footer-icon-link:hover svg {
  filter: drop-shadow(0 0 5px rgba(232, 157, 70, 0.5));
}

/* Séparateur pour la Zone Signature */
#shopify-section-{{ section.id }} .footer-separator {
  width: 100%;
  height: 1px;
  background: rgba(255, 255, 255, 0.05); /* Ligne 1px subtile */
  margin-bottom: 3rem;
}

/* Bloc Signature Centrale */
#shopify-section-{{ section.id }} .footer-signature-block {
  text-align: center;
  margin-bottom: 4rem;
}

#shopify-section-{{ section.id }} .footer-cocon-logo {
  font-size: 2.75rem;
  color: var(--illu-cream, #F9F9F9);
  font-weight: 800;
  margin-bottom: 1rem;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 12px;
}

#shopify-section-{{ section.id }} .footer-cocon-logo svg {
  color: var(--illu-accent-amber, #E89D46);
  width: 32px;
  height: 32px;
}

#shopify-section-{{ section.id }} .footer-cocon-tagline {
  color: rgba(249, 249, 249, 0.6);
  font-style: italic;
  font-size: 1.38rem;
  font-weight: 300;
  margin-bottom: 3rem;
}

/* Formulaire Newsletter style Chubby/Glass */
#shopify-section-{{ section.id }} .footer-newsletter-form {
  max-width: 450px;
  margin: 0 auto;
  text-align: center;
}

#shopify-section-{{ section.id }} .newsletter-title {
  color: rgba(249, 249, 249, 0.8);
  font-size: 1.1rem;
  margin-bottom: 1.25rem;
  display: block;
}

#shopify-section-{{ section.id }} .newsletter-input-group {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.03); /* Glass Input */
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 99px; /* Chubby style */
  padding: 6px 6px 6px 24px;
  backdrop-filter: blur(5px);
  -webkit-backdrop-filter: blur(5px);
  transition: border-color 0.3s ease;
}

#shopify-section-{{ section.id }} .newsletter-input-group:focus-within {
  border-color: rgba(232, 157, 70, 0.5);
  background: rgba(255, 255, 255, 0.05);
}

#shopify-section-{{ section.id }} .newsletter-input {
  flex: 1;
  background: transparent;
  border: none;
  outline: none;
  color: var(--illu-cream, #F9F9F9);
  font-size: 1.21rem;
  font-family: inherit;
}

#shopify-section-{{ section.id }} .newsletter-input::placeholder {
  color: rgba(249, 249, 249, 0.4);
}

#shopify-section-{{ section.id }} .newsletter-btn {
  background: var(--illu-accent-amber, #E89D46);
  color: var(--illu-night, #081A32);
  border: none;
  border-radius: 99px;
  padding: 14px 28px;
  font-weight: 700;
  font-size: 1.21rem;
  cursor: pointer;
  transition: all 0.3s ease;
  font-family: inherit;
}

#shopify-section-{{ section.id }} .newsletter-btn:hover {
  background: #f0ab5a;
  box-shadow: 0 4px 15px rgba(232, 157, 70, 0.3);
}

/* Zone du Bas (Copyright & Légaux) */
#shopify-section-{{ section.id }} .footer-bottom-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 20px;
  padding-top: 2rem;
  border-top: 1px solid rgba(255, 255, 255, 0.05);
  font-size: 1.1rem;
}

#shopify-section-{{ section.id }} .footer-copyright {
  color: rgba(249, 249, 249, 0.5);
}

#shopify-section-{{ section.id }} .footer-bottom-links {
  display: flex;
  gap: 24px;
  list-style: none;
  padding: 0;
  margin: 0;
}

#shopify-section-{{ section.id }} .footer-socials {
  display: flex;
  gap: 16px;
}

#shopify-section-{{ section.id }} .footer-socials a {
  opacity: 0.5;
}

#shopify-section-{{ section.id }} .footer-socials a:hover {
  opacity: 1;
  color: var(--illu-cream, #F9F9F9); /* Hover neutre pour les RS */
}

/* Responsive */
@media (max-width: 1024px) {
  #shopify-section-{{ section.id }} .footer-cocon-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 4rem 2rem;
  }
}

@media (max-width: 768px) {
  #shopify-section-{{ section.id }} .footer-cocon {
    padding: 60px 4% 30px;
  }
  #shopify-section-{{ section.id }} .footer-bottom-bar {
    flex-direction: column;
    text-align: center;
    gap: 16px;
  }
  #shopify-section-{{ section.id }} .footer-bottom-links {
    flex-wrap: wrap;
    justify-content: center;
    gap: 16px;
  }
}

@media (max-width: 600px) {
  #shopify-section-{{ section.id }} .footer-cocon-grid {
    grid-template-columns: 1fr; /* Passage en 1 colonne sur mobile */
    text-align: center;
  }
  #shopify-section-{{ section.id }} .footer-icon-link {
    justify-content: center;
  }
  #shopify-section-{{ section.id }} .newsletter-input-group {
    flex-direction: column;
    padding: 6px;
    border-radius: 20px;
  }
  #shopify-section-{{ section.id }} .newsletter-input {
    width: 100%;
    padding: 12px 18px;
    text-align: center;
  }
  #shopify-section-{{ section.id }} .newsletter-btn {
    width: 100%;
  }
}
</style>

<div class="sf-stitch footer-cocon">
  <!-- Glow (Lumière de Fin) -->
  <div class="footer-cocon-glow"></div>

  <div class="footer-cocon-inner">
    
    <!-- Colonnes du Menu -->
    <div class="footer-cocon-grid">
      {%- for block in section.blocks -%}
        
        {%- if block.type == 'link_list' -%}
          <div class="footer-col" {{ block.shopify_attributes }}>
            <h3 class="footer-col-title">{{ block.settings.title | escape }}</h3>
            {%- if block.settings.menu != blank -%}
              <ul class="footer-menu-list">
                {%- for link in block.settings.menu.links -%}
                  <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                {%- endfor -%}
              </ul>
            {%- else -%}
              <ul class="footer-menu-list">
                <li><a href="#">Lien par défaut 1</a></li>
                <li><a href="#">Lien par défaut 2</a></li>
                <li><a href="#">Lien par défaut 3</a></li>
              </ul>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- if block.type == 'link_list_with_icons' -%}
          <div class="footer-col" {{ block.shopify_attributes }}>
            <h3 class="footer-col-title">{{ block.settings.title | escape }}</h3>
            <ul class="footer-menu-list">
              {%- if block.settings.link_1_text != blank -%}
                <li>
                  <a href="{{ block.settings.link_1_url | default: '#' }}" class="footer-icon-link">
                    {%- if block.settings.link_1_icon != blank -%}{{ block.settings.link_1_icon }}{%- endif -%}
                    {{ block.settings.link_1_text | escape }}
                  </a>
                </li>
              {%- endif -%}
              {%- if block.settings.link_2_text != blank -%}
                <li>
                  <a href="{{ block.settings.link_2_url | default: '#' }}" class="footer-icon-link">
                    {%- if block.settings.link_2_icon != blank -%}{{ block.settings.link_2_icon }}{%- endif -%}
                    {{ block.settings.link_2_text | escape }}
                  </a>
                </li>
              {%- endif -%}
              {%- if block.settings.link_3_text != blank -%}
                <li>
                  <a href="{{ block.settings.link_3_url | default: '#' }}" class="footer-icon-link">
                    {%- if block.settings.link_3_icon != blank -%}{{ block.settings.link_3_icon }}{%- endif -%}
                    {{ block.settings.link_3_text | escape }}
                  </a>
                </li>
              {%- endif -%}
            </ul>
          </div>
        {%- endif -%}

      {%- endfor -%}
    </div>

    <div class="footer-separator"></div>

    <!-- Section Signature & Newsletter -->
    <div class="footer-signature-block">
      <div class="footer-cocon-logo">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 45 32" fill="none">
          <path d="M5 25.0312H40V28.0312H5V25.0312Z" fill="currentColor"/>
          <path d="M22.5 19.0312C18.675 19.0312 15.3562 21.1312 13.5187 24.2812H31.4812C29.6437 21.1312 26.325 19.0312 22.5 19.0312Z" fill="currentColor"/>
          <path d="M24 10.0312H21V16.0312H24V10.0312Z" fill="currentColor"/>
          <path d="M12.45 13.1212L10.3312 10.9837L8.2125 13.1025L10.3312 15.24L12.45 13.1212Z" fill="currentColor"/>
          <path d="M34.6687 10.9837L32.55 13.1212L34.6687 15.24L36.7875 13.1025L34.6687 10.9837Z" fill="currentColor"/>
        </svg>
        {{ section.settings.logo_text | escape }}
      </div>
      
      <div class="footer-cocon-tagline">
        {{ section.settings.tagline | escape }}
      </div>

      <div class="footer-newsletter-form">
        <span class="newsletter-title">{{ section.settings.newsletter_title | escape }}</span>
        {%- form 'customer', id: 'ContactFooter', class: 'footer__newsletter newsletter-form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="newsletter-input-group">
            <input
              id="NewsletterForm--{{ section.id }}"
              type="email"
              name="contact[email]"
              class="newsletter-input"
              value="{{ form.email }}"
              aria-required="true"
              autocorrect="off"
              autocapitalize="off"
              autocomplete="email"
              {% if form.errors %}
                autofocus
                aria-invalid="true"
                aria-describedby="ContactFooter-error"
              {% elsif form.posted_successfully? %}
                aria-describedby="ContactFooter-success"
              {% endif %}
              placeholder="Votre email"
              required
            >
            <button type="submit" class="newsletter-btn" name="commit" id="Subscribe">
              {{ section.settings.newsletter_button | escape }}
            </button>
          </div>
        {%- endform -%}
      </div>

    </div>

    <!-- Footer Bas (Liens Légaux) -->
    <div class="footer-bottom-bar">
      <div class="footer-copyright">
        {{ section.settings.copyright_text | escape }}
      </div>

      {%- assign bottom_menu_block = section.blocks | where: "type", "bottom_links" | first -%}
      {%- if bottom_menu_block and bottom_menu_block.settings.bottom_menu != blank -%}
        <ul class="footer-bottom-links">
          {%- for link in bottom_menu_block.settings.bottom_menu.links -%}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {%- endfor -%}
        </ul>
      {%- else -%}
        <ul class="footer-bottom-links">
          <li><a href="#">Mentions légales</a></li>
          <li><a href="#">Politique de confidentialité</a></li>
          <li><a href="#">Conditions générales</a></li>
        </ul>
      {%- endif -%}

      <div class="footer-socials">
        <!-- SVG factices pour RS -->
        <a href="#" aria-label="Instagram"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg></a>
        <a href="#" aria-label="Facebook"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg></a>
        <a href="#" aria-label="Pinterest"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" x2="12" y1="22" y2="2"/><line x1="2" x2="22" y1="12" y2="12"/><path d="m20 16-4-4"/><path d="m4 8 4 4"/><path d="m20 8-4 4"/><path d="m4 16 4-4"/></svg></a>
      </div>
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Univers Quotidien Hero",
  "settings": [
    {
      "type": "textarea",
      "id": "title",
      "label": "Title",
      "default": "Espaces de vie,"
    },
    {
      "type": "text",
      "id": "title_highlight",
      "label": "Title Highlight (Amber)",
      "default": "Lumière & Harmonie"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Des solutions d'éclairage conçues pour s'intégrer parfaitement à votre quotidien, tout en respectant l'ambiance de chaque pièce."
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    }
  ],
  "presets": [
    {
      "name": "Univers Quotidien Hero"
    }
  ]
}
{% endschema %}

<style>
#shopify-section-{{ section.id }} {
  background-color: #081A32;
  position: relative;
}

#shopify-section-{{ section.id }} .daily-wrapper {
  position: relative;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  color: #F9F9F9;
}

/* L'image de fond qui couvre toute la section */
#shopify-section-{{ section.id }} .daily-bg-img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  filter: saturate(1.2) brightness(0.6); /* Image plus sombre dès la base */
  z-index: 0;
}

/* L'overlay radial qui part du centre */
#shopify-section-{{ section.id }} .daily-overlay {
  position: absolute;
  inset: 0;
  /* Overlay global allégé puisqu'on a une boîte pour le texte */
  background: linear-gradient(to bottom, rgba(8, 26, 50, 0.4) 0%, rgba(8, 26, 50, 0.6) 100%);
  z-index: 1;
  pointer-events: none;
}

/* Hero Content au dessus de l'overlay, hauteur 100vh pour centrer le texte */
#shopify-section-{{ section.id }} .daily-hero-content {
  position: relative;
  height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  z-index: 2;
  padding: 0 5%;
}

/* Nouvel encart "Glassmorphism" pour garantir une lisibilité absolue */
#shopify-section-{{ section.id }} .daily-hero-box {
  background: rgba(8, 26, 50, 0.75);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 24px;
  padding: 3rem 2rem;
  max-width: 900px;
  width: 100%;
  box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5);
}

#shopify-section-{{ section.id }} .daily-h1 {
  font-family: 'Inter', sans-serif;
  font-size: clamp(2.5rem, 6vw, 4.5rem);
  font-weight: 800;
  line-height: 1.05;
  color: #F9F9F9;
  margin: 0 0 1.5rem 0;
  letter-spacing: -0.03em;
  /* Ombres allégées grâce au fond sombre */
  text-shadow: 0 2px 10px rgba(0, 0, 0, 0.5); 
}

#shopify-section-{{ section.id }} .daily-h1 span {
  color: #E89D46;
  text-shadow: 0 0 25px rgba(232, 157, 70, 0.4);
}

#shopify-section-{{ section.id }} .daily-subtitle {
  font-family: 'Inter', sans-serif;
  font-size: 1.25rem;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.9);
  max-width: 750px;
  margin: 0 auto;
}

/* Mobile responsive for the box */
@media screen and (max-width: 768px) {
  #shopify-section-{{ section.id }} .daily-hero-box {
    padding: 2rem 1.5rem;
  }
}
</style>

<div class="daily-wrapper">
  
  {%- if section.settings.background_image != blank -%}
    {{ section.settings.background_image | image_url: width: 2500 | image_tag: 
      class: 'daily-bg-img', 
      loading: 'eager', 
      widths: '500, 750, 1000, 1500, 2000, 2500' 
    }}
  {%- endif -%}

  <div class="daily-overlay"></div>

  <div class="daily-hero-content">
    <div class="daily-hero-box">
      <h1 class="daily-h1">
        {{ section.settings.title | newline_to_br }}
        {%- if section.settings.title_highlight != blank -%}
          <br><span>{{ section.settings.title_highlight }}</span>
        {%- endif -%}
      </h1>
      
      {%- if section.settings.subtitle != blank -%}
        <p class="daily-subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>
  </div>

</div>

{{ 'sf-echo-lumineux.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign echo_title = section.settings.title_default
  assign target_collection = blank
  assign found_match = false

  comment
    LOGIQUE D'INTELLIGENCE PAR BLOCS : 
    On boucle sur les paramètres de l'éditeur (blocks) et on compare le "tag déclencheur"
    avec la liste des tags du produit actuel. Le premier qui matche l'emporte.
  endcomment

  for block in section.blocks
    assign trigger_tag = block.settings.trigger_tag | downcase | strip

    for tag in product.tags
      assign product_tag_down = tag | downcase | strip
      
      if product_tag_down contains trigger_tag
        assign echo_title = block.settings.block_title
        assign target_collection = collections[block.settings.block_collection]
        assign found_match = true
        break
      endif
    endfor

    if found_match
      break
    endif
  endfor

  comment
    Si aucun tag trouvé, on prend une collection par défaut
  endcomment
  if target_collection == blank
    assign target_collection = collections[section.settings.collection_default]
  endif
-%}

{%- if target_collection != blank and target_collection.products_count > 0 -%}
  <div class="sf-echo-lumineux" style="--illu-bg-night: {{ section.settings.bg_color }};">
    <div class="page-width">
      <h2 class="sf-echo-title">{{ echo_title }}</h2>
      
      <div class="sf-echo-grid">
        {%- for echo_product in target_collection.products limit: section.settings.product_limit -%}
          {%- comment -%} On exclut le produit actuellement consulté {%- endcomment -%}
          {%- if echo_product.id != product.id -%}
            
            <a href="{{ echo_product.url }}" class="sf-echo-card">
              <div class="sf-echo-image-wrapper">
                <img src="{{ echo_product.featured_image | image_url: width: 600 }}" 
                     alt="{{ echo_product.title | escape }}" 
                     width="600" 
                     height="600" 
                     loading="lazy">
              </div>
              
              <div class="sf-echo-info">
                <h3 class="sf-echo-product-title">{{ echo_product.title }}</h3>
                <p class="sf-echo-product-price">{{ echo_product.price | money }}</p>
                
                {%- if section.settings.show_add_button -%}
                  <form method="post" action="/cart/add" class="sf-echo-add-form" style="margin: 0; padding: 0;">
                    <input type="hidden" name="id" value="{{ echo_product.variants.first.id }}">
                    <button type="submit" class="sf-echo-add-button">
                      {{ section.settings.add_button_text }}
                    </button>
                  </form>
                {%- else -%}
                   <div class="sf-echo-add-button" style="text-align: center; margin-top: 16px;">Découvrir</div>
                {%- endif -%}
              </div>
            </a>
            
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Echo Lumineux",
  "tag": "section",
  "class": "section-echo-lumineux",
  "settings": [
    {
      "type": "header",
      "content": "Affichage par Defaut (Si aucun tag ne matche)"
    },
    {
      "type": "text",
      "id": "title_default",
      "label": "Titre par defaut",
      "default": "Sublimez votre univers avec ces essentiels"
    },
    {
      "type": "collection",
      "id": "collection_default",
      "label": "Collection par Défaut"
    },
    {
      "type": "header",
      "content": "Design & Affichage"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Couleur de Fond",
      "default": "#0A1428"
    },
    {
      "type": "range",
      "id": "product_limit",
      "min": 3,
      "max": 8,
      "step": 1,
      "default": 4,
      "label": "Nombre max de produits"
    },
    {
      "type": "checkbox",
      "id": "show_add_button",
      "label": "Activer le bouton d'ajout au panier direct",
      "default": true
    },
    {
      "type": "text",
      "id": "add_button_text",
      "label": "Texte du bouton",
      "default": "Ajouter au panier"
    }
  ],
  "blocks": [
    {
      "type": "universe_rule",
      "name": "Regle Univers",
      "settings": [
        {
          "type": "text",
          "id": "trigger_tag",
          "label": "Tag declencheur",
          "info": "Si le produit actuel possede ce tag (ex: 'cocon' ou 'bureau'), les regles ci-dessous s'appliqueront."
        },
        {
          "type": "text",
          "id": "block_title",
          "label": "Titre de section personnalise",
          "default": "Pour completer votre espace"
        },
        {
          "type": "collection",
          "id": "block_collection",
          "label": "Collection a suggerer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Echo Lumineux",
      "category": "Produit",
      "blocks": [
        {
          "type": "universe_rule",
          "settings": {
            "trigger_tag": "cocon",
            "block_title": "Pour completer son cocon de douceur"
          }
        },
        {
          "type": "universe_rule",
          "settings": {
            "trigger_tag": "pro",
            "block_title": "Pour optimiser votre configuration de travail"
          }
        },
        {
          "type": "universe_rule",
          "settings": {
            "trigger_tag": "setup",
            "block_title": "Pour pousser l'immersion un cran plus loin"
          }
        }
      ]
    }
  ]
}
{% endschema %}

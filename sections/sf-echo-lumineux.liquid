{{ 'sf-echo-lumineux.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign echo_title = section.settings.title_default
  assign best_collection = blank
  assign best_count = 999999

  comment
    =============================================
    INTELLIGENCE AUTOMATIQUE — Echo Lumineux v2
    =============================================
    1. On detecte le tag univers du produit (cocon / pro / setup)
       pour adapter le titre via les blocs configurables.
    2. On parcourt TOUTES les collections du produit actuel,
       on ignore les generiques (all, frontpage),
       et on prend la PLUS SPECIFIQUE (celle avec le moins de produits).
       C'est toujours la sous-collection la plus pertinente.
    3. Fallback : si aucune collection pertinente, on utilise
       les recommendations natives de Shopify.
  endcomment


  for block in section.blocks
    assign trigger_tag = block.settings.trigger_tag | downcase | strip
    if trigger_tag == blank
      continue
    endif

    for tag in product.tags
      assign product_tag_down = tag | downcase | strip
      if product_tag_down contains trigger_tag
        assign echo_title = block.settings.block_title
        break
      endif
    endfor
  endfor


  for col in product.collections
    assign col_handle = col.handle | downcase


    if col_handle == 'all' or col_handle == 'frontpage' or col_handle == 'all-products'
      continue
    endif


    if col.products_count < best_count and col.products_count > 1
      assign best_collection = col
      assign best_count = col.products_count
    endif
  endfor



  assign use_recommendations = false
  if best_collection == blank
    assign use_recommendations = true
  endif
-%}

{%- if use_recommendations -%}
  {%- comment -%} FALLBACK : Shopify Product Recommendations API {%- endcomment -%}
  <div class="sf-echo-lumineux" style="--illu-bg-night: {{ section.settings.bg_color }};"
       id="echo-lumineux-{{ section.id }}"
       data-product-id="{{ product.id }}"
       data-limit="{{ section.settings.product_limit }}"
       data-section-id="{{ section.id }}">
    <div class="page-width">
      <h2 class="sf-echo-title">{{ echo_title }}</h2>
      <div class="sf-echo-grid" id="echo-grid-{{ section.id }}">
        {%- comment -%} Rempli par JS via l'API recommendations {%- endcomment -%}
      </div>
    </div>
  </div>

  <script>
    (function() {
      const section = document.getElementById('echo-lumineux-{{ section.id }}');
      if (!section) return;
      const productId = section.dataset.productId;
      const limit = parseInt(section.dataset.limit) + 1;
      const grid = document.getElementById('echo-grid-{{ section.id }}');

      fetch(`${window.Shopify.routes.root}recommendations/products.json?product_id=${productId}&limit=${limit}&intent=related`)
        .then(r => r.json())
        .then(data => {
          if (!data.products || data.products.length === 0) {
            section.style.display = 'none';
            return;
          }
          let html = '';
          const showBtn = {{ section.settings.show_add_button | json }};
          const btnText = {{ section.settings.add_button_text | json }};

          data.products.forEach(p => {
            if (String(p.id) === String(productId)) return;
            const img = p.featured_image || p.images[0] || '';
            const price = (p.price / 100).toFixed(2).replace('.', ',') + ' \u20ac';
            const variantId = p.variants[0].id;

            html += `<a href="${p.url}" class="sf-echo-card">
              <div class="sf-echo-image-wrapper">
                <img src="${img}?width=600" alt="${p.title}" width="600" height="600" loading="lazy">
              </div>
              <div class="sf-echo-info">
                <h3 class="sf-echo-product-title">${p.title}</h3>
                <p class="sf-echo-product-price">${price}</p>
                ${showBtn
                  ? `<form method="post" action="/cart/add" class="sf-echo-add-form" style="margin:0;padding:0;">
                       <input type="hidden" name="id" value="${variantId}">
                       <button type="submit" class="sf-echo-add-button">${btnText}</button>
                     </form>`
                  : `<div class="sf-echo-add-button" style="text-align:center;margin-top:16px;">Decouvrir</div>`
                }
              </div>
            </a>`;
          });
          grid.innerHTML = html;
        })
        .catch(() => { section.style.display = 'none'; });
    })();
  </script>

{%- elsif best_collection.products_count > 0 -%}
  {%- comment -%} MODE PRINCIPAL : Collection auto-detectee {%- endcomment -%}
  <div class="sf-echo-lumineux" style="--illu-bg-night: {{ section.settings.bg_color }};">
    <div class="page-width">
      <h2 class="sf-echo-title">{{ echo_title }}</h2>
      
      <div class="sf-echo-grid">
        {%- assign shown_count = 0 -%}
        {%- for echo_product in best_collection.products limit: section.settings.product_limit -%}
          {%- if echo_product.id != product.id -%}
            {%- assign shown_count = shown_count | plus: 1 -%}
            {%- if shown_count > section.settings.product_limit | minus: 1 -%}
              {%- break -%}
            {%- endif -%}
            
            <a href="{{ echo_product.url }}" class="sf-echo-card">
              <div class="sf-echo-image-wrapper">
                <img src="{{ echo_product.featured_image | image_url: width: 600 }}" 
                     alt="{{ echo_product.title | escape }}" 
                     width="600" 
                     height="600" 
                     loading="lazy">
              </div>
              
              <div class="sf-echo-info">
                <h3 class="sf-echo-product-title">{{ echo_product.title }}</h3>
                <p class="sf-echo-product-price">{{ echo_product.price | money }}</p>
                
                {%- if section.settings.show_add_button -%}
                  <form method="post" action="/cart/add" class="sf-echo-add-form" style="margin: 0; padding: 0;">
                    <input type="hidden" name="id" value="{{ echo_product.variants.first.id }}">
                    <button type="submit" class="sf-echo-add-button">
                      {{ section.settings.add_button_text }}
                    </button>
                  </form>
                {%- else -%}
                   <div class="sf-echo-add-button" style="text-align: center; margin-top: 16px;">Decouvrir</div>
                {%- endif -%}
              </div>
            </a>
            
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Echo Lumineux",
  "tag": "section",
  "class": "section-echo-lumineux",
  "settings": [
    {
      "type": "header",
      "content": "Titre & Affichage"
    },
    {
      "type": "text",
      "id": "title_default",
      "label": "Titre par defaut",
      "default": "Sublimez votre univers avec ces essentiels",
      "info": "Affiche si aucun tag univers ne matche."
    },
    {
      "type": "header",
      "content": "Design"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Couleur de Fond",
      "default": "#0A1428"
    },
    {
      "type": "range",
      "id": "product_limit",
      "min": 3,
      "max": 8,
      "step": 1,
      "default": 4,
      "label": "Nombre max de produits"
    },
    {
      "type": "checkbox",
      "id": "show_add_button",
      "label": "Bouton ajout panier",
      "default": true
    },
    {
      "type": "text",
      "id": "add_button_text",
      "label": "Texte du bouton",
      "default": "Ajouter au panier"
    }
  ],
  "blocks": [
    {
      "type": "universe_rule",
      "name": "Regle Univers",
      "settings": [
        {
          "type": "text",
          "id": "trigger_tag",
          "label": "Tag declencheur",
          "info": "Si le produit possede ce tag, le titre ci-dessous s'affichera. La collection est detectee automatiquement."
        },
        {
          "type": "text",
          "id": "block_title",
          "label": "Titre personnalise",
          "default": "Pour completer votre espace"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Echo Lumineux",
      "category": "Produit",
      "blocks": [
        {
          "type": "universe_rule",
          "settings": {
            "trigger_tag": "cocon",
            "block_title": "Pour completer son cocon de douceur"
          }
        },
        {
          "type": "universe_rule",
          "settings": {
            "trigger_tag": "pro",
            "block_title": "Pour optimiser votre configuration"
          }
        },
        {
          "type": "universe_rule",
          "settings": {
            "trigger_tag": "setup",
            "block_title": "Pour pousser l'immersion plus loin"
          }
        }
      ]
    }
  ]
}
{% endschema %}

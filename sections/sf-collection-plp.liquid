{{ 'sf-collection-plp.css' | asset_url | stylesheet_tag }}

<style>
  #shopify-section-{{ section.id }} {
    background-color: var(--illu-bg-night, #081A32);
  }
  
  /* Quick Add Styles */
  .glass-product-card {
    position: relative;
    display: flex;
    flex-direction: column;
  }
  .glass-product-card-title-link {
    text-decoration: none;
    color: inherit;
  }
  .glass-product-card-title-link::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1; /* Makes the whole card clickable */
  }
  .sf-plp-price-action {
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: relative;
    z-index: 2; /* Ensures button is clickable above the card link */
    margin-top: 0.5rem;
  }
  .sf-plp-quick-add-form {
    margin: 0;
  }
  .sf-plp-quick-add-btn {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 50%;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--illu-text-cream, #F9F9F9);
    cursor: pointer;
    transition: all 0.3s ease;
    backdrop-filter: blur(4px);
  }
  .sf-plp-quick-add-btn:hover:not(:disabled) {
    background: var(--illu-accent-amber, #E89D46);
    border-color: var(--illu-accent-amber, #E89D46);
    color: var(--illu-bg-night, #081A32);
    transform: scale(1.05);
  }
  .sf-plp-quick-add-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  @keyframes spinPLP {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  .animate-spin-plp {
    animation: spinPLP 1s linear infinite;
  }
</style>

{%- assign is_collection_page = false -%}
{%- if request.page_type == 'collection' -%}
  {%- assign is_collection_page = true -%}
{%- endif -%}

{%- assign display_collection = collection -%}
{%- if is_collection_page == false and section.settings.custom_collection != blank -%}
  {%- assign display_collection = section.settings.custom_collection -%}
{%- endif -%}

{% paginate display_collection.products by 24 %}

<div class="sf-plp-banner">
  <h1 class="sf-plp-banner-title">
    {% if section.settings.title != blank %}
      {{ section.settings.title | escape }}
    {% elsif display_collection.title != blank %}
      {{ display_collection.title | escape }}
    {% else %}
      Toutes nos Créations
    {% endif %}
  </h1>
  {% if section.settings.subtitle != blank %}
    <p class="sf-plp-banner-subtitle">{{ section.settings.subtitle | escape }}</p>
  {% endif %}
</div>

<div class="sf-plp-container">
  <aside class="sf-plp-sidebar">
    <div class="sf-plp-sidebar-inner">
      {%- for block in section.blocks -%}
        {%- if block.type == 'filter_group' -%}
          <details class="sf-plp-filter-group" open {{ block.shopify_attributes }}>
            <summary class="sf-plp-filter-title">
              {{ block.settings.title | escape }}
              <span class="sf-plp-filter-icon">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
              </span>
            </summary>
            <div class="sf-plp-filter-content">
              <ul class="sf-plp-filter-list">
                {%- assign tags = block.settings.tags | split: ',' -%}
                {%- for tag in tags -%}
                  {%- assign trimmed_tag = tag | strip -%}
                  {%- assign tag_handle = trimmed_tag | downcase -%}
                  {%- if trimmed_tag != blank -%}
                    <li class="sf-plp-filter-item">
                      <button data-tag="{{ tag_handle }}" class="sf-plp-filter-pill {% if current_tags contains tag_handle %}is-active{% endif %}">
                        {{ trimmed_tag }}
                      </button>
                    </li>
                  {%- endif -%}
                {%- endfor -%}
              </ul>
            </div>
          </details>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </aside>

  <main class="sf-plp-main">
    <div class="plp-grid">
      {%- assign products_list = display_collection.products -%}
      {%- if is_collection_page == false and products_list == blank -%}
        <!-- Fallback if no collection selected on non-collection page -->
        <p style="color: white; margin: 40px; text-align: center; width: 100%; grid-column: 1 / -1;">Veuillez sélectionner une collection dans les paramètres de la section.</p>
      {%- endif -%}

      {% for product in products_list limit: 24 %}
        <div class="glass-product-card">
          <div class="glass-product-card-image-wrap">
            {% if product.featured_image != blank %}
              <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.title | escape }}" class="product-thumb-glow" loading="lazy">
            {% else %}
              {{ 'product-1' | placeholder_svg_tag: 'product-thumb-glow' }}
            {% endif %}
          </div>
          <div class="glass-product-card-info">
            <a href="{{ product.url | within: display_collection }}" class="glass-product-card-title-link">
              <h3 class="glass-product-card-title">{{ product.title | escape }}</h3>
            </a>
            <div class="sf-plp-price-action">
              <p class="glass-product-card-price" style="margin: 0;">{{ product.price | money }}</p>
              
              <form method="post" action="/cart/add" class="sf-plp-quick-add-form">
                <input type="hidden" name="id" value="{{ product.variants.first.id }}" />
                <button type="button" class="sf-plp-quick-add-btn" {% unless product.available %}disabled{% endunless %} aria-label="Ajouter au panier">
                  {% if product.available %}
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
                  {% else %}
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
                  {% endif %}
                </button>
              </form>
            </div>
          </div>
        </div>
      {% else %}
        {%- if is_collection_page or display_collection != blank -%}
          <p style="color: white; margin: 40px; text-align: center; width: 100%; grid-column: 1 / -1;">Aucun produit trouvé dans cette collection.</p>
        {%- endif -%}
      {% endfor %}
    </div>
    
    {%- if is_collection_page and paginate.pages > 1 -%}
      <div style="margin: 40px auto; display: flex; justify-content: center; width: 100%;">
        {% render 'pagination', paginate: paginate %}
      </div>
    {%- endif -%}
  </main>
</div>

{% endpaginate %}

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const pills = document.querySelectorAll('.sf-plp-filter-pill');
    const gridContainer = document.querySelector('.plp-grid');
    const collectionUrl = '{{ display_collection.url }}' || '/collections/all';
    
    pills.forEach(pill => {
      pill.addEventListener('click', function(e) {
        e.preventDefault();
        
        // Toggle active state visually
        this.classList.toggle('is-active');
        
        // Gather all currently active tags
        const activeTags = Array.from(document.querySelectorAll('.sf-plp-filter-pill.is-active'))
                               .map(p => p.getAttribute('data-tag'));
        
        // Construct new URL (Shopify handles multiple tags joined by '+')
        let fetchUrl = collectionUrl;
        if (activeTags.length > 0) {
          fetchUrl += '/' + activeTags.join('+');
        }
        
        // Show loading state
        gridContainer.style.opacity = '0.5';
        gridContainer.style.pointerEvents = 'none';
        
        fetch(fetchUrl)
          .then(response => response.text())
          .then(html => {
            // Parse the new HTML
            const parser = new DOMParser();
            const doc = parser.parseFromString(html, 'text/html');
            const newGrid = doc.querySelector('.plp-grid');
            
            if (newGrid) {
              gridContainer.innerHTML = newGrid.innerHTML;
            } else {
              gridContainer.innerHTML = '<p style="color: white; margin: 40px; text-align: center; width: 100%; grid-column: 1 / -1;">Aucun produit trouvé avec ces filtres.</p>';
            }
            
            // Remove loading state
            gridContainer.style.opacity = '1';
            gridContainer.style.pointerEvents = 'all';
            
            // Push state to browser history so URL updates without reload
            window.history.pushState({path: fetchUrl}, '', fetchUrl);
          })
          .catch(error => {
            console.error('Error fetching filtered products:', error);
            gridContainer.style.opacity = '1';
            gridContainer.style.pointerEvents = 'all';
          });
      });
    });

    // Quick Add Handling
    document.addEventListener('click', function(e) {
      const btn = e.target.closest('.sf-plp-quick-add-btn');
      if (!btn) return;
      
      const form = btn.closest('form');
      if (!form) return;
      
      e.preventDefault();
      
      const formData = new FormData(form);
      const originalHTML = btn.innerHTML;
      
      // Loading state
      btn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="animate-spin-plp"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>';
      
      fetch(window.Shopify.routes.root + 'cart/add.js', {
        method: 'POST',
        body: formData
      })
      .then(response => response.json())
      .then(data => {
        if (data.status && data.status !== 200) {
           throw new Error(data.message);
        }
        // Success state
        btn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>';
        btn.style.background = '#4ade80'; // Success green
        btn.style.borderColor = '#4ade80';
        btn.style.color = '#000';
        
        // Trigger generic cart update event that sf-cart-drawer listens to
        document.dispatchEvent(new CustomEvent('cart:updated'));
        
        // Reset after 2s
        setTimeout(() => {
          btn.innerHTML = originalHTML;
          btn.style.background = '';
          btn.style.borderColor = '';
          btn.style.color = '';
        }, 2000);
      })
      .catch(error => {
        console.error('Error adding to cart:', error);
        btn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"/></svg>';
        setTimeout(() => {
           btn.innerHTML = originalHTML;
        }, 2000);
      });
    });
  });
</script>

{% schema %}
{
  "name": "✨ Galerie Collection PLP",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titre",
      "default": "Toutes nos Créations"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Sous-titre",
      "default": "L'EXPERTISE DE LA LUMIÈRE AU SERVICE DE VOS ÉMOTIONS"
    },
    {
      "type": "collection",
      "id": "custom_collection",
      "label": "Collection (si utilisé hors d'une page collection)",
      "info": "Utile si vous ajoutez cette section sur l'accueil."
    }
  ],
  "blocks": [
    {
      "type": "filter_group",
      "name": "Groupe de Filtres",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Titre du Groupe (ex: Univers)",
          "default": "Univers"
        },
        {
          "type": "text",
          "id": "tags",
          "label": "Tags à inclure",
          "info": "Séparez les tags par des virgules sans espace obligatoire. Ex: Pro, Setup, Cocon"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "✨ Galerie Collection PLP",
      "settings": {
        "title": "Toutes nos Créations",
        "subtitle": "L'EXPERTISE DE LA LUMIÈRE AU SERVICE DE VOS ÉMOTIONS"
      },
      "blocks": [
        {
          "type": "filter_group",
          "settings": {
            "title": "Univers",
            "tags": "Pro, Setup, Cocon"
          }
        },
        {
          "type": "filter_group",
          "settings": {
            "title": "Ambiance",
            "tags": "Sereine, Dynamique, Nocturne"
          }
        }
      ]
    }
  ],
  "enabled_on": {
    "templates": ["*"]
  }
}
{% endschema %}

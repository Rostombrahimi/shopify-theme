{% schema %}
{
  "name": "Besoins Cocon (Cards)",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Étiquette (Sur-titre)",
      "default": "PETIT COCON"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Titre principal",
      "default": "Segmenter par <em>Besoins</em>",
      "info": "Utilisez <em>mot</em> pour appliquer l'effet brillant ambre, ou <i>mot</i> pour la couleur ambre sans surbrillance."
    }
  ],
  "blocks": [
    {
      "type": "need_card",
      "name": "Carte Besoin",
      "limit": 3,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image de la carte"
        },
        {
          "type": "html",
          "id": "icon",
          "label": "Icône SVG",
          "info": "Le code SVG de l'icône à gauche du titre."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titre",
          "default": "Les Premières Nuits"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Texte",
          "default": "Une douceur absolue pour les soins nocturnes, sans jamais briser le calme."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Lien de la carte (Rend la carte cliquable)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Besoins Cocon (Cards)",
      "blocks": [
        {
          "type": "need_card",
          "settings": {
            "title": "Les Premières Nuits",
            "text": "Une douceur absolue pour les soins nocturnes, sans jamais briser le calme.",
            "icon": "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z\"/></svg>"
          }
        },
        {
          "type": "need_card",
          "settings": {
            "title": "L'Heure des Histoires",
            "text": "Des ambiances chaleureuses pour ritualiser le coucher et apaiser les esprits.",
            "icon": "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20\"/></svg>"
          }
        },
        {
          "type": "need_card",
          "settings": {
            "title": "Vers l'Autonomie",
            "text": "Des points de repère rassurants pour explorer la nuit en toute confiance.",
            "icon": "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"12\" cy=\"12\" r=\"10\"/><polygon points=\"16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76\"/></svg>"
          }
        }
      ]
    }
  ]
}
{% endschema %}

<style>
/* Section 3 - Segmentation Cocon */
#shopify-section-{{ section.id }} .cocon-needs-section {
  background-color: var(--illu-night, #081A32); /* Adapté pour coller avec le reste */
  padding: 80px 20px;
  font-family: inherit;
  display: flex;
  flex-direction: column;
  align-items: center;
}

#shopify-section-{{ section.id }} .cocon-needs-header {
  text-align: center;
  margin-bottom: 60px;
  display: flex;
  flex-direction: column;
  align-items: center;
}

#shopify-section-{{ section.id }} .cocon-needs-label {
  color: var(--illu-accent-amber, #E89D46);
  font-size: 0.94rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  margin-bottom: 1rem;
}

/* Titre principal et tags personnalisés */
#shopify-section-{{ section.id }} .cocon-needs-title {
  font-size: clamp(2.5rem, 5vw, 3.5rem);
  color: var(--illu-cream, #F9F9F9);
  font-weight: 700;
  line-height: 1.1;
  letter-spacing: -0.02em;
  margin-bottom: 1.5rem;
  max-width: 800px;
  text-wrap: balance;
  position: relative;
  padding-bottom: 24px;
}

/* Le petit trait horizontal sous le titre */
#shopify-section-{{ section.id }} .cocon-needs-title::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60px;
  height: 3px;
  background-color: var(--illu-accent-amber, #E89D46);
  border-radius: 3px;
}

/* Em pour l'effet brillant */
#shopify-section-{{ section.id }} .cocon-needs-title em {
  font-style: normal;
  color: var(--illu-accent-amber, #E89D46);
  text-shadow: 0 0 15px rgba(232, 157, 70, 0.45);
}

/* I pour l'ambre simple */
#shopify-section-{{ section.id }} .cocon-needs-title i {
  font-style: normal;
  color: var(--illu-accent-amber, #E89D46);
}

#shopify-section-{{ section.id }} .cocon-needs-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 32px;
  max-width: 1300px; /* Moins large que le 1440px pour un look plus groupé */
  width: 100%;
  margin: 0 auto;
}

#shopify-section-{{ section.id }} .need-card {
  background: var(--illu-bg-night-light, #0B2240);
  border-radius: 32px;
  overflow: hidden;
  border: 1px solid rgba(255, 255, 255, 0.05);
  transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  display: flex;
  flex-direction: column;
  text-decoration: none; /* Car c'est un lien */
  color: inherit;
  height: 100%;
}

#shopify-section-{{ section.id }} .need-card:hover {
  transform: translateY(-10px);
  border-color: rgba(232, 157, 70, 0.3);
  box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4), 0 0 20px rgba(232, 157, 70, 0.05);
}

/* Gérer l'image et l'ombre interne */
#shopify-section-{{ section.id }} .need-image-wrapper {
  width: 100%;
  aspect-ratio: 1 / 1;
  position: relative;
  overflow: hidden;
  background: #050B14;
}

/* Ombre interne pour l'image */
#shopify-section-{{ section.id }} .need-image-wrapper::after {
  content: '';
  position: absolute;
  inset: 0;
  box-shadow: inset 0 -30px 50px rgba(8, 26, 50, 0.8), inset 0 0 50px rgba(8, 26, 50, 0.3);
  pointer-events: none;
  z-index: 1;
}

#shopify-section-{{ section.id }} .need-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  opacity: 0.8;
  transition: opacity 0.5s ease, transform 1s ease;
  pointer-events: none;
}

#shopify-section-{{ section.id }} .need-card:hover .need-image {
  opacity: 1;
  transform: scale(1.03); /* Léger zoom sur l'image au survol */
}

#shopify-section-{{ section.id }} .need-content {
  padding: 32px;
  text-align: left;
  flex-grow: 1;
  display: flex;
  flex-direction: column;
}

#shopify-section-{{ section.id }} .need-title-group {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 1rem;
}

#shopify-section-{{ section.id }} .need-title-icon {
  color: var(--illu-accent-amber, #E89D46);
  display: flex;
  align-items: center;
  justify-content: center;
}

#shopify-section-{{ section.id }} .need-title-icon svg {
  width: 24px;
  height: 24px;
}

#shopify-section-{{ section.id }} .need-title {
  color: var(--illu-accent-amber, #E89D46);
  font-size: 1.3rem;
  font-weight: 700;
  margin: 0;
  transition: letter-spacing 0.3s ease;
}

/* L'effet de respiration (Scale on Hover) sur le titre */
#shopify-section-{{ section.id }} .need-card:hover .need-title {
  letter-spacing: 0.01em; 
}

#shopify-section-{{ section.id }} .need-desc {
  color: rgba(249, 249, 249, 0.75);
  line-height: 1.6;
  font-size: 1.1rem;
  font-weight: 300;
  margin: 0;
}

/* Grille CSS Responsivité */
@media (max-width: 1024px) {
  #shopify-section-{{ section.id }} .cocon-needs-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 768px) {
  #shopify-section-{{ section.id }} .cocon-needs-grid {
    grid-template-columns: 1fr;
    max-width: 450px;
  }
}
</style>

<div class="sf-stitch cocon-needs-section">
  <div class="cocon-needs-header">
    {%- if section.settings.label != blank -%}
      <div class="cocon-needs-label">{{ section.settings.label | escape }}</div>
    {%- endif -%}

    {%- if section.settings.title != blank -%}
      <h2 class="cocon-needs-title">
        {{ section.settings.title | replace: '<em>', '<em>' | replace: '</em>', '</em>' | replace: '<i>', '<i>' | replace: '</i>', '</i>' }}
      </h2>
    {%- endif -%}
  </div>

  {%- if section.blocks.size > 0 -%}
    <div class="cocon-needs-grid">
      {%- for block in section.blocks -%}
        
        {%- assign card_tag = 'div' -%}
        {%- if block.settings.link != blank -%}
          {%- assign card_tag = 'a' -%}
        {%- endif -%}

        <{{ card_tag }} {% if block.settings.link != blank %}href="{{ block.settings.link }}"{% endif %} class="need-card" {{ block.shopify_attributes }}>
          
          <div class="need-image-wrapper">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 800 | image_tag: class: 'need-image', loading: 'lazy' }}
            {%- else -%}
              <img src="https://via.placeholder.com/800x800/0B2240/E89D46?text=Image+Besoin" alt="Image vide" class="need-image" loading="lazy">
            {%- endif -%}
          </div>

          <div class="need-content">
            <div class="need-title-group">
              {%- if block.settings.icon != blank -%}
                <span class="need-title-icon">{{ block.settings.icon }}</span>
              {%- endif -%}
              {%- if block.settings.title != blank -%}
                <h3 class="need-title">{{ block.settings.title | escape }}</h3>
              {%- endif -%}
            </div>
            
            {%- if block.settings.text != blank -%}
              <p class="need-desc">{{ block.settings.text | escape }}</p>
            {%- endif -%}
          </div>

        </{{ card_tag }}>

      {%- endfor -%}
    </div>
  {%- endif -%}
</div>

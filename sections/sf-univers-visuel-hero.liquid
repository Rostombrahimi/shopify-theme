{% schema %}
{
  "name": "Univers Visuel Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Image de fond"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Texte du badge",
      "default": "🏮 SOUS-COLLECTION ANIMÉ"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Titre Principal",
      "default": "Lampes Animé –\n<em>Ambiances inspirées des licences cultes</em>",
      "info": "Utilisez <em>mot</em> pour appliquer l'effet brillant ambre."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Une immersion lumineuse radicale. Plongez votre espace dans l'aura de vos héros avec notre curation exclusive de pièces d'exception."
    }
  ],
  "presets": [
    {
      "name": "Univers Visuel Hero",
      "category": "Image"
    }
  ]
}
{% endschema %}

<style>
/* Section Hero Animé Vibrant */
#shopify-section-{{ section.id }} .hero-anime-vibrant {
  position: relative;
  height: 80vh;
  min-height: 600px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  background-color: var(--illu-night, #081A32);
  padding: 0 4rem;
  overflow: hidden;
}

#shopify-section-{{ section.id }} .hero-anime-bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  z-index: 0;
  opacity: 0.6; /* Assombri pour faire ressortir le texte */
}

/* Light Bloom : Effet d'émanation lumineuse */
#shopify-section-{{ section.id }} .hero-anime-vibrant::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at 50% 50%, rgba(232, 157, 70, 0.15) 0%, transparent 60%);
  mix-blend-mode: plus-lighter;
  z-index: 1;
  pointer-events: none;
}

/* Vignette pour assombrir les bords */
#shopify-section-{{ section.id }} .hero-anime-vibrant::after {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at center, transparent 30%, var(--illu-night, #081A32) 100%);
  z-index: 1;
  pointer-events: none;
}

#shopify-section-{{ section.id }} .hero-anime-content {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  max-width: 900px;
  margin: 0 auto;
}

/* Dark Glass Box for robust legibility */
#shopify-section-{{ section.id }} .hero-anime-box {
  background: rgba(8, 26, 50, 0.75);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 24px;
  padding: 3rem 2rem;
  width: 100%;
  box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5);
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* Glassmorphism Badge */
#shopify-section-{{ section.id }} .badge-anime-pill {
  background: rgba(232, 157, 70, 0.1);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border: 1px solid #E89D46;
  padding: 8px 24px;
  border-radius: 99px;
  color: #E89D46;
  font-family: 'Inter', sans-serif;
  font-size: 0.83rem;
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  margin-bottom: 2.5rem;
  box-shadow: 0 0 15px rgba(232, 157, 70, 0.2);
}

#shopify-section-{{ section.id }} .title-vibrant-anime {
  font-family: 'Inter', sans-serif;
  font-weight: 900; /* Font-Weight Optimization */
  font-size: clamp(2.75rem, 6.6vw, 4.95rem);
  line-height: 1.1;
  color: #F9F9F9;
  margin: 0 0 2rem 0;
  text-shadow: 0 2px 10px rgba(0,0,0,0.5); /* Ombre allégée grace à la box */
  letter-spacing: -0.02em;
}

#shopify-section-{{ section.id }} .title-vibrant-anime em,
#shopify-section-{{ section.id }} .title-vibrant-anime i {
  font-style: normal;
  color: #E89D46;
  text-shadow: 0 0 25px rgba(232, 157, 70, 0.4); /* Glow ajusté */
  display: block; /* Force line break for the highlighted part if wanted, or inline block */
}

#shopify-section-{{ section.id }} .desc-anime-vibrant {
  font-family: 'Inter', sans-serif;
  font-size: 1.24rem;
  line-height: 1.6;
  color: rgba(249, 249, 249, 0.9);
  max-width: 700px;
  margin-bottom: 0;
}

@media (max-width: 768px) {
  #shopify-section-{{ section.id }} .hero-anime-vibrant {
    padding: 0 1.5rem;
    height: 70vh;
    min-height: 500px;
  }
  #shopify-section-{{ section.id }} .hero-anime-box {
    padding: 2rem 1.5rem;
  }
}
</style>

<div class="sf-stitch hero-anime-vibrant">
  {%- if section.settings.background_image != blank -%}
    {{ section.settings.background_image | image_url: width: 2000 | image_tag: class: 'hero-anime-bg', loading: 'eager' }}
  {%- endif -%}

  <div class="hero-anime-content">
    <div class="hero-anime-box">
      {%- if section.settings.badge_text != blank -%}
        <div class="badge-anime-pill">
          {{ section.settings.badge_text }}
        </div>
      {%- endif -%}

      {%- if section.settings.title != blank -%}
        <h1 class="title-vibrant-anime">
          {{ section.settings.title | newline_to_br | replace: '<em>', '<em>' | replace: '</em>', '</em>' | replace: '<i>', '<i>' | replace: '</i>', '</i>' }}
        </h1>
      {%- endif -%}

      {%- if section.settings.description != blank -%}
        <p class="desc-anime-vibrant">
          {{ section.settings.description }}
        </p>
      {%- endif -%}
    </div>
  </div>
</div>


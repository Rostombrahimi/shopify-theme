{{ 'sf-light-path.css' | asset_url | stylesheet_tag }}

<div class="light-path-wrapper" {{ block.shopify_attributes }}>
    
    <div class="light-path-header">
        <h3 class="light-path-subtitle">
            Le Trajet de la Lumière
            <span class="path-badge">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                Expert Verified
            </span>
        </h3>
        
        <div class="phrase-rotator" id="phrase-rotator-{{ section.id }}">
            <p class="phrase-item is-active" data-phase="0">Votre atmosphère est prête à être infusée.</p>
            <p class="phrase-item" data-phase="1">Temps de propagation des photons : 3 à 5 jours.</p>
            <p class="phrase-item" data-phase="2">Votre univers s'illumine le <span id="dynamic-delivery-date-{{ section.id }}"></span>.</p>
        </div>
    </div>

    <!-- Animation du point A au point B -->
    <div class="path-line-container">
        <!-- Point de départ -->
        <div class="path-icon">
            <span class="path-point"></span>
        </div>

        <!-- Le fameux photon -->
        <div class="photon-pulse"></div>

        <!-- Point d'arrivée (Maison) -->
        <div class="path-icon icon-home">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
        </div>
    </div>

    <div class="light-path-labels">
        <div class="label-start">L'Atelier Illuminées</div>
        <div class="label-end">Votre Univers</div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
    // 1. Calcul dynamique de la date (J+4) avec formatage "le 10 Mars"
    const dateSpan = document.getElementById('dynamic-delivery-date-{{ section.id }}');
    if (dateSpan) {
        const arrivalDate = new Date();
        arrivalDate.setDate(arrivalDate.getDate() + 4);
        const options = { day: 'numeric', month: 'long' };
        dateSpan.textContent = arrivalDate.toLocaleDateString('fr-FR', options);
    }

    // 2. Logique de rotation des phrases basée sur le cycle de 4s (4000ms)
    const rotator = document.getElementById('phrase-rotator-{{ section.id }}');
    if (!rotator) return;
    
    const phrases = rotator.querySelectorAll('.phrase-item');
    if (phrases.length < 3) return;

    let currentPhase = 0;
    // 4000ms divisé par 3 phrases = ~1333ms par phase
    const phaseDuration = 1333; 

    setInterval(() => {
        // Enlever is-active de la phase actuelle et la mettre en is-leaving
        phrases[currentPhase].classList.remove('is-active');
        phrases[currentPhase].classList.add('is-leaving');
        
        // Passer à la phrase suivante
        currentPhase = (currentPhase + 1) % phrases.length;
        
        // Préparer la nouvelle phrase (la remettre en bas) puis is-active
        phrases[currentPhase].classList.remove('is-leaving');
        phrases[currentPhase].classList.add('is-active');
        
    }, phaseDuration);
});
</script>

{% schema %}
{
  "name": "✨ Le Trajet de la Lumière",
  "target": "section",
  "settings": [],
  "presets": [
    {
      "name": "✨ Le Trajet de la Lumière"
    }
  ]
}
{% endschema %}

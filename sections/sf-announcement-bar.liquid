<style>
  .sf-announcement-bar {
    background-color: var(--illu-bg-night, #081A32);
    height: 42px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-bottom: 1px solid rgba(232, 157, 70, 0.1);
    position: relative;
    overflow: hidden;
    z-index: 1100;
  }
  
  /* Lueur ambre filante en fond */
  .sf-announcement-bar::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent 0%, rgba(232, 157, 70, 0.05) 50%, transparent 100%);
    animation: light-sweep-sf 6s infinite linear;
    mix-blend-mode: plus-lighter;
    pointer-events: none;
  }
  
  @keyframes light-sweep-sf {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(100%); }
  }

  .sf-announcement-carousel {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .sf-announcement-slide {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.5s ease-in-out, visibility 0.5s ease-in-out;
  }

  .sf-announcement-slide.is-active {
    opacity: 1;
    visibility: visible;
  }
  
  .sf-announcement-text {
    color: var(--illu-text-cream, #F9F9F9);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    position: relative;
    z-index: 2;
    margin: 0;
    display: flex;
    align-items: center;
    gap: 8px;
    text-align: center;
    padding: 0 20px;
  }
  
  .sf-announcement-text span {
    color: var(--illu-accent-amber, #E89D46);
    text-shadow: 0 0 10px rgba(232, 157, 70, 0.3);
  }
  
  .sf-announcement-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    filter: brightness(1.2) drop-shadow(0 0 5px var(--illu-accent-amber, #E89D46));
    animation: heartbeat-sf 3s infinite ease-in-out;
  }

  @keyframes heartbeat-sf {
    0%, 100% { transform: scale(1); opacity: 0.8; }
    50% { transform: scale(1.1); opacity: 1; }
  }
  
  .sf-announcement-link {
    text-decoration: none;
    color: inherit;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
  }
  .sf-announcement-link:hover .sf-announcement-text span {
    text-shadow: 0 0 15px rgba(232, 157, 70, 0.6);
  }
</style>

{%- if section.settings.show_announcement and section.blocks.size > 0 -%}
  <div class="sf-announcement-bar" role="region" aria-label="Annonce" data-speed="{{ section.settings.rotation_speed | times: 1000 }}">
    <div class="sf-announcement-carousel">
      {%- for block in section.blocks -%}
        <div class="sf-announcement-slide {% if forloop.first %}is-active{% endif %}" {{ block.shopify_attributes }}>
          {%- if block.settings.link != blank -%}
            <a href="{{ block.settings.link }}" class="sf-announcement-link">
          {%- else -%}
            <div class="sf-announcement-link">
          {%- endif -%}
          
            <p class="sf-announcement-text" style="font-family: var(--illu-font-main, sans-serif);">
              {%- if block.settings.show_icon -%}
                <span class="sf-announcement-icon">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12 2L14.5 9.5L22 12L14.5 14.5L12 22L9.5 14.5L2 12L9.5 9.5L12 2Z" fill="#E89D46" filter="drop-shadow(0 0 3px rgba(232, 157, 70, 0.5))"/>
                  </svg>
                </span>
              {%- endif -%}
              {{ block.settings.text_first_part }}
              {%- if block.settings.text_highlight != blank -%}
                <span>{{ block.settings.text_highlight }}</span>
              {%- endif -%}
            </p>
            
          {%- if block.settings.link != blank -%}
            </a>
          {%- else -%}
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>

  {%- if section.blocks.size > 1 -%}
    <script>
      document.addEventListener('DOMContentLoaded', function() {
        const bar = document.querySelector('.sf-announcement-bar');
        if (!bar) return;
        const slides = bar.querySelectorAll('.sf-announcement-slide');
        const speed = parseInt(bar.dataset.speed, 10) || 5000;
        let currentIndex = 0;
        let interval;

        function showNextSlide() {
          slides[currentIndex].classList.remove('is-active');
          currentIndex = (currentIndex + 1) % slides.length;
          slides[currentIndex].classList.add('is-active');
        }

        function startRotation() {
          interval = setInterval(showNextSlide, speed);
        }

        function stopRotation() {
          clearInterval(interval);
        }

        startRotation();

        // Pause on hover
        bar.addEventListener('mouseenter', stopRotation);
        bar.addEventListener('mouseleave', startRotation);
        
        // Handle theme editor events to show the correct block
        document.addEventListener('shopify:block:select', function(event) {
          stopRotation();
          slides.forEach((slide, index) => {
             if (slide.contains(event.target) || slide === event.target) {
               slides[currentIndex].classList.remove('is-active');
               currentIndex = index;
               slides[currentIndex].classList.add('is-active');
             }
          });
        });
        document.addEventListener('shopify:block:deselect', startRotation);
      });
    </script>
  {%- endif -%}
{%- endif -%}

{% schema %}
{
  "name": "✨ Barre d'Annonce",
  "tag": "section",
  "class": "section",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Afficher la barre d'annonce",
      "default": true
    },
    {
      "type": "range",
      "id": "rotation_speed",
      "min": 2,
      "max": 10,
      "step": 1,
      "unit": "s",
      "label": "Vitesse de rotation",
      "default": 4
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Annonce",
      "settings": [
        {
          "type": "checkbox",
          "id": "show_icon",
          "label": "Afficher l'icône étincelle ✨",
          "default": true
        },
        {
          "type": "text",
          "id": "text_first_part",
          "label": "Texte principal",
          "default": "Nouvelle ambiance Nuit Étoilée disponible : "
        },
        {
          "type": "text",
          "id": "text_highlight",
          "label": "Texte mis en valeur (Ambre)",
          "default": "Transformez sa chambre dès ce soir."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Lien cible"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "✨ Barre d'Annonce (Illuminées)",
      "blocks": [
         {
           "type": "announcement"
         }
      ]
    }
  ]
}
{% endschema %}

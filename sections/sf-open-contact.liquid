{{ 'sf-open-contact.css' | asset_url | stylesheet_tag }}

<div class="sf-open-contact-section">
  <div class="contact-hero-simple">

    
    <h1>{{ section.settings.heading | default: 'On reste en contact ?' }}</h1>
    <p class="contact-description">
      {{ section.settings.description | default: 'Une question sur une commande, un doute sur une lampe ou juste un mot doux... On vous répond avec plaisir.' }}
    </p>
  </div>

  <div class="contact-card-vaporeuse">
    {%- form 'contact', id: 'ContactForm' -%}
      {%- if form.posted_successfully? -%}
        <div class="form-status form-status-list form__message" tabindex="-1" autofocus style="color: #4ade80; text-align: center; margin-bottom: 24px;">
          Votre message a bien été envoyé. Nous vous répondrons rapidement !
        </div>
      {%- elsif form.errors -%}
        <div class="form__message" style="color: #ef4444; margin-bottom: 24px;">
          Une erreur est survenue. Veuillez vérifier vos informations.
        </div>
      {%- endif -%}

      <label class="contact-field-label" for="ContactForm-subject">Sujet de votre message</label>
      <select id="ContactForm-subject" name="contact[sujet]" class="contact-select">
        <option value="Suivi de commande">Suivi de commande</option>
        <option value="Question technique">Question technique</option>
        <option value="Demande de partenariat">Demande de partenariat</option>
        <option value="Autre">Autre</option>
      </select>

      <div class="contact-input-row">
        <div>
          <label class="contact-field-label" for="ContactForm-name">Nom complet</label>
          <input class="contact-input" autocomplete="name" type="text" id="ContactForm-name" name="contact[name]" value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}" placeholder="Votre petit nom...">
        </div>
        <div>
          <label class="contact-field-label" for="ContactForm-email">Adresse Email</label>
          <input autocomplete="email" type="email" id="ContactForm-email" class="contact-input" name="contact[email]" spellcheck="false" autocapitalize="off" value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}" aria-required="true" placeholder="Votre mail pour vous répondre...">
        </div>
      </div>

      <label class="contact-field-label" for="ContactForm-body">Votre message</label>
      <textarea rows="6" id="ContactForm-body" class="contact-input" name="contact[body]" placeholder="Dites-nous tout...">{{- form.body -}}</textarea>

      <button type="submit" class="btn-contact-submit">
        ENVOYER
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="#081A32" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <p class="contact-promise-text">Promis, on vous répond sous 24h.</p>
    {%- endform -%}
  </div>
</div>

{% schema %}
{
  "name": "Contact Open Door",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "On reste en contact ?",
      "label": "Titre"
    },
    {
      "type": "textarea",
      "id": "description",
      "default": "Une question sur une commande, un doute sur une lampe ou juste un mot doux... On vous répond avec plaisir.",
      "label": "Description"
    }
  ],
  "presets": [
    {
      "name": "Contact Open Door"
    }
  ]
}
{% endschema %}

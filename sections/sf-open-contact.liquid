{{ 'sf-open-contact.css' | asset_url | stylesheet_tag }}

<div class="sf-open-contact-section">
  <div class="contact-hero-simple">
    <div class="sf-badge-expert">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M9 21H15M12 11V15M12 2C6.47715 2 2 6.47715 2 12C2 13.5997 2.37563 15.1116 3.04346 16.4525C3.39345 17.1554 3.73836 17.7011 4.14652 18.2612C4.78281 19.1343 5.37257 19.8974 5.92348 20.8413C6.31976 21.5204 7.05436 22 7.84687 22H16.1531C16.9456 22 17.6802 21.5204 18.0765 20.8413C18.6274 19.8974 19.2172 19.1343 19.8535 18.2612C20.2616 17.7011 20.6066 17.1554 20.9565 16.4525C21.6244 15.1116 22 13.5997 22 12C22 6.47715 17.5228 2 12 2Z" stroke="#E89D46" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      ILLUMINÉES
    </div>
    
    <h1>{{ section.settings.heading | default: 'On reste en contact ?' }}</h1>
    <p class="contact-description">
      {{ section.settings.description | default: 'Une question sur une commande, un doute sur une lampe ou juste un mot doux... On vous répond avec plaisir.' }}
    </p>
  </div>

  <div class="contact-card-vaporeuse">
    {%- form 'contact', id: 'ContactForm' -%}
      {%- if form.posted_successfully? -%}
        <div class="form-status form-status-list form__message" tabindex="-1" autofocus style="color: #4ade80; text-align: center; margin-bottom: 24px;">
          Votre message a bien été envoyé. Nous vous répondrons rapidement !
        </div>
      {%- elsif form.errors -%}
        <div class="form__message" style="color: #ef4444; margin-bottom: 24px;">
          Une erreur est survenue. Veuillez vérifier vos informations.
        </div>
      {%- endif -%}

      <label class="field__label" for="ContactForm-subject">{{ 'templates.contact.form.subject' | t | default: 'Sujet de votre message' }}</label>
      <select id="ContactForm-subject" name="contact[sujet]" class="contact-select">
        <option value="Suivi de commande">Suivi de commande</option>
        <option value="Question technique">Question technique</option>
        <option value="Demande de partenariat">Demande de partenariat</option>
        <option value="Autre">Autre</option>
      </select>

      <div class="contact-input-row">
        <div>
          <label class="field__label" for="ContactForm-name">{{ 'templates.contact.form.name' | t | default: 'Nom complet' }}</label>
          <input class="contact-input" autocomplete="name" type="text" id="ContactForm-name" name="contact[{{ 'templates.contact.form.name' | t | default: 'name' }}]" value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}" placeholder="Votre petit nom...">
        </div>
        <div>
          <label class="field__label" for="ContactForm-email">{{ 'templates.contact.form.email' | t | default: 'Adresse Email' }}</label>
          <input autocomplete="email" type="email" id="ContactForm-email" class="contact-input" name="contact[email]" spellcheck="false" autocapitalize="off" value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}" aria-required="true" placeholder="Votre mail pour vous répondre...">
        </div>
      </div>

      <label class="field__label" for="ContactForm-body">{{ 'templates.contact.form.comment' | t | default: 'Votre message' }}</label>
      <textarea rows="6" id="ContactForm-body" class="contact-input" name="contact[{{ 'templates.contact.form.comment' | t | default: 'body' }}]" placeholder="Dites-nous tout...">{{- form.body -}}</textarea>

      <button type="submit" class="btn-contact-submit">
        {{ 'templates.contact.form.send' | t | default: 'Envoyer le message' }}
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="#081A32" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <p class="contact-promise-text">Promis, on vous répond sous 24h.</p>
    {%- endform -%}
  </div>
</div>

{% schema %}
{
  "name": "Contact Open Door",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "On reste en contact ?",
      "label": "Titre"
    },
    {
      "type": "textarea",
      "id": "description",
      "default": "Une question sur une commande, un doute sur une lampe ou juste un mot doux... On vous répond avec plaisir.",
      "label": "Description"
    }
  ],
  "presets": [
    {
      "name": "Contact Open Door"
    }
  ]
}
{% endschema %}

{% schema %}
{
  "name": "Exploration Lumineuse",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titre Principal",
      "default": "Exploration Lumineuse"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Sous-titre",
      "default": "Découvrez nos univers dédiés à la science de la lumière, de l'éveil des plus petits à l'optimisation de votre espace de travail."
    }
  ],
  "blocks": [
    {
      "type": "bento_card",
      "name": "Carte Navigation",
      "limit": 4,
      "settings": [
        {
          "type": "select",
          "id": "card_width",
          "label": "Taille de la carte (Asymétrie)",
          "options": [
            { "value": "grid-pos-0", "label": "Large (6 colonnes - ex: Parents)" },
            { "value": "grid-pos-1", "label": "Moyenne (4 colonnes - ex: Labo)" },
            { "value": "grid-pos-2", "label": "Compacte (4 ou 6 col en bas)" },
            { "value": "grid-pos-3", "label": "Texte Large (6 col bas droit)" }
          ],
          "default": "grid-pos-0"
        },
        {
          "type": "checkbox",
          "id": "is_text_only",
          "label": "Mode Texte Uniquement",
          "default": false
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titre"
        },
        {
          "type": "textarea",
          "id": "subtitle",
          "label": "Mots-clés / Sous-titre"
        },
        {
          "type": "textarea",
          "id": "icon_svg",
          "label": "Icône SVG"
        },
        {
          "type": "image_picker",
          "id": "bg_image",
          "label": "Image de fond"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Lien de redirection"
        },
        {
          "type": "text",
          "id": "cta_text",
          "label": "Texte Bouton Action",
          "info": "Laisser vide si aucun bouton (ex: QG du Flow n'en a pas sur la maquette)"
        },
        {
          "type": "text",
          "id": "badge_text",
          "label": "Texte du Badge (optionnel)",
          "info": "Ex: PREMIUM"
        },
        {
          "type": "header",
          "content": "Mode Texte Seulement (Optionnel)"
        },
        {
          "type": "text",
          "id": "secondary_cta_1",
          "label": "Lien Texte 1"
        },
        {
          "type": "text",
          "id": "secondary_cta_2",
          "label": "Lien Texte 2"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Exploration Lumineuse (Bento)",
      "category": "Illuminées Manifeste",
      "blocks": [
        {
          "type": "bento_card",
          "settings": {
            "card_width": "grid-pos-0",
            "title": "L'École des Parents",
            "subtitle": "Sommeil, Veilleuses, Sécurité",
            "cta_text": "Découvrir l'univers ➔",
            "icon_svg": "<svg width=\"32\" height=\"32\" viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n  <path d=\"M4 19V5C4 3.89543 4.89543 3 6 3H18C19.1046 3 20 3.89543 20 5V19\" stroke=\"#E89D46\" stroke-width=\"1.5\" stroke-linecap=\"round\"/>\n  <path d=\"M2 19H22\" stroke=\"#E89D46\" stroke-width=\"1.5\" stroke-linecap=\"round\"/>\n  <circle cx=\"12\" cy=\"11\" r=\"3\" stroke=\"#E89D46\" stroke-width=\"1.5\" opacity=\"0.6\"/>\n</svg>"
          }
        },
        {
          "type": "bento_card",
          "settings": {
            "card_width": "grid-pos-1",
            "title": "Le Labo Technique",
            "subtitle": "Lumière bleue, IRC, Scintillement",
            "cta_text": "Explorer la science",
            "icon_svg": "<svg width=\"32\" height=\"32\" viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n  <path d=\"M12 2L2 20H22L12 2Z\" stroke=\"#E89D46\" stroke-width=\"1.5\" stroke-linejoin=\"round\"/>\n  <path d=\"M2 20L12 12\" stroke=\"#E89D46\" stroke-width=\"1.5\" stroke-linecap=\"round\" opacity=\"0.4\"/>\n  <path d=\"M12 12L22 20\" stroke=\"#E89D46\" stroke-width=\"1.5\" stroke-linecap=\"round\" opacity=\"0.4\"/>\n</svg>"
          }
        },
        {
          "type": "bento_card",
          "settings": {
            "card_width": "grid-pos-2",
            "title": "Le QG du Flow",
            "subtitle": "Productivité, Setup, Immersion",
            "badge_text": "PREMIUM",
            "icon_svg": "<svg width=\"32\" height=\"32\" viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n  <circle cx=\"12\" cy=\"12\" r=\"9\" stroke=\"#E89D46\" stroke-width=\"1.5\" opacity=\"0.3\"/>\n  <path d=\"M12 8V12L14 14\" stroke=\"#E89D46\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n  <path d=\"M12 2v2M12 20v2M2 12h2M20 12h2\" stroke=\"#E89D46\" stroke-width=\"1.5\" stroke-linecap=\"round\"/>\n</svg>"
          }
        },
        {
          "type": "bento_card",
          "settings": {
            "card_width": "grid-pos-3",
            "is_text_only": true,
            "title": "La lumière influence votre vie",
            "subtitle": "Saviez-vous que la température de couleur affecte directement votre cycle circadien ? Apprenez à maîtriser votre environnement lumineux avec L'Atelier.",
            "secondary_cta_1": "Lire le manifeste",
            "secondary_cta_2": "Nos guides ➔",
            "icon_svg": "<svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n<circle cx=\"12\" cy=\"10\" r=\"6\" stroke=\"#E89D46\" stroke-width=\"2\"/>\n<path d=\"M10 19L14 19M11 22L13 22\" stroke=\"#E89D46\" stroke-width=\"2\" stroke-linecap=\"round\"/>\n<path d=\"M12 16V19\" stroke=\"#E89D46\" stroke-width=\"2\" stroke-linecap=\"round\"/>\n</svg>"
          }
        }
      ]
    }
  ]
}
{% endschema %}

<style>
  html { scroll-behavior: smooth; }

  /* Root Continuity & Antialiasing */
  .atelier-bento-section {
    padding: 80px 4rem 120px 4rem;
    background-color: var(--illu-bg-night, #081A32);
    font-family: var(--illu-font-main, 'Inter', sans-serif);
    -webkit-font-smoothing: antialiased; /* Vital pour les textes immersifs */
  }

  .atelier-bento-content {
    max-width: 1400px;
    margin: 0 auto;
  }

  /* Header Area */
  .atelier-bento-header {
    margin-bottom: 56px;
    max-width: 800px;
  }

  .atelier-bento-title {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 700;
    color: #F9F9F9;
    letter-spacing: -0.02em;
    margin: 0 0 16px 0;
    line-height: 1.1;
  }

  .atelier-bento-subtitle {
    font-size: 1.15rem;
    color: rgba(249, 249, 249, 0.7);
    line-height: 1.6;
    margin: 0;
  }

  /* Bento Grid Layout */
  .atelier-bento-grid {
    display: grid;
    grid-template-columns: repeat(10, 1fr);
    grid-auto-rows: minmax(350px, auto);
    gap: 24px;
  }

  /* Asymétrie demandée (adaptation personnalisée maquette vs CSS fourni) */
  /* Sur la maquette : Parents en haut gauche, Labo haut droite. En bas : Flow gauche, Texte droite. */
  .bento-card-wrapper {
    display: flex; /* Permet un height 100% de l'enfant */
  }

  .grid-pos-0 { grid-column: span 6;  grid-row: span 1; } /* Parents */
  .grid-pos-1 { grid-column: span 4;  grid-row: span 1; } /* Labo */
  .grid-pos-2 { grid-column: span 4;  grid-row: span 1; } /* QG Flow */
  .grid-pos-3 { grid-column: span 6;  grid-row: span 1; } /* Texte large final optionnel - si 4ème bloc */

  /* Fallback s'il y a plus de blocs que prévu ou moins */
  .bento-parents { grid-column: span 6; }
  .bento-labo { grid-column: span 4; }
  .bento-qg { grid-column: span 4; }

  /* Carte Link Container */
  .bento-card-link {
    position: relative;
    width: 100%;
    border-radius: 32px; /* Chubby */
    overflow: hidden;
    background: #112640; /* Couleur fond si pas d'image */
    border: 1px solid rgba(255, 255, 255, 0.05);
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    text-decoration: none;
    display: flex;
    flex-direction: column;
  }

  /* Hover Effects */
  .bento-card-link:hover {
    transform: translateY(-8px);
    border-color: rgba(232, 157, 70, 0.3);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
  }

  /* Image Visual & Parallax Hover */
  .bento-visual {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.5;
    transition: transform 1.2s cubic-bezier(0.2, 0, 0, 1), opacity 0.5s ease;
    z-index: 0;
  }

  .bento-card-link:hover .bento-visual {
    transform: scale(1.05);
    opacity: 0.8;
  }

  /* Light Reveal Effect (Pseudo-element au survol) */
  .bento-card-link::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 50% 100%, rgba(232, 157, 70, 0.15) 0%, transparent 60%);
    mix-blend-mode: plus-lighter;
    opacity: 0;
    transition: opacity 0.6s ease;
    z-index: 1;
    pointer-events: none;
  }

  .bento-card-link:hover::after {
    opacity: 1;
  }

  /* Dark Overlay for Text Readable */
  .bento-overlay-content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 40px;
    background: linear-gradient(to top, rgba(8, 26, 50, 0.9) 0%, rgba(8, 26, 50, 0.4) 40%, transparent 80%);
    z-index: 2;
  }

  /* Cas spécial : Bloc Texte sans image (Comme la maquette en bas à droite) */
  .bento-text-only .bento-overlay-content {
    background: #1C2D41;
    justify-content: center;
    align-items: center;
    text-align: center;
  }

  /* Eléments textuels */
  .bento-icon {
    width: 32px;
    height: 32px;
    color: var(--illu-accent-amber, #E89D46);
    margin-bottom: auto;
  }

  /* Pour le bloc texte centré */
  .bento-text-only .bento-icon {
    margin-bottom: 24px;
    width: 48px;
    height: 48px;
    background: rgba(232, 157, 70, 0.1);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    filter: drop-shadow(0 0 10px rgba(232, 157, 70, 0.3));
  }
  .bento-text-only .bento-icon svg { width: 24px; height: 24px; }

  .bento-card-title {
    font-size: 1.8rem;
    font-weight: 700;
    color: #F9F9F9;
    margin: 0 0 8px 0;
    letter-spacing: -0.01em;
  }

  .bento-card-subtitle {
    font-size: 1rem;
    color: rgba(249, 249, 249, 0.7);
    margin: 0;
  }

  .bento-text-only .bento-card-subtitle {
    margin: 16px 0 32px 0;
    line-height: 1.6;
    max-width: 80%;
  }

  /* CTA actions (Boutons, Liens) */
  .bento-card-action {
    display: inline-flex;
    align-items: center;
    font-weight: 600;
    color: #E89D46;
    margin-top: 24px;
    font-size: 0.95rem;
    transition: color 0.3s ease;
  }

  /* Styles Bouton encadré transparent (Ex: Labo Technique) */
  .bento-btn-outline {
    margin-top: 24px;
    padding: 10px 24px;
    border: 1px solid rgba(232, 157, 70, 0.3);
    border-radius: 99px;
    color: #E89D46;
    background: rgba(232, 157, 70, 0.05); /* Glassmorphism light */
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    font-weight: 600;
    font-size: 0.95rem;
    align-self: flex-start;
    transition: all 0.3s ease;
  }

  .bento-card-link:hover .bento-btn-outline {
    background: rgba(232, 157, 70, 0.1);
    border-color: #E89D46;
  }

  /* Actions groupés pour le bloc texte info */
  .bento-actions-group {
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .bento-link-underline {
    color: #E89D46;
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .bento-link-sub {
    color: rgba(249, 249, 249, 0.6);
    font-size: 0.95rem;
  }

  /* Badge Premium Absolute */
  .bento-badge {
    position: absolute;
    top: 32px;
    right: 32px;
    background: rgba(232, 157, 70, 0.9);
    color: #081A32;
    padding: 4px 12px;
    border-radius: 99px;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    z-index: 3;
    pointer-events: none;
  }

  /* Responsive Constraints */
  @media screen and (max-width: 1024px) {
    .atelier-bento-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 350px;
    }
    .grid-pos-0, .grid-pos-1, .grid-pos-2, .grid-pos-3, .bento-parents, .bento-labo, .bento-qg {
      grid-column: span 1;
    }
  }

  @media screen and (max-width: 768px) {
    .atelier-bento-section {
      padding: 60px 1.5rem 80px 1.5rem;
    }
    .atelier-bento-grid {
      grid-template-columns: 1fr;
      grid-auto-rows: minmax(320px, auto);
      gap: 16px;
    }
    .atelier-bento-title {
      font-size: 2.2rem;
    }
    .bento-overlay-content {
      padding: 32px 24px;
    }
    .bento-card-title {
      font-size: 1.5rem;
    }
    .bento-badge {
      top: 24px; right: 24px;
    }
    .bento-actions-group {
      flex-direction: column;
      gap: 16px;
    }
  }
</style>

<section class="atelier-bento-section">
  <div class="atelier-bento-content">

    <div class="atelier-bento-header">
      {% if section.settings.title != blank %}
        <h2 class="atelier-bento-title">{{ section.settings.title }}</h2>
      {% endif %}
      {% if section.settings.subtitle != blank %}
        <p class="atelier-bento-subtitle">{{ section.settings.subtitle }}</p>
      {% endif %}
    </div>

    <!-- GRILLE BENTO -->
    <div class="atelier-bento-grid">
      {% for block in section.blocks %}
        {% assign pos_class = block.settings.card_width %}
        
        <div class="bento-card-wrapper {{ pos_class }}" {{ block.shopify_attributes }}>
          {% if block.settings.is_text_only %}
            <div class="bento-card-link bento-text-only" style="cursor: default;">
              <div class="bento-overlay-content">
                 <div class="bento-icon">
                   {{ block.settings.icon_svg }}
                 </div>
                 <h3 class="bento-card-title">{{ block.settings.title }}</h3>
                 <p class="bento-card-subtitle">{{ block.settings.subtitle }}</p>
                 <div class="bento-actions-group">
                   {% if block.settings.secondary_cta_1 != blank %}
                     <a href="{{ block.settings.link | default: '#' }}" class="bento-link-underline">{{ block.settings.secondary_cta_1 }}</a>
                   {% endif %}
                   {% if block.settings.secondary_cta_2 != blank %}
                     <a href="{{ block.settings.link | default: '#' }}" class="bento-link-sub">{{ block.settings.secondary_cta_2 }}</a>
                   {% endif %}
                 </div>
              </div>
            </div>
          {% else %}
            <a href="{{ block.settings.link | default: '#' }}" class="bento-card-link">
              
              {% if block.settings.badge_text != blank %}
                <div class="bento-badge">{{ block.settings.badge_text }}</div>
              {% endif %}

              {% if block.settings.bg_image != blank %}
                {{ block.settings.bg_image | image_url: width: 800 | image_tag: class: 'bento-visual', loading: 'lazy' }}
              {% else %}
                 <!-- Improvise background si vide -->
                 <div class="bento-visual" style="background: linear-gradient(135deg, #1A365D 0%, #0F172A 100%);"></div>
              {% endif %}
              
              <div class="bento-overlay-content">
                {% if block.settings.icon_svg != blank %}
                  <div class="bento-icon">{{ block.settings.icon_svg }}</div>
                {% endif %}
                
                <h3 class="bento-card-title">{{ block.settings.title }}</h3>
                <p class="bento-card-subtitle">{{ block.settings.subtitle }}</p>
                
                {% if block.settings.cta_text != blank %}
                  <!-- Style conditionnel basé sur la longueur ou le design (Maquette) -->
                  {% if forloop.index == 2 %}
                    <span class="bento-btn-outline">{{ block.settings.cta_text }}</span>
                  {% else %}
                    <span class="bento-card-action">{{ block.settings.cta_text }}</span>
                  {% endif %}
                {% endif %}
              </div>
            </a>
          {% endif %}
        </div>
      {% endfor %}
    </div>

  </div>
</section>

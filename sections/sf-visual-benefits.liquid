{% schema %}
{
  "name": "Bénéfices Visuels",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titre de section",
      "default": "Ce que cette ambiance permet"
    },
    {
      "type": "text",
      "id": "footer_text",
      "label": "Texte final",
      "default": "La lumière se voit. Elle se ressent."
    }
  ],
  "blocks": [
    {
      "type": "benefit_card",
      "name": "Carte Bénéfice",
      "limit": 3,
      "settings": [
        {
          "type": "html",
          "id": "icon",
          "label": "Icône SVG"
        },
        {
          "type": "textarea",
          "id": "title",
          "label": "Titre du bénéfice",
          "default": "Titre du bénéfice"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Description du bénéfice apporté."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bénéfices Visuels",
      "blocks": [
        {
          "type": "benefit_card",
          "settings": {
            "icon": "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"12\" cy=\"12\" r=\"4\"/><path d=\"M12 2v2\"/><path d=\"M12 20v2\"/><path d=\"m4.93 4.93 1.41 1.41\"/><path d=\"m17.66 17.66 1.41 1.41\"/><path d=\"M2 12h2\"/><path d=\"M20 12h2\"/><path d=\"m6.34 17.66-1.41 1.41\"/><path d=\"m19.07 4.93-1.41 1.41\"/></svg>",
            "title": "Créer une présence lumineuse sans éblouir",
            "text": "Profitez d'une diffusion optimale pour un confort visuel absolu lors de vos sessions tardives."
          }
        },
        {
          "type": "benefit_card",
          "settings": {
            "icon": "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"12\" cy=\"5\" r=\"1\"/><circle cx=\"19\" cy=\"5\" r=\"1\"/><circle cx=\"5\" cy=\"5\" r=\"1\"/><circle cx=\"12\" cy=\"12\" r=\"1\"/><circle cx=\"19\" cy=\"12\" r=\"1\"/><circle cx=\"5\" cy=\"12\" r=\"1\"/><circle cx=\"12\" cy=\"19\" r=\"1\"/><circle cx=\"19\" cy=\"19\" r=\"1\"/><circle cx=\"5\" cy=\"19\" r=\"1\"/></svg>",
            "title": "Structurer un espace avec des halos et des contrastes",
            "text": "Redéfinissez les volumes de votre pièce grâce à des jeux d'ombres et de lumières architecturaux."
          }
        },
        {
          "type": "benefit_card",
          "settings": {
            "icon": "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M3.85 8.62a4 4 0 0 1 4.78-4.77 4 4 0 0 1 6.74 0 4 4 0 0 1 4.78 4.78 4 4 0 0 1 0 6.74 4 4 0 0 1-4.77 4.78 4 4 0 0 1-6.75 0 4 4 0 0 1-4.78-4.77 4 4 0 0 1 0-6.76Z\"/><path d=\"m9 12 2 2 4-4\"/></svg>",
            "title": "Donner du caractère à une chambre ou un setup",
            "text": "Apposez votre signature visuelle unique et transformez votre environnement en un sanctuaire personnel."
          }
        }
      ]
    }
  ]
}
{% endschema %}

<style>
/* Section Visuels Bénéfices - sf-visual-benefits.css */

#shopify-section-{{ section.id }} .visual-benefits-section {
  background-color: #081A32; /* illu-night */
  padding: 100px 0;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

/* En-tête */
#shopify-section-{{ section.id }} .visual-benefits-header {
  text-align: left;
  max-width: 1300px;
  margin: 0 auto 4rem auto;
  padding: 0 4rem;
}

#shopify-section-{{ section.id }} .visual-title {
  font-size: clamp(2.2rem, 4vw, 3.2rem);
  color: #F9F9F9;
  font-weight: 800;
  margin: 0;
  display: inline-block;
  position: relative;
  letter-spacing: -0.02em;
}

/* Soulignement Ambre (gauche) */
#shopify-section-{{ section.id }} .visual-title::after {
  content: '';
  position: absolute;
  bottom: -10px;
  left: 0;
  width: 60px;
  height: 4px;
  background-color: #E89D46; /* illu-amber */
  border-radius: 2px;
}

/* Grille */
#shopify-section-{{ section.id }} .visual-benefit-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 32px;
  padding: 0 4rem;
  max-width: 1300px;
  margin: 0 auto;
}

/* Carte */
#shopify-section-{{ section.id }} .visual-benefit-card {
  background: rgba(255, 255, 255, 0.02);
  border: 1px solid rgba(255, 255, 255, 0.05);
  border-radius: 32px; /* radius chubby (32px) */
  padding: 48px 32px;
  text-align: left;
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

#shopify-section-{{ section.id }} .visual-benefit-card:hover {
  transform: translateY(-8px);
  border-color: rgba(232, 157, 70, 0.3);
  background: rgba(255, 255, 255, 0.04);
}

/* Icônes */
#shopify-section-{{ section.id }} .visual-icon-wrapper {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 56px;
  height: 56px;
  background: rgba(255, 255, 255, 0.03); /* subtle dark background inside the card */
  border: 1px solid rgba(255, 255, 255, 0.05);
  border-radius: 16px;
  color: #E89D46;
  margin-bottom: 2rem;
  transition: all 0.4s ease;
  filter: drop-shadow(0 0 10px rgba(232, 157, 70, 0.3)); /* Lueur permanente demandée */
}

#shopify-section-{{ section.id }} .visual-icon-wrapper svg {
  width: 28px !important;
  height: 28px !important;
  min-width: 28px;
  min-height: 28px;
  display: block;
  flex-shrink: 0;
}

/* Textes des cartes */
#shopify-section-{{ section.id }} .visual-benefit-title {
  color: #F9F9F9;
  font-size: 1.25rem;
  font-weight: 700;
  margin: 0 0 1rem 0;
  line-height: 1.3;
  white-space: pre-line;
}

#shopify-section-{{ section.id }} .visual-benefit-desc {
  color: #9CA3AF; /* Gris clair */
  font-size: 0.95rem;
  line-height: 1.6;
  margin: 0;
}

/* Footer texte */
#shopify-section-{{ section.id }} .visual-footer-text {
  text-align: center;
  color: #E89D46;
  font-size: clamp(1.4rem, 2.5vw, 1.8rem);
  font-weight: 700;
  margin-top: 5rem;
  padding: 0 2rem;
}

/* MOBILE RESPONSIVE - SNAP CAROUSEL */
@media screen and (max-width: 1024px) {
  #shopify-section-{{ section.id }} .visual-benefit-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media screen and (max-width: 768px) {
  #shopify-section-{{ section.id }} .visual-benefits-section {
    padding: 80px 0;
  }
  
  #shopify-section-{{ section.id }} .visual-benefits-header {
    padding: 0 1.5rem;
    margin-bottom: 3rem;
  }
  
  #shopify-section-{{ section.id }} .visual-title {
    font-size: 2.2rem;
  }

  /* Slider Snap Logic */
  #shopify-section-{{ section.id }} .visual-benefit-grid-wrapper {
    width: 100vw;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding-bottom: 2rem;
  }

  #shopify-section-{{ section.id }} .visual-benefit-grid-wrapper::-webkit-scrollbar {
    display: none;
  }

  #shopify-section-{{ section.id }} .visual-benefit-grid {
    display: flex;
    flex-direction: row;
    width: max-content;
    padding: 0 1.5rem;
    margin: 0;
    gap: 1.25rem;
  }
  
  #shopify-section-{{ section.id }} .visual-benefit-card {
    scroll-snap-align: center;
    width: 85vw;
    max-width: 320px;
    padding: 32px 24px;
  }
  
  #shopify-section-{{ section.id }} .visual-footer-text {
    margin-top: 3rem;
    font-size: 1.2rem;
  }
}
</style>

<section class="visual-benefits-section sf-stitch">
  
  <div class="visual-benefits-header">
    {% if section.settings.title != blank %}
      <h2 class="visual-title">{{ section.settings.title }}</h2>
    {% endif %}
  </div>

  {% if section.blocks.size > 0 %}
    <div class="visual-benefit-grid-wrapper">
      <div class="visual-benefit-grid">
        {% for block in section.blocks %}
          <div class="visual-benefit-card" {{ block.shopify_attributes }}>
            <div class="visual-icon-wrapper">
              {% if block.settings.icon != blank %}
                {{ block.settings.icon }}
              {% endif %}
            </div>
            <h3 class="visual-benefit-title">{{ block.settings.title | newline_to_br }}</h3>
            <p class="visual-benefit-desc">{{ block.settings.text }}</p>
          </div>
        {% endfor %}
      </div>
    </div>
  {% endif %}

  {% if section.settings.footer_text != blank %}
    <div class="visual-footer-text">
      {{ section.settings.footer_text }}
    </div>
  {% endif %}

</section>

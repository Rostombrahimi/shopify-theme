{% schema %}
{
  "name": "Transition Forêt CTA",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "LA COLLECTION AMIS DE LA FORÊT"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Heading",
      "default": "Une présence rassurante,<br>inspirée par la nature"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Main Product Image"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Pour cette ambiance, nous avons sélectionné une base lumineuse douce, déclinée en plusieurs formes inspirées du monde naturel, afin de créer une présence rassurante adaptée à chaque enfant."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Découvrir la veilleuse Amis de la Forêt"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "text",
      "id": "footer_text",
      "label": "Footer Trust Text",
      "default": "RECOMMANDÉ PAR NOS EXPERTS"
    }
  ],
  "presets": [
    {
      "name": "Transition Forêt CTA"
    }
  ]
}
{% endschema %}

<style>
/* Transition Produit - Forest */
.forest-cta-section {
  position: relative;
  background-color: #081A32;
  padding: 120px 4rem;
  text-align: center;
  overflow: hidden;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

.forest-cta-aura {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 1000px;
  height: 1000px;
  background: radial-gradient(circle, rgba(232, 157, 70, 0.1) 0%, transparent 60%);
  z-index: 1;
  pointer-events: none;
}

.forest-cta-container {
  max-width: 900px;
  margin: 0 auto;
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.forest-cta-badge {
  color: rgba(249, 249, 249, 0.5);
  font-size: 0.88rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  margin-bottom: 1.5rem;
}

.forest-cta-h2 {
  font-size: clamp(2.2rem, 4.4vw, 3.52rem);
  color: #F9F9F9;
  line-height: 1.15;
  margin: 0 0 4rem 0;
  font-weight: 600;
  letter-spacing: -0.02em;
}

.forest-cta-media-container {
  width: 100%;
  margin-bottom: 4rem;
  position: relative;
}

.forest-cta-media {
  width: 100%;
  aspect-ratio: 16/9;
  border-radius: 40px;
  overflow: hidden;
  position: relative;
  box-shadow: 0 40px 80px rgba(0, 0, 0, 0.3);
  background: #112642; /* Fallback */
}

/* Saturation Visuelle */
.forest-cta-media img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  filter: saturate(1.1) contrast(1.05); /* Rendu vibrant demandé */
  transition: transform 0.7s ease;
}

.forest-cta-media:hover img {
  transform: scale(1.03);
}

/* Ombre projetée interne pour adoucir les bords de l'image */
.forest-cta-media::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 40px;
  box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.05), inset 0 0 20px rgba(0, 0, 0, 0.5);
  pointer-events: none;
}

.forest-cta-text {
  font-size: 1.26rem;
  color: #F9F9F9;
  line-height: 1.6;
  margin-bottom: 3rem;
  opacity: 0.85;
  max-width: 700px;
}

/* Le CTA Pilule Ambre */
.btn-forest-primary {
  display: inline-flex;
  align-items: center;
  gap: 12px;
  padding: 16px 40px;
  background: #E89D46;
  color: #081A32;
  border-radius: 99px; /* Forme de pilule absolue */
  font-weight: 600;
  font-size: 1.21rem;
  text-transform: none; /* Le mockup montre un texte normal, pas uppercase */
  text-decoration: none;
  transition: all 0.4s cubic-bezier(0.25, 1, 0.5, 1);
  box-shadow: 0 10px 30px rgba(232, 157, 70, 0.25);
  position: relative;
  overflow: hidden;
}

/* Micro-Glow CTA */
.btn-forest-primary::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(to bottom, rgba(255,255,255,0.2), transparent);
  mix-blend-mode: plus-lighter;
  opacity: 0;
  transition: opacity 0.3s ease;
  pointer-events: none;
}

.btn-forest-primary:hover {
  transform: translateY(-4px) scale(1.02);
  box-shadow: 0 15px 40px rgba(232, 157, 70, 0.4);
}

.btn-forest-primary:hover::before {
  opacity: 1;
}

.btn-forest-primary svg {
  width: 20px;
  height: 20px;
  stroke: currentColor;
  transition: transform 0.3s ease;
}

.btn-forest-primary:hover svg {
  transform: translateX(4px);
}

.forest-cta-trust {
  margin-top: 3rem;
  display: flex;
  align-items: center;
  gap: 8px;
  color: rgba(249, 249, 249, 0.5);
  font-size: 0.83rem;
  font-weight: 600;
  letter-spacing: 0.05em;
  text-transform: uppercase;
}

.forest-cta-trust svg {
  width: 16px;
  height: 16px;
  stroke: #E89D46;
}

@media screen and (max-width: 1024px) {
  .forest-cta-section {
    padding: 100px 3rem;
  }
}

@media screen and (max-width: 768px) {
  .forest-cta-section {
    padding: 80px 1.5rem;
  }
  .forest-cta-media {
    border-radius: 24px;
    aspect-ratio: 4/5; /* Plus vertical sur mobile */
  }
  .forest-cta-media::after {
    border-radius: 24px;
  }
  .btn-forest-primary {
    width: 100%;
    justify-content: center;
    padding: 16px 24px;
  }
}
</style>

<section class="forest-cta-section">
  <div class="forest-cta-aura"></div>
  
  <div class="forest-cta-container">
    {% if section.settings.badge_text != blank %}
      <div class="forest-cta-badge">{{ section.settings.badge_text }}</div>
    {% endif %}
    
    {% if section.settings.title != blank %}
      <h2 class="forest-cta-h2">{{ section.settings.title }}</h2>
    {% endif %}
    
    <div class="forest-cta-media-container">
      <div class="forest-cta-media">
        {% if section.settings.image != blank %}
          {{ section.settings.image | image_url: width: 1600 | image_tag: loading: 'lazy', alt: section.settings.title }}
        {% else %}
          <div style="width: 100%; height: 100%; background: #112642; display: flex; align-items: center; justify-content: center;">
            <span style="color: rgba(255,255,255,0.2);">Sélectionnez l'image produit (Gros plan Renard)</span>
          </div>
        {% endif %}
      </div>
    </div>
    
    {% if section.settings.description != blank %}
      <p class="forest-cta-text">{{ section.settings.description }}</p>
    {% endif %}
    
    {% if section.settings.button_text != blank %}
      <a href="{{ section.settings.button_link | default: '#' }}" class="btn-forest-primary">
        {{ section.settings.button_text }}
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    {% endif %}
    
    {% if section.settings.footer_text != blank %}
      <div class="forest-cta-trust">
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M22 11.08V12a10 10 0 11-5.93-9.14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M22 4L12 14.01l-3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        {{ section.settings.footer_text }}
      </div>
    {% endif %}
  </div>
</section>

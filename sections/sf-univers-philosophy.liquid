{% schema %}
{
  "name": "Univers - Philosophie",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Surtitre",
      "default": "NOTRE PHILOSOPHIE"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Titre Principal",
      "default": "La maîtrise de l'exceptionnel <i>plutôt que la quantité.</i>",
      "info": "Utilisez <em>mot</em> pour appliquer l'effet brillant, ou <i>mot</i> pour la couleur ambre sans surbrillance."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Texte Descriptif",
      "default": "Nous ne multiplions pas les modèles pour remplir un catalogue. Nous avons conçu des lampes immersives capables de s'adapter à différents univers visuels, puis nous les déclinons par licences, thèmes et personnages pour garantir un rendu fidèle et cohérent."
    },
    {
      "type": "header",
      "content": "Image de Droite"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image Principale"
    },
    {
      "type": "text",
      "id": "card_title",
      "label": "Titre encart Image",
      "default": "Expertise Lumineuse"
    },
    {
      "type": "text",
      "id": "card_subtitle",
      "label": "Sous-titre encart Image",
      "default": "Conception française artisanale"
    },
    {
      "type": "html",
      "id": "card_icon",
      "label": "Icone encart Image (SVG)",
      "default": "<svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"12\" cy=\"12\" r=\"4\"></circle><path d=\"M12 2v2\"></path><path d=\"M12 20v2\"></path><path d=\"M5 5l1.5 1.5\"></path><path d=\"M17.5 17.5L19 19\"></path><path d=\"M2 12h2\"></path><path d=\"M20 12h2\"></path><path d=\"M5 19l1.5-1.5\"></path><path d=\"M17.5 6.5L19 5\"></path></svg>"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Caractéristique",
      "limit": 3,
      "settings": [
        {
          "type": "html",
          "id": "icon",
          "label": "Icone (SVG)",
          "default": "<svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle></svg>"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titre",
          "default": "Modèles Limités"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Texte",
          "default": "Une architecture unique pensée pour l'immersion totale."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Univers - Philosophie",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "icon": "<svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"12\" cy=\"12\" r=\"2\"></circle><path d=\"M12 3v1\"></path><path d=\"M12 20v1\"></path><path d=\"M3 12h1\"></path><path d=\"M20 12h1\"></path><path d=\"M5.6 5.6l.7.7\"></path><path d=\"M18.4 18.4l-.7-.7\"></path><path d=\"M5.6 18.4l.7-.7\"></path><path d=\"M18.4 5.6l-.7.7\"></path></svg>",
            "title": "Modèles Limités",
            "text": "Une architecture unique pensée pour l'immersion totale."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "<svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"></path><polyline points=\"9 12 11 14 15 10\"></polyline></svg>",
            "title": "Choix Contrôlé",
            "text": "Une sélection rigoureuse pour sublimer votre intérieur."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "<svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 2l3 6 6 3-6 3-3 6-3-6-6-3 6-3z\"></path><path d=\"M19 19l2 1-2 1-1 2-1-2-2-1 2-1 1-2z\"></path></svg>",
            "title": "Qualité Maîtrisée",
            "text": "Un rendu chromatique fidèle à chaque univers."
          }
        }
      ]
    }
  ]
}
{% endschema %}

<style>
/* sf-univers-philosophy.css */
#shopify-section-{{ section.id }} .phil-section {
  background-color: var(--illu-night, #081A32);
  padding: 120px 5%;
  color: var(--illu-text-light, #F9F9F9);
  font-family: inherit;
  overflow: hidden;
}

#shopify-section-{{ section.id }} .phil-container {
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1.1fr 0.9fr;
  gap: 80px;
  align-items: center;
}

@media (max-width: 1024px) {
  #shopify-section-{{ section.id }} .phil-container {
    grid-template-columns: 1fr;
    gap: 60px;
  }
}

/* Left Content */
#shopify-section-{{ section.id }} .phil-content {
  display: flex;
  flex-direction: column;
}

#shopify-section-{{ section.id }} .phil-label-wrap {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 24px;
}

#shopify-section-{{ section.id }} .phil-line {
  width: 40px;
  height: 1px;
  background-color: var(--illu-accent-amber, #E89D46);
}

#shopify-section-{{ section.id }} .phil-label {
  color: var(--illu-accent-amber, #E89D46);
  font-size: 1.24rem;
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  opacity: 0.9;
}

#shopify-section-{{ section.id }} .phil-title {
  font-size: clamp(2.5rem, 4vw, 3.5rem);
  font-weight: 800;
  line-height: 1.1;
  color: var(--illu-text-light, #F9F9F9);
  margin-bottom: 32px;
  letter-spacing: -0.02em;
}



#shopify-section-{{ section.id }} .phil-title em {
  font-style: normal;
  color: var(--illu-accent-amber, #E89D46);
  text-shadow: 0 0 15px rgba(232, 157, 70, 0.45);
}

#shopify-section-{{ section.id }} .phil-title i {
  font-style: normal;
  color: var(--illu-accent-amber, #E89D46);
}

#shopify-section-{{ section.id }} .phil-text {
  font-size: 1.24rem;
  line-height: 1.7;
  color: rgba(249, 249, 249, 0.75);
  margin-bottom: 48px;
  max-width: 90%;
}

/* Feature Cards */
#shopify-section-{{ section.id }} .phil-features {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
  gap: 20px;
}

#shopify-section-{{ section.id }} .phil-feature-card {
  background: rgba(255, 255, 255, 0.02);
  border: 1px solid rgba(255, 255, 255, 0.05);
  border-radius: 24px;
  padding: 32px 24px;
  display: flex;
  flex-direction: column;
  transition: transform 0.3s ease, background 0.3s;
}

#shopify-section-{{ section.id }} .phil-feature-card:hover {
  transform: translateY(-5px);
  background: rgba(255, 255, 255, 0.04);
  border-color: rgba(232, 157, 70, 0.2);
}

#shopify-section-{{ section.id }} .feature-icon {
  width: 40px;
  height: 40px;
  background: rgba(232, 157, 70, 0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--illu-accent-amber, #E89D46);
  margin-bottom: 20px;
}

#shopify-section-{{ section.id }} .feature-icon svg {
  width: 20px;
  height: 20px;
}

#shopify-section-{{ section.id }} .feature-title {
  font-size: 1rem;
  font-weight: 700;
  color: var(--illu-text-light, #F9F9F9);
  margin-bottom: 12px;
}

#shopify-section-{{ section.id }} .feature-text {
  font-size: 0.94rem;
  color: rgba(249, 249, 249, 0.6);
  line-height: 1.5;
}

/* Right Content: Image & Glass Card */
#shopify-section-{{ section.id }} .phil-media {
  position: relative;
  border-radius: var(--illu-radius-chubby, 32px);
  border: 1px solid rgba(255, 255, 255, 0.05);
  overflow: hidden;
  background: rgba(255, 255, 255, 0.02);
  display: flex;
}

#shopify-section-{{ section.id }} .phil-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  aspect-ratio: 1 / 1.1;
  display: block;
}

#shopify-section-{{ section.id }} .phil-media::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(8, 26, 50, 0.9) 0%, transparent 40%);
  pointer-events: none;
}

#shopify-section-{{ section.id }} .phil-glass-card {
  position: absolute;
  bottom: 32px;
  left: 50%;
  transform: translateX(-50%);
  width: calc(100% - 64px);
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 20px;
  padding: 24px;
  display: flex;
  align-items: center;
  gap: 20px;
  z-index: 2;
  box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
}

@media (max-width: 600px) {
  #shopify-section-{{ section.id }} .phil-glass-card {
    width: calc(100% - 32px);
    bottom: 16px;
    padding: 16px;
    flex-direction: column;
    text-align: center;
  }
}

#shopify-section-{{ section.id }} .glass-icon {
  width: 48px;
  height: 48px;
  background: rgba(232, 157, 70, 0.15);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--illu-accent-amber, #E89D46);
  flex-shrink: 0;
}

#shopify-section-{{ section.id }} .glass-icon svg {
  width: 24px;
  height: 24px;
}

#shopify-section-{{ section.id }} .glass-text-wrap {
  flex: 1;
}

#shopify-section-{{ section.id }} .glass-title {
  color: var(--illu-text-light, #F9F9F9);
  font-size: 1.125rem;
  font-weight: 700;
  margin-bottom: 4px;
}

#shopify-section-{{ section.id }} .glass-subtitle {
  color: rgba(249, 249, 249, 0.6);
  font-size: 0.94rem;
}
</style>

<div class="sf-stitch phil-section">
  <div class="phil-container">
    <div class="phil-content">
      {%- if section.settings.label != blank -%}
        <div class="phil-label-wrap">
          <div class="phil-line"></div>
          <div class="phil-label">{{ section.settings.label | escape }}</div>
        </div>
      {%- endif -%}

      {%- if section.settings.title != blank -%}
        <h2 class="phil-title">{{ section.settings.title | replace: '<i>', '<i>' | replace: '</i>', '</i>' }}</h2>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <p class="phil-text">{{ section.settings.text | escape }}</p>
      {%- endif -%}

      <div class="phil-features">
        {%- for block in section.blocks -%}
          <div class="phil-feature-card" {{ block.shopify_attributes }}>
            <div class="feature-icon">
              {{ block.settings.icon }}
            </div>
            <div class="feature-title">{{ block.settings.title | escape }}</div>
            <div class="feature-text">{{ block.settings.text | escape }}</div>
          </div>
        {%- endfor -%}
      </div>
    </div>

    <div class="phil-media">
      {%- if section.settings.image != blank -%}
        <img src="{{ section.settings.image | image_url: width: 1000 }}" class="phil-img" alt="" loading="lazy">
      {%- else -%}
        <div class="phil-img" style="display: flex; align-items: center; justify-content: center; background: #0f1c2e;">
          <svg style="width: 60px; height: 60px; opacity: 0.1; color: white;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>
        </div>
      {%- endif -%}

      <div class="phil-glass-card">
        <div class="glass-icon">
          {{ section.settings.card_icon }}
        </div>
        <div class="glass-text-wrap">
          <div class="glass-title">{{ section.settings.card_title | escape }}</div>
          <div class="glass-subtitle">{{ section.settings.card_subtitle | escape }}</div>
        </div>
      </div>
    </div>
  </div>
</div>

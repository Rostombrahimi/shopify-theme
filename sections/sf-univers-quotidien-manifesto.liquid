{% schema %}
{
  "name": "Quotidien Manifesto",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "badge_text",
      "label": "Texte du badge",
      "default": "NOTRE APPROCHE"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Titre",
      "default": "Le choix de la justesse,\npas de l'abondance."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Texte",
      "default": "Dans l'univers Espace Quotidien, nous ne cherchons pas à proposer toutes les lampes possibles. Chaque modèle est sélectionné pour répondre à un usage précis, avec une attention particulière portée au confort visuel, à la durabilité et au design."
    }
  ],
  "blocks": [
    {
      "type": "pillar",
      "name": "Pilier",
      "limit": 4,
      "settings": [
        {
          "type": "html",
          "id": "icon",
          "label": "Icône SVG"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titre",
          "default": "Curation Maîtrisée"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Texte",
          "default": "Sélection rigoureuse de l'essentiel."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Quotidien Manifesto",
      "category": "Text",
      "blocks": [
        {
          "type": "pillar",
          "settings": {
            "title": "Présence Affirmée",
            "text": "Une luminosité qui sculpte l'espace et définit le ton de la pièce.",
            "icon": "<svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 2v2\"/><path d=\"M12 20v2\"/><path d=\"m4.93 4.93 1.41 1.41\"/><path d=\"m19.07 4.93-1.41 1.41\"/><path d=\"m4.93 19.07 1.41-1.41\"/><path d=\"m19.07 19.07-1.41-1.41\"/><path d=\"M2 12h2\"/><path d=\"M20 12h2\"/><path d=\"M9 16a5 5 0 1 1 6 0 3.5 3.5 0 0 0-1 3 2 2 0 0 1-4 0 3.5 3.5 0 0 0-1-3\"/><path d=\"M9 18h6\"/></svg>"
          }
        },
        {
          "type": "pillar",
          "settings": {
            "title": "Confort Absolu",
            "text": "Douceur pour le regard, sans éblouissement ni fatigue.",
            "icon": "<svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M9.88 9.88a3 3 0 1 0 4.24 4.24\"/><path d=\"M10.73 5.08A10.43 10.43 0 0 1 12 5c7 0 10 7 10 7a13.16 13.16 0 0 1-1.67 2.68\"/><path d=\"M6.61 6.61A13.526 13.526 0 0 0 2 12s3 7 10 7a9.74 9.74 0 0 0 5.39-1.61\"/><line x1=\"2\" y1=\"2\" x2=\"22\" y2=\"22\"/></svg>"
          }
        },
        {
          "type": "pillar",
          "settings": {
            "title": "Signature Visuelle",
            "text": "L'esthétique de la lumière devient aussi importante que l'objet.",
            "icon": "<svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"12\" cy=\"12\" r=\"2\"/><path d=\"M12 2v2\"/><path d=\"M12 20v2\"/><path d=\"m4.93 4.93 1.41 1.41\"/><path d=\"m19.07 4.93-1.41 1.41\"/><path d=\"m4.93 19.07 1.41-1.41\"/><path d=\"m19.07 19.07-1.41-1.41\"/><path d=\"M2 12h2\"/><path d=\"M20 12h2\"/><circle cx=\"12\" cy=\"6\" r=\"1\" fill=\"currentColor\" /><circle cx=\"12\" cy=\"18\" r=\"1\" fill=\"currentColor\" /><circle cx=\"6\" cy=\"12\" r=\"1\" fill=\"currentColor\" /><circle cx=\"18\" cy=\"12\" r=\"1\" fill=\"currentColor\" /><circle cx=\"8\" cy=\"8\" r=\"1\" fill=\"currentColor\" /><circle cx=\"16\" cy=\"8\" r=\"1\" fill=\"currentColor\" /><circle cx=\"8\" cy=\"16\" r=\"1\" fill=\"currentColor\" /><circle cx=\"16\" cy=\"16\" r=\"1\" fill=\"currentColor\" /></svg>"
          }
        }

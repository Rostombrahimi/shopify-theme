{% schema %}
{
  "name": "Bénéfices Quotidien",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titre principal",
      "default": "Ce que cette lumière permet"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Sous-titre",
      "default": "Une expertise technologique au service de votre confort visuel quotidien, conçue pour durer et s'adapter."
    }
  ],
  "blocks": [
    {
      "type": "benefit_card",
      "name": "Carte Bénéfice",
      "limit": 3,
      "settings": [
        {
          "type": "html",
          "id": "icon",
          "label": "Icône SVG"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titre du bénéfice",
          "default": "Titre du bénéfice"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Description du bénéfice apporté."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bénéfices Quotidien",
      "blocks": [
        {
          "type": "benefit_card",
          "settings": {
            "icon": "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z\"/><path d=\"M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z\"/></svg>",
            "title": "Lecture confortable",
            "text": "Une lumière stable pour lire longtemps sans fatigue oculaire, avec un rendu des couleurs naturel."
          }
        },
        {
          "type": "benefit_card",
          "settings": {
            "icon": "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M18 6c0 2-2 2-2 4v10a2 2 0 0 1-2 2h-4a2 2 0 0 1-2-2V10c0-2-2-2-2-4V2h12v4Z\"/><line x1=\"6\" x2=\"18\" y1=\"6\" y2=\"6\"/><line x1=\"12\" x2=\"12\" y1=\"12\" y2=\"12\"/></svg>",
            "title": "Éclairage ciblé",
            "text": "Un flux maîtrisé pour voir clair sans éblouir, idéal pour vos tâches de précision au bureau ou à la maison."
          }
        },
        {
          "type": "benefit_card",
          "settings": {
            "icon": "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"12\" cy=\"5\" r=\"1\"/><circle cx=\"19\" cy=\"5\" r=\"1\"/><circle cx=\"5\" cy=\"5\" r=\"1\"/><circle cx=\"12\" cy=\"12\" r=\"1\"/><circle cx=\"19\" cy=\"12\" r=\"1\"/><circle cx=\"5\" cy=\"12\" r=\"1\"/><circle cx=\"12\" cy=\"19\" r=\"1\"/><circle cx=\"19\" cy=\"19\" r=\"1\"/><circle cx=\"5\" cy=\"19\" r=\"1\"/></svg>",
            "title": "Ambiance maîtrisée",
            "text": "Une atmosphère calme qui s'intègre naturellement dans votre espace de vie pour un bien-être total."
          }
        }
      ]
    }
  ]
}
{% endschema %}

<style>
/* Section Bénéfices Quotidien - sf-quotidien-benefits.css */

#shopify-section-{{ section.id }} .quotidien-benefits-section {
  background-color: #081A32; /* illu-night */
  padding: 100px 0;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

/* En-tête */
#shopify-section-{{ section.id }} .quotidien-benefits-header {
  text-align: left;
  max-width: 1300px;
  margin: 0 auto 4rem auto;
  padding: 0 4rem;
}

#shopify-section-{{ section.id }} .quotidien-title {
  font-size: clamp(2.2rem, 4vw, 3.2rem);
  color: #F9F9F9;
  font-weight: 800;
  margin: 0 0 1rem 0;
  letter-spacing: -0.02em;
  line-height: 1.1;
  max-width: 800px;
}

#shopify-section-{{ section.id }} .quotidien-subtitle {
  font-size: clamp(1rem, 2vw, 1.2rem);
  color: #9CA3AF; /* Gris clair */
  font-weight: 400;
  margin: 0;
  max-width: 800px;
  line-height: 1.6;
}

/* Grille */
#shopify-section-{{ section.id }} .quotidien-benefits-grid-wrapper {
  width: 100%;
}

#shopify-section-{{ section.id }} .quotidien-benefits-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 32px;
  max-width: 1300px;
  margin: 0 auto;
  padding: 0 4rem;
}

/* Carte */
#shopify-section-{{ section.id }} .quotidien-benefit-card {
  background: rgba(255, 255, 255, 0.02);
  border: 1px solid rgba(255, 255, 255, 0.05);
  border-radius: 32px; /* radius chubby (32px) */
  padding: 48px 32px;
  text-align: left;
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  display: flex;
  flex-direction: column;
}

#shopify-section-{{ section.id }} .quotidien-benefit-card:hover {
  transform: translateY(-8px);
  border-color: rgba(232, 157, 70, 0.3);
  background: rgba(255, 255, 255, 0.04);
}

/* Icônes */
#shopify-section-{{ section.id }} .quotidien-icon-wrapper {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 56px;
  height: 56px;
  background: rgba(255, 255, 255, 0.03); /* Rounded square inside the card */
  border: 1px solid rgba(255, 255, 255, 0.05);
  border-radius: 16px; /* border radius carre arrondi */
  color: #E89D46;
  margin-bottom: 2rem;
  transition: all 0.4s ease;
  filter: drop-shadow(0 0 10px rgba(232, 157, 70, 0.15));
}

#shopify-section-{{ section.id }} .quotidien-icon-wrapper svg {
  width: 28px !important;
  height: 28px !important;
  min-width: 28px;
  min-height: 28px;
  display: block;
  flex-shrink: 0;
}

#shopify-section-{{ section.id }} .quotidien-benefit-card:hover .quotidien-icon-wrapper {
  background: #E89D46;
  color: #fff;
  filter: drop-shadow(0 0 15px rgba(232, 157, 70, 0.4));
  transform: scale(1.05);
}

/* Textes des cartes */
#shopify-section-{{ section.id }} .quotidien-benefit-title {
  color: #F9F9F9;
  font-size: 1.25rem;
  font-weight: 700;
  margin: 0 0 1rem 0;
  line-height: 1.3;
}

#shopify-section-{{ section.id }} .quotidien-benefit-desc {
  color: #9CA3AF; /* Gris clair */
  font-size: 0.95rem;
  line-height: 1.6;
  margin: 0;
}


/* MOBILE RESPONSIVE - SNAP CAROUSEL */
@media screen and (max-width: 1024px) {
  #shopify-section-{{ section.id }} .quotidien-benefits-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media screen and (max-width: 768px) {
  #shopify-section-{{ section.id }} .quotidien-benefits-section {
    padding: 80px 0;
  }
  
  #shopify-section-{{ section.id }} .quotidien-benefits-header {
    padding: 0 1.5rem;
    margin-bottom: 3rem;
  }
  
  #shopify-section-{{ section.id }} .quotidien-title {
    font-size: 2.2rem;
  }

  /* Slider Snap Logic */
  #shopify-section-{{ section.id }} .quotidien-benefits-grid-wrapper {
    width: 100vw;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding-bottom: 2rem;
  }

  #shopify-section-{{ section.id }} .quotidien-benefits-grid-wrapper::-webkit-scrollbar {
    display: none;
  }

  #shopify-section-{{ section.id }} .quotidien-benefits-grid {
    display: flex;
    flex-direction: row;
    width: max-content;
    padding: 0 1.5rem;
    margin: 0;
    gap: 1.25rem;
  }
  
  #shopify-section-{{ section.id }} .quotidien-benefit-card {
    scroll-snap-align: center;
    width: 85vw;
    max-width: 320px;
    padding: 32px 24px;
    flex-shrink: 0;
    /* Prevent hover translation jumping issues on mobile touch */
    transition: transform 0.3s ease, background 0.3s ease, border-color 0.3s ease;
  }

  #shopify-section-{{ section.id }} .quotidien-benefit-card:active {
    transform: translateY(-4px);
  }
}
</style>

<section class="quotidien-benefits-section sf-stitch">
  
  <div class="quotidien-benefits-header">
    {% if section.settings.title != blank %}
      <h2 class="quotidien-title">{{ section.settings.title }}</h2>
    {% endif %}
    {% if section.settings.subtitle != blank %}
      <p class="quotidien-subtitle">{{ section.settings.subtitle }}</p>
    {% endif %}
  </div>

  {% if section.blocks.size > 0 %}
    <div class="quotidien-benefits-grid-wrapper">
      <div class="quotidien-benefits-grid">
        {% for block in section.blocks %}
          <div class="quotidien-benefit-card" {{ block.shopify_attributes }}>
            <div class="quotidien-icon-wrapper">
              {% if block.settings.icon != blank %}
                {{ block.settings.icon }}
              {% endif %}
            </div>
            <h3 class="quotidien-benefit-title">{{ block.settings.title | newline_to_br }}</h3>
            <p class="quotidien-benefit-desc">{{ block.settings.text }}</p>
          </div>
        {% endfor %}
      </div>
    </div>
  {% endif %}

</section>

    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Lien Bouton"
    },
    {
      "type": "header",
      "content": "Bloc Réassurance"
    },
    {
      "type": "text",
      "id": "reassure_title",
      "label": "Titre Réassurance",
      "default": "L'engagement Qualité & Sécurité"
    },
    {
      "type": "textarea",
      "id": "reassure_text",
      "label": "Texte Réassurance",
      "default": "Parce que la lumière habille votre quotidien, nous concevons nos produits pour qu'ils soient aussi sûrs qu'élégants. Une tranquillité d'esprit pour toute la famille."

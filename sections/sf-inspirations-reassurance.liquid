  ],
  "blocks": [
    {
      "type": "inspiration_image",
      "name": "Image d'inspiration",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    },
    {
      "type": "reassurance_item",
      "name": "Item Réassurance",
      "limit": 4,
      "settings": [
        {
          "type": "html",
          "id": "icon",
          "label": "Icone (SVG)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titre"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Texte"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Inspirations & Rassur.",
      "blocks": [
        {
          "type": "inspiration_image"
        },
        {
          "type": "inspiration_image"
        },
        {
          "type": "inspiration_image"
        },
        {
          "type": "inspiration_image"
        },
        {
          "type": "inspiration_image"
        },
        {
          "type": "inspiration_image"
        },
        {
          "type": "reassurance_item",
          "settings": {
            "icon": "<svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"></path><polyline points=\"9 12 11 14 15 10\"></polyline></svg>",
            "title": "Matériaux testés",
            "text": "Des composants nobles, durables et résistants à l'usure pour une longévité maximale dans votre intérieur."
          }
        },
        {
          "type": "reassurance_item",
          "settings": {
            "icon": "<svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z\"></path><circle cx=\"12\" cy=\"12\" r=\"3\"></circle></svg>",
            "title": "Lumière non agressive",
            "text": "Une luminosité calibrée et diffuse, conçue pour ne pas fatiguer les yeux, même lors de longues sessions."
          }
        },
        {
          "type": "reassurance_item",
          "settings": {
            "icon": "<svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"M8 12h8\"></path><path d=\"M9 9h6\"></path><path d=\"M9 15h6\"></path></svg>",
            "title": "Conformité Européenne",
            "text": "Respect strict et rigoureux de toutes les normes CE en vigueur pour garantir votre sécurité électrique."
          }
        },
        {
          "type": "reassurance_item",
          "settings": {
            "icon": "<svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><rect x=\"3\" y=\"11\" width=\"18\" height=\"11\" rx=\"2\" ry=\"2\"></rect><path d=\"M7 11V7a5 5 0 0 1 10 0v4\"></path></svg>",
            "title": "Usage sécurisé",
            "text": "Technologies LED basse température restant froides au toucher. Sécuritaire pour les enfants et les animaux."
          }
        }
      ]
    }
  ]

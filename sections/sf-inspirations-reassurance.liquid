{% endschema %}

<style>
/* Inspirations & Réassurance - sf-inspirations-reassurance.css */
#shopify-section-{{ section.id }} .ins-section {
  background-color: var(--illu-night, #081A32);
  padding: 100px 5%;
  -webkit-font-smoothing: antialiased;
  font-family: inherit;
  color: var(--illu-cream, #F9F9F9);
}

#shopify-section-{{ section.id }} .ins-title-group {
  margin-bottom: 40px;
  max-width: 800px;
  margin-left: auto;
  margin-right: auto;
  text-align: center;
}

#shopify-section-{{ section.id }} .ins-h2 {
  font-size: clamp(2.2rem, 4.4vw, 2.75rem);
  color: var(--illu-cream, #F9F9F9);
  font-weight: 800;
  margin-bottom: 1rem;
  line-height: 1.2;
}

#shopify-section-{{ section.id }} .ins-h2 em {
  font-style: normal;
  color: var(--illu-accent-amber, #E89D46);
  text-shadow: 0 0 15px rgba(232, 157, 70, 0.45);
}

#shopify-section-{{ section.id }} .ins-h2 i {
  font-style: normal;
  color: var(--illu-accent-amber, #E89D46);
}



#shopify-section-{{ section.id }} .ins-subtitle {
  font-size: 1.1rem;
  color: rgba(249, 249, 249, 0.7);
  line-height: 1.6;
  max-width: 600px;
  margin-left: auto;
  margin-right: auto;
}

/* Grille Masonry Inspirations */
#shopify-section-{{ section.id }} .ins-grid {
  columns: 3;
  column-gap: 24px;
  max-width: 1200px;
  margin: 0 auto 60px auto;
}

#shopify-section-{{ section.id }} .ins-item {
  break-inside: avoid;
  margin-bottom: 24px;
  border-radius: var(--illu-radius-chubby, 32px);
  overflow: hidden;
  border: 1px solid rgba(255, 255, 255, 0.05);
  transition: transform 0.4s ease, border-color 0.4s;
  background: rgba(255, 255, 255, 0.02);
}

#shopify-section-{{ section.id }} .ins-item:hover {
  transform: scale(1.02);
  border-color: rgba(232, 157, 70, 0.2);
}

#shopify-section-{{ section.id }} .ins-img {
  width: 100%;
  height: auto;
  display: block;
  object-fit: cover;
  filter: brightness(0.9) contrast(1.1);
  transition: filter 0.4s;
}

#shopify-section-{{ section.id }} .ins-item:hover .ins-img {
  filter: brightness(1) contrast(1.05);
}

#shopify-section-{{ section.id }} .ins-btn-wrap {
  text-align: center;
  margin-bottom: 100px;
}

#shopify-section-{{ section.id }} .ins-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
  color: var(--illu-amber, #E89D46);
  font-size: 1.21rem;
  font-weight: 700;
  text-decoration: none;
  transition: all 0.3s ease;
  padding: 14px 32px;
  border: 1px solid rgba(232, 157, 70, 0.4);
  border-radius: 99px;
  background: transparent;
}

#shopify-section-{{ section.id }} .ins-btn:hover {
  background: rgba(232, 157, 70, 0.08);
  border-color: var(--illu-amber, #E89D46);
}

#shopify-section-{{ section.id }} .ins-btn svg {
  width: 20px;
  height: 20px;
  transition: transform 0.3s;
}

#shopify-section-{{ section.id }} .ins-btn:hover svg {
  transform: translateX(4px);
}

/* Réassurance Soft (Parental) */
#shopify-section-{{ section.id }} .reassurance-container {
  background: var(--illu-night-light, #0f1c2e); /* Slightly lighter than the background */
  border-radius: var(--illu-radius-chubby, 32px);
  padding: 60px 5%;
  max-width: 1200px;
  margin: 0 auto;
}

#shopify-section-{{ section.id }} .reassure-header {
  margin-bottom: 40px;
  max-width: 600px;
}

#shopify-section-{{ section.id }} .reassure-h3 {
  font-size: clamp(1.65rem, 3.3vw, 2.2rem);
  font-weight: 800;
  margin-bottom: 12px;
  color: var(--illu-cream, #F9F9F9);
}

#shopify-section-{{ section.id }} .reassure-desc {
  color: rgba(249, 249, 249, 0.7);
  font-size: 1.05rem;
  line-height: 1.6;
}

#shopify-section-{{ section.id }} .reassurance-bar {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24px;
}

#shopify-section-{{ section.id }} .re-item {
  display: flex;
  flex-direction: column;
  background: rgba(255, 255, 255, 0.02);
  padding: 32px 24px;
  border-radius: 24px;
  border: 1px solid rgba(255, 255, 255, 0.05);
  transition: transform 0.3s, background 0.3s;
}

#shopify-section-{{ section.id }} .re-item:hover {
  transform: translateY(-5px);
  background: rgba(255, 255, 255, 0.04);
}

#shopify-section-{{ section.id }} .re-icon {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background: rgba(232, 157, 70, 0.1);
  color: var(--illu-amber, #E89D46);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20px;
  filter: drop-shadow(0 0 10px rgba(232, 157, 70, 0.15));
}

#shopify-section-{{ section.id }} .re-icon svg {
  width: 24px;
  height: 24px;
}

#shopify-section-{{ section.id }} .re-label {
  color: var(--illu-cream, #F9F9F9);
  font-size: 1.1rem;
  font-weight: 700;
  line-height: 1.4;
  margin-bottom: 8px;
}

#shopify-section-{{ section.id }} .re-text {
  color: rgba(249, 249, 249, 0.6);
  font-size: 0.94rem;
  line-height: 1.5;
}

/* Responsiveness */
@media (max-width: 990px) {
  #shopify-section-{{ section.id }} .ins-grid {
    columns: 2;
  }
  #shopify-section-{{ section.id }} .reassurance-bar {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 600px) {
  #shopify-section-{{ section.id }} .ins-section {
    padding: 60px 20px;
  }
  #shopify-section-{{ section.id }} .ins-grid {
    columns: 1;
  }
  #shopify-section-{{ section.id }} .reassurance-container {
    padding: 40px 20px;
  }
  #shopify-section-{{ section.id }} .reassurance-bar {
    grid-template-columns: 1fr;
  }
}
</style>

<div class="sf-stitch ins-section">
  <div class="ins-title-group">
    <h2 class="ins-h2">{{ section.settings.title | replace: '<em>', '<em>' | replace: '</em>', '</em>' | replace: '<i>', '<i>' | replace: '</i>', '</i>' }}</h2>
    {%- if section.settings.subtitle != blank -%}
      <p class="ins-subtitle">{{ section.settings.subtitle | escape }}</p>
    {%- endif -%}
  </div>

  {%- assign has_images = false -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'inspiration_image' -%}
      {%- assign has_images = true -%}
    {%- endif -%}
  {%- endfor -%}

  {%- if has_images -%}
    <div class="ins-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'inspiration_image' -%}
          <div class="ins-item" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              <img src="{{ block.settings.image | image_url: width: 600 }}" class="ins-img" alt="Inspiration" loading="lazy">
            {%- else -%}
              <div style="width: 100%; aspect-ratio: 1/1; display:flex; align-items:center; justify-content:center; background:#122137; opacity:0.8;">
                <svg style="width: 40px; height: 40px; opacity: 0.3; color: white;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  {%- endif -%}

  {%- if section.settings.btn_text != blank -%}
    <div class="ins-btn-wrap">
      <a href="{{ section.settings.btn_link | default: '#' }}" class="ins-btn">
        {{ section.settings.btn_text | escape }}
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
      </a>
    </div>
  {%- endif -%}

  <div class="reassurance-container">
    <div class="reassure-header">
      {%- if section.settings.reassure_title != blank -%}
        <h3 class="reassure-h3">{{ section.settings.reassure_title | escape }}</h3>
      {%- endif -%}
      {%- if section.settings.reassure_text != blank -%}
        <p class="reassure-desc">{{ section.settings.reassure_text | escape }}</p>
      {%- endif -%}
    </div>

    <div class="reassurance-bar">
      {%- for block in section.blocks -%}
        {%- if block.type == 'reassurance_item' -%}
          <div class="re-item" {{ block.shopify_attributes }}>
            <div class="re-icon">
              {{ block.settings.icon }}
            </div>
            <div class="re-label">{{ block.settings.title | escape }}</div>
            <div class="re-text">{{ block.settings.text | escape }}</div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>

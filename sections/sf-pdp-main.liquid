{{ 'sf-pdp-main.css' | asset_url | stylesheet_tag }}
{{ 'sf-light-path.css' | asset_url | stylesheet_tag }}
{%- assign current_variant = product.selected_or_first_available_variant -%}

{%- style -%}
  /* Sticky ATC */
  .sf-sticky-atc {
    position: fixed;
    bottom: 0;
    left: 0;
    width: 100%;
    background: rgba(8, 26, 50, 0.95);
    backdrop-filter: blur(15px);
    -webkit-backdrop-filter: blur(15px);
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding: 12px 20px;
    z-index: 999;
    transform: translateY(100%);
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    display: none; /* Hidden on desktop by default */
    box-shadow: 0 -10px 30px rgba(0, 0, 0, 0.4);
  }

  @media screen and (max-width: 768px) {
    .sf-sticky-atc {
      display: block;
    }
  }

  .sf-sticky-atc.is-visible {
    transform: translateY(0);
  }

  .sf-sticky-atc-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1200px;
    margin: 0 auto;
  }

  .sf-sticky-atc-info {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .sf-sticky-atc-info img {
    width: 48px;
    height: 48px;
    border-radius: 8px;
    object-fit: cover;
  }

  .sf-sticky-atc-text {
    display: flex;
    flex-direction: column;
  }

  .sf-sticky-atc-title {
    font-size: 0.9rem;
    font-weight: 700;
    color: #F9F9F9;
    line-height: 1.2;
  }

  .sf-sticky-atc-price {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--illu-accent-amber, #E89D46);
    margin-top: 2px;
  }

  .sf-sticky-btn {
    padding: 10px 20px !important;
    font-size: 1rem !important;
    margin: 0 !important;
    width: auto !important;
  }
{%- endstyle -%}
<section id="MainProduct-{{ section.id }}" class="sf-pdp-section" data-section="{{ section.id }}">
  <div class="sf-pdp-wrapper">
    
    <!-- Breadcrumbs -->
    <nav class="sf-pdp-breadcrumb" aria-label="breadcrumbs">
      <a href="{{ routes.root_url }}">Accueil</a>
      <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
      {% if collection %}
        <a href="{{ collection.url }}">{{ collection.title }}</a>
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
      {% endif %}
      <span aria-current="page">{{ product.title }}</span>
    </nav>

    <div class="sf-pdp-grid">
      <!-- Zone Gauche (Galerie) -->
      <div class="sf-pdp-gallery-wrap">
        <div class="sf-pdp-main-image-container">
          {% if product.featured_media != null %}
            <img 
              src="{{ product.featured_media | image_url: width: 1000 }}"
              alt="{{ product.featured_media.alt | escape }}"
              class="product-gallery sf-pdp-main-image"
              loading="eager"
            >
          {% else %}
            {{ 'product-1' | placeholder_svg_tag: 'product-gallery sf-pdp-main-image' }}
          {% endif %}
        </div>
        
        <!-- Miniatures -->
        {% if product.media.size > 1 %}
          <div class="sf-pdp-thumbnails">
            {% for media in product.media %}
              <div class="sf-pdp-thumb {% if forloop.first %}is-active{% endif %}" data-media-id="{{ media.id }}" data-image-url="{{ media | image_url: width: 1000 }}">
                <img src="{{ media | image_url: width: 150 }}" alt="{{ media.alt | escape }}" loading="lazy">
              </div>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <!-- Zone Droite (Achat & Info Sticky) -->
      <div class="sf-pdp-sidebar-wrap">
        <div class="pdp-sticky-container">
          
          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when '@app' -%}
                {% render block %}
                
              {%- when 'badge' -%}
                <div class="sf-pdp-badge" {{ block.shopify_attributes }}>
                  {%- if block.settings.icon_svg != blank -%}
                    {{ block.settings.icon_svg }}
                  {%- else -%}
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                  {%- endif -%}
                  {{ block.settings.text }}
                </div>
                
              {%- when 'title' -%}
                <h1 class="sf-pdp-title" {{ block.shopify_attributes }}>{{ product.title | escape }}</h1>

              {%- when 'reviews' -%}
                <a href="#sf-reviews-section" class="sf-pdp-reviews" {{ block.shopify_attributes }}>
                  <div class="sf-pdp-stars sf-rating-{{ block.settings.rating }}">
                    {%- for i in (1..5) -%}
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="{% if block.settings.rating > 0 and i <= block.settings.rating %}currentColor{% else %}none{% endif %}" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
                    {%- endfor -%}
                  </div>
                  {%- if block.settings.text != blank -%}
                    <span class="sf-pdp-reviews-text">{{ block.settings.text }}</span>
                  {%- endif -%}
                </a>
                
              {%- when 'subtitle' -%}
                {%- assign subtitle_text = product.metafields.custom.subtitle | default: block.settings.text -%}
                {%- if subtitle_text != blank -%}
                  <p class="sf-pdp-subtitle" {{ block.shopify_attributes }}>{{ subtitle_text | escape }}</p>
                {%- endif -%}
                
              {%- when 'price' -%}
                <div class="sf-pdp-price-wrap" {{ block.shopify_attributes }}>
                  <span class="sf-pdp-price-current">{{ current_variant.price | money }}</span>
                  {% if current_variant.compare_at_price > current_variant.price %}
                    <span class="sf-pdp-price-compare">{{ current_variant.compare_at_price | money }}</span>
                  {% endif %}
                </div>
                
              {%- when 'variant_picker' -%}
                {%- unless product.has_only_default_variant -%}
                  <div class="sf-pdp-variants" {{ block.shopify_attributes }}>
                    <sf-variant-radios class="no-js-hidden" data-section="{{ section.id }}" data-url="{{ product.url }}">
                      {%- for option in product.options_with_values -%}
                        <div class="sf-variant-drawer-wrapper js-drawer-wrapper" data-option="{{ option.name }}" style="z-index: {{ 100 | minus: forloop.index }};">
                          <!-- Trigger Button -->
                          <button type="button" class="sf-variant-trigger js-drawer-trigger" aria-expanded="false">
                            <div class="sf-variant-trigger-info">
                              <span class="sf-variant-trigger-label">Choisissez : {{ option.name }}</span>
                              <span class="sf-variant-trigger-value js-selected-value">{{ option.selected_value }}</span>
                            </div>
                            <svg class="sf-variant-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
                          </button>
                          
                          <!-- Drawer overlay & container -->
                          <div class="sf-variant-overlay js-drawer-overlay"></div>
                          <div class="sf-variant-drawer-container js-drawer-container">
                            <div class="sf-variant-drawer-header">
                              <h3>{{ option.name }}</h3>
                              <button type="button" class="sf-variant-close js-drawer-close">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                              </button>
                            </div>
                            <div class="sf-variant-drawer-body sf-variant-options">
                              {%- for value in option.values -%}
                                <div class="sf-variant-row">
                                  <input type="radio" id="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}"
                                        name="{{ option.name }}"
                                        value="{{ value | escape }}"
                                        form="product-form-{{ section.id }}"
                                        {% if option.selected_value == value %}checked{% endif %}
                                  >
                                  <label for="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}">
                                    {{ value }}
                                  </label>
                                </div>
                              {%- endfor -%}
                            </div>
                          </div>
                        </div>
                      {%- endfor -%}
                      <script type="application/json">
                        {{ product.variants | json }}
                      </script>
                    </sf-variant-radios>
                  </div>
                {%- endunless -%}
                
              {%- when 'buy_buttons' -%}
                <div style="margin-bottom: 40px;" {{ block.shopify_attributes }}>
                  <form method="post" action="/cart/add" id="product-form-{{ section.id }}" class="sf-pdp-form">
                    <input type="hidden" name="id" value="{{ current_variant.id }}">
                    
                    <div class="sf-pdp-quantity-selector">
                      <button type="button" class="sf-pdp-quantity-btn" onclick="this.parentNode.querySelector('input[type=number]').stepDown()">−</button>
                      <input class="sf-pdp-quantity-input" min="1" type="number" name="quantity" value="1">
                      <button type="button" class="sf-pdp-quantity-btn" onclick="this.parentNode.querySelector('input[type=number]').stepUp()">+</button>
                    </div>

                    <div class="sf-pdp-add-to-cart-wrapper">
                      <button type="submit" name="add" class="btn-add-to-cart" {% unless current_variant.available %}disabled{% endunless %}>
                        {% if current_variant.available %}
                          {{ block.settings.btn_text }}
                          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
                        {% else %}
                          Rupture de stock
                        {% endif %}
                      </button>
                    </div>
                  </form>
                </div>
                
              {%- when 'reassurance' -%}
                <div class="sf-pdp-feature-item" style="margin-bottom: 16px;" {{ block.shopify_attributes }}>
                  {%- if block.settings.icon_svg != blank -%}
                    <span style="color: #E89D46; display: flex;">{{ block.settings.icon_svg }}</span>
                  {%- else -%}
                    <svg class="sf-pdp-feature-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
                  {%- endif -%}
                  {{ block.settings.text }}
                </div>
                
              {%- when 'illuminations_path' -%}
                <light-path 
                    class="light-path-wrapper" 
                    style="margin-bottom: 24px; display: block; --illu-accent-amber: {{ block.settings.accent_color | default: '#E89D46' }}; --path-duration: {{ block.settings.carousel_speed | default: 4 }}s;" 
                    data-days="{{ block.settings.delivery_days | default: 4 }}"
                    data-speed="{{ block.settings.carousel_speed | default: 4 }}"
                    {{ block.shopify_attributes }}>
                    <div class="light-path-header">
                        <div class="light-path-title-row">
                          <h3 class="light-path-subtitle">Le Trajet de la Lumière</h3>
                          <span class="path-badge">
                              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                              Expert Verified
                          </span>
                        </div>
                        
                        <div class="phrase-rotator">
                            <p class="phrase-item is-active" data-phase="0">{{ block.settings.phrase_1 | default: 'Votre atmosphère est prête à être infusée.' }}</p>
                            <p class="phrase-item" data-phase="1">{{ block.settings.phrase_2 | default: 'Temps de propagation des photons : 3 à 5 jours.' }}</p>
                            <p class="phrase-item" data-phase="2">{{ block.settings.phrase_3 | default: "Votre univers s'illumine le" }} <span class="dynamic-delivery-date"></span>.</p>
                        </div>
                    </div>

                    <div class="path-line-container">
                        <div class="path-icon">
                            <span class="path-point"></span>
                        </div>

                        <div class="path-line">
                            <div class="photon-pulse"></div>
                        </div>

                        <div class="path-icon icon-home">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
                        </div>
                    </div>

                    <div class="light-path-labels">
                        <div class="label-start">{{ block.settings.label_start | default: "L'Atelier Illuminées" }}</div>
                        <div class="label-end">{{ block.settings.label_end | default: "Votre Univers" }}</div>
                    </div>
                </light-path>

                <script>
                if (!customElements.get('light-path')) {
                  customElements.define('light-path', class LightPath extends HTMLElement {
                    connectedCallback() {
                      if (this.dataset.initialized) return;
                      this.dataset.initialized = 'true';
                      
                      const days = parseInt(this.dataset.days) || 4;
                      const speedSeconds = parseInt(this.dataset.speed) || 4;

                      const dateSpan = this.querySelector('.dynamic-delivery-date');
                      if (dateSpan) {
                          const arrivalDate = new Date();
                          arrivalDate.setDate(arrivalDate.getDate() + days);
                          const options = { day: 'numeric', month: 'long' };
                          dateSpan.textContent = arrivalDate.toLocaleDateString('fr-FR', options);
                      }

                      const rotator = this.querySelector('.phrase-rotator');
                      if (rotator) {
                        const phrases = rotator.querySelectorAll('.phrase-item');
                        if (phrases.length > 0) {
                            let currentPhase = 0;
                            const phaseDuration = (speedSeconds * 1000) / Math.max(1, phrases.length);

                            this.interval = setInterval(() => {
                                phrases[currentPhase].classList.remove('is-active');
                                phrases[currentPhase].classList.add('is-leaving');
                                
                                currentPhase = (currentPhase + 1) % phrases.length;
                                
                                phrases[currentPhase].classList.remove('is-leaving');
                                phrases[currentPhase].classList.add('is-active');
                            }, phaseDuration);
                        }
                      }
                    }
                    
                    disconnectedCallback() {
                      if (this.interval) clearInterval(this.interval);
                    }
                  });
                }
                </script>

              {%- when 'description' -%}
                {% if product.description != blank %}
                <div class="glass-accordion" style="margin-bottom: 16px;" {{ block.shopify_attributes }}>
                  <div class="glass-accordion-header">
                    <div class="glass-accordion-title-wrap">
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                      {{ block.settings.heading }}
                    </div>
                  </div>
                  <div class="glass-accordion-content">
                    {{ product.description }}
                  </div>
                </div>
                {% endif %}
                
              {%- when 'accordion' -%}
                <details class="glass-accordion" style="margin-bottom: 16px;" {{ block.shopify_attributes }}>
                  <summary>
                    <div class="glass-accordion-title-wrap">
                      {%- if block.settings.icon_svg != blank -%}
                        <span style="color: #E89D46; display: flex;">{{ block.settings.icon_svg }}</span>
                      {%- else -%}
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
                      {%- endif -%}
                      {{ block.settings.heading }}
                    </div>
                    <svg class="glass-accordion-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
                  </summary>
                  <div class="glass-accordion-content">
                    {{ block.settings.content }}
                    {{ block.settings.page.content }}
                  </div>
                </details>
                
            {%- endcase -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Sticky Add-to-Cart (Mobile) -->
<div class="sf-sticky-atc" id="sf-sticky-atc">
  <div class="sf-sticky-atc-inner">
    <div class="sf-sticky-atc-info">
      {% if product.featured_media != null %}
        <img src="{{ product.featured_media | image_url: width: 100 }}" alt="{{ product.title | escape }}" loading="lazy">
      {% endif %}
      <div class="sf-sticky-atc-text">
        <span class="sf-sticky-atc-title">{{ product.title | truncate: 25 }}</span>
        <span class="sf-sticky-atc-price">{{ current_variant.price | money }}</span>
      </div>
    </div>
    <button type="button" class="btn-add-to-cart sf-sticky-btn" onclick="document.querySelector('.sf-pdp-add-to-cart-wrapper .btn-add-to-cart').click();" {% unless current_variant.available %}disabled{% endunless %}>
      {% if current_variant.available %}
        Ajouter
      {% else %}
        Épuisé
      {% endif %}
    </button>
  </div>
</div>

<!-- Thumbnail Switch JS -->
<script>
  document.addEventListener('DOMContentLoaded', function() {
    const mainImage = document.querySelector('.sf-pdp-main-image');
    const thumbnails = document.querySelectorAll('.sf-pdp-thumb');

    thumbnails.forEach(thumb => {
      thumb.addEventListener('click', function() {
        // Change main image src
        const newSrc = this.getAttribute('data-image-url');
        if(newSrc && mainImage) {
          mainImage.src = newSrc;
        }
        
        // Remove active class from all
        thumbnails.forEach(t => t.classList.remove('is-active'));
        // Add active class to clicked
        this.classList.add('is-active');
      });
    });

    // Sticky ATC Observer
    const stickyAtc = document.getElementById('sf-sticky-atc');
    const mainAtcForm = document.querySelector('.sf-pdp-form');
    
    if (stickyAtc && mainAtcForm) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (!entry.isIntersecting && entry.boundingClientRect.top < 0) {
            // Main form is above viewport, show sticky
            stickyAtc.classList.add('is-visible');
          } else {
            // Main form is in or below viewport, hide sticky
            stickyAtc.classList.remove('is-visible');
          }
        });
      }, { threshold: 0 });

      observer.observe(mainAtcForm);
    }
  });

  class SfVariantSelects extends HTMLElement {
    constructor() {
      super();
      this.addEventListener('change', this.onVariantChange);
      this.initDrawers();
    }

    initDrawers() {
      const wrappers = this.querySelectorAll('.js-drawer-wrapper');
      
      wrappers.forEach(wrapper => {
        const trigger = wrapper.querySelector('.js-drawer-trigger');
        const overlay = wrapper.querySelector('.js-drawer-overlay');
        const closeBtn = wrapper.querySelector('.js-drawer-close');
        
        const openDrawer = () => wrapper.classList.add('is-open');
        const closeDrawer = () => wrapper.classList.remove('is-open');

        if(trigger) trigger.addEventListener('click', openDrawer);
        if(overlay) overlay.addEventListener('click', closeDrawer);
        if(closeBtn) closeBtn.addEventListener('click', closeDrawer);
        
        // Fix iOS fixed container label focus jump
        const labels = wrapper.querySelectorAll('label');
        labels.forEach(label => {
          label.addEventListener('click', (e) => {
            e.preventDefault(); // Stop native scrolling and focus
            const inputId = label.getAttribute('for');
            if (inputId) {
              const input = document.getElementById(inputId);
              if (input && !input.checked) {
                input.checked = true;
                input.dispatchEvent(new Event('change', { bubbles: true }));
              }
            }
          });
        });
      });
    }

    onVariantChange(event) {
      // Prevent browser from native scroll adjustments
      const currentScrollY = window.scrollY;

      this.updateOptions();
      this.updateMasterId();
      this.updateFormId();
      this.updatePrice();
      this.updateImage();
      this.updateURL();
      
      // Force scroll restoration instantly
      window.scrollTo({ top: currentScrollY, behavior: 'instant' });
      
      // Update drawer trigger label & close drawer
      const wrapper = event.target.closest('.js-drawer-wrapper');
      if (wrapper) {
         const selectedValueEl = wrapper.querySelector('.js-selected-value');
         if(selectedValueEl) selectedValueEl.textContent = event.target.value;
         
         // Fix mobile scroll jump: prevent focus loss from bubbling scroll and add visual feedback
         setTimeout(() => {
           wrapper.classList.remove('is-open');
         }, 250);
      }
    }

    updateOptions() {
      this.options = Array.from(this.querySelectorAll('input[type="radio"]:checked'), (radio) => radio.value);
    }

    updateMasterId() {
      this.currentVariant = this.getVariantData().find((variant) => {
        return !variant.options.map((option, index) => {
          return this.options[index] === option;
        }).includes(false);
      });
    }

    updateFormId() {
      const formInput = document.querySelector(`#product-form-${this.dataset.section} input[name="id"]`);
      if (formInput && this.currentVariant) {
        formInput.value = this.currentVariant.id;
      }
      
      const stickyBtn = document.querySelector('.sf-sticky-btn');
      const addBtn = document.querySelector('.sf-pdp-add-to-cart-wrapper .btn-add-to-cart');
      
      if (this.currentVariant) {
        if (this.currentVariant.available) {
          if (addBtn) {
            addBtn.disabled = false;
            addBtn.innerHTML = addBtn.dataset.originalText || 'Ajouter au panier'; 
          }
          if (stickyBtn) {
            stickyBtn.disabled = false;
            stickyBtn.textContent = 'Ajouter';
          }
        } else {
          if (addBtn) {
            if(!addBtn.dataset.originalText) addBtn.dataset.originalText = addBtn.innerHTML;
            addBtn.disabled = true;
            addBtn.textContent = 'Rupture de stock';
          }
          if (stickyBtn) {
            stickyBtn.disabled = true;
            stickyBtn.textContent = 'Épuisé';
          }
        }
      }
    }

    updateURL() {
      if (!this.currentVariant) return;
      // Prevent browser from trying to scroll to an element if the URL changes
      const currentUrl = window.location.href;
      const urlObject = new URL(currentUrl);
      urlObject.searchParams.set('variant', this.currentVariant.id);
      window.history.replaceState({ path: urlObject.href }, '', urlObject.href);
    }

    updatePrice() {
      if (!this.currentVariant) return;
      const priceElement = document.querySelector('.sf-pdp-price-current');
      const compareElement = document.querySelector('.sf-pdp-price-compare');
      const stickyPrice = document.querySelector('.sf-sticky-atc-price');
      
      const formatMoney = (cents) => {
        return (cents / 100).toFixed(2).replace('.', ',') + ' €'; 
      };

      if (priceElement) priceElement.textContent = formatMoney(this.currentVariant.price);
      if (stickyPrice) stickyPrice.textContent = formatMoney(this.currentVariant.price);
      
      if (compareElement) {
        if (this.currentVariant.compare_at_price > this.currentVariant.price) {
          compareElement.textContent = formatMoney(this.currentVariant.compare_at_price);
          compareElement.style.display = 'inline-block';
        } else {
          compareElement.style.display = 'none';
        }
      }
    }

    updateImage() {
      if (!this.currentVariant || !this.currentVariant.featured_media) return;
      const mainImage = document.querySelector('.sf-pdp-main-image');
      const stickyImage = document.querySelector('.sf-sticky-atc-info img');
      
      if (mainImage) {
        const thumbs = document.querySelectorAll('.sf-pdp-thumb');
        thumbs.forEach(t => t.classList.remove('is-active'));
        const activeThumb = document.querySelector(`.sf-pdp-thumb[data-media-id="${this.currentVariant.featured_media.id}"]`);
        if(activeThumb) activeThumb.classList.add('is-active');

        mainImage.src = this.currentVariant.featured_media.preview_image.src;
      }
      
      if (stickyImage) {
        stickyImage.src = this.currentVariant.featured_media.preview_image.src;
      }
    }

    getVariantData() {
      this.variantData = this.variantData || JSON.parse(this.querySelector('[type="application/json"]').textContent);
      return this.variantData;
    }
  }

  customElements.define('sf-variant-radios', SfVariantSelects);

  // Initialize add-to-cart button text storage
  document.addEventListener('DOMContentLoaded', () => {
    const addBtn = document.querySelector('.sf-pdp-add-to-cart-wrapper .btn-add-to-cart');
    if(addBtn) {
      addBtn.dataset.originalText = addBtn.innerHTML;
    }
  });
</script>


{% schema %}
{
  "name": "Univers - Sous-Univers",
  "settings": [
    {
      "type": "header",
      "content": "Header Section"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Sur-titre (Label)",
      "default": "— EXPLORATION"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Titre",
      "default": "Les <span>Sous-Univers</span>",
      "info": "Utilisez <span>texte</span> pour colorer en Ambre."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Salut ! Prêt à transformer ton setup ? Plonge dans nos portails thématiques, conçus pour t'aider à créer l'espace qui te ressemble vraiment."
    },
    {
      "type": "header",
      "content": "Help Banner (Bottom)"
    },
    {
      "type": "checkbox",
      "id": "show_help",
      "label": "Afficher la bannière d'aide",
      "default": true
    },
    {
      "type": "text",
      "id": "help_title",
      "label": "Titre Aide",
      "default": "Pas sûr de ton choix ?"
    },
    {
      "type": "textarea",
      "id": "help_text",
      "label": "Texte Aide",
      "default": "En tant que passionnés, on sait que l'éclairage change tout. Si tu hésites entre deux univers, envoie-nous une photo de ton setup sur Discord, on te donnera notre avis d'expert gratuitement !"
    }
  ],
  "blocks": [
    {
      "type": "universe_card",
      "name": "Carte Univers",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image de la carte"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge",
          "default": "01. POP CULTURE"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titre",
          "default": "Univers Anime & Manga"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Inspiré des licences cultes et des scènes iconiques pour une immersion totale."
        },
        {
          "type": "text",
          "id": "btn_text",
          "label": "Texte du bouton",
          "default": "Explorer cet univers"
        },
        {
          "type": "url",
          "id": "btn_link",
          "label": "Lien du bouton"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Univers - Sous-Univers",
      "blocks": [
        {
          "type": "universe_card",
          "settings": {
            "badge": "01. POP CULTURE",
            "title": "Univers Anime & Manga",
            "description": "Inspiré des licences cultes et des scènes iconiques pour une immersion totale."
          }
        },
        {
          "type": "universe_card",
          "settings": {
            "badge": "02. DESIGN SETUP",
            "title": "Setup Visuel & Pop Culture",
            "description": "Pour créer une ambiance forte, même sans jouer. Le design au service de ton espace."
          }
        },
        {
          "type": "universe_card",
          "settings": {
            "badge": "03. ATMOSPHÈRE",
            "title": "Ambiance Chill & Nocturne",
            "description": "Lumières douces pour se poser, écouter, créer. Ta bulle de sérénité quotidienne."
          }
        }
      ]
    }
  ]
}
{% endschema %}

<style>
/* sf-sub-universes.css */
#shopify-section-{{ section.id }} .sub-uv-section {
  background-color: var(--illu-bg-night, #081A32);
  padding: 100px 5%;
  font-family: inherit;
  color: #fff;
}

#shopify-section-{{ section.id }} .sub-uv-container {
  max-width: 1200px;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  gap: 60px;
}

/* Header Section */
#shopify-section-{{ section.id }} .sub-uv-header {
  margin-bottom: 20px;
}

#shopify-section-{{ section.id }} .sub-uv-label {
  color: var(--illu-accent-amber, #E89D46);
  font-size: 1.24rem;
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  margin-bottom: 1rem;
  opacity: 0.9;
}

#shopify-section-{{ section.id }} .sub-uv-main-title {
  font-size: clamp(2.5rem, 5vw, 4rem);
  color: var(--illu-text-light, #F9F9F9);
  font-weight: 800;
  margin-bottom: 1.5rem;
  line-height: 1.1;
  letter-spacing: -0.02em;
}

#shopify-section-{{ section.id }} .sub-uv-main-title span {
  color: var(--illu-accent-amber, #E89D46);
}

#shopify-section-{{ section.id }} .sub-uv-main-desc {
  font-size: 1.24rem;
  color: rgba(249, 249, 249, 0.7);
  max-width: 600px;
  line-height: 1.6;
}

/* Cards Loop */
#shopify-section-{{ section.id }} .sub-uv-cards-wrap {
  display: flex;
  flex-direction: column;
  gap: 40px;
}

#shopify-section-{{ section.id }} .sub-uv-card {
  display: flex;
  background: rgba(255, 255, 255, 0.03);
  border-radius: 32px;
  overflow: hidden;
  border: 1px solid rgba(255, 255, 255, 0.05);
  transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  min-height: 480px;
}

@media (max-width: 900px) {
  #shopify-section-{{ section.id }} .sub-uv-card {
    flex-direction: column !important;
  }
}

/* Alternance Image / Texte */
#shopify-section-{{ section.id }} .sub-uv-card:nth-child(even) {
  flex-direction: row-reverse;
}

#shopify-section-{{ section.id }} .sub-uv-card:hover {
  transform: translateY(-10px);
  border-color: rgba(232, 157, 70, 0.3);
  background: rgba(255, 255, 255, 0.05);
  box-shadow: 0 40px 80px -20px rgba(0, 0, 0, 0.6);
}

#shopify-section-{{ section.id }} .sub-uv-media {
  flex: 1.3;
  position: relative;
  overflow: hidden;
  background: #0f1c2e;
}

/* Vignettage Image */
#shopify-section-{{ section.id }} .sub-uv-media::after {
  content: '';
  position: absolute;
  inset: 0;
  /* Direction du gradient variable selon l'alternance en desktop, mais on fait simple: gradient vers le centre / intérieur */
  background: linear-gradient(to right, rgba(8, 26, 50, 0.8) 0%, transparent 30%, transparent 70%, rgba(8, 26, 50, 0.8) 100%);
  z-index: 1;
  pointer-events: none;
}

@media (max-width: 900px) {
  #shopify-section-{{ section.id }} .sub-uv-media::after {
    background: linear-gradient(to bottom, transparent 50%, rgba(8, 26, 50, 0.8) 100%);
  }
}

#shopify-section-{{ section.id }} .sub-uv-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 1s ease, filter 0.5s ease;
  filter: brightness(0.85) contrast(1.1);
  position: absolute;
  inset: 0;
}

#shopify-section-{{ section.id }} .sub-uv-card:hover .sub-uv-img {
  transform: scale(1.08);
  filter: brightness(1) contrast(1.1);
}

#shopify-section-{{ section.id }} .sub-uv-content {
  flex: 1;
  padding: 64px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: flex-start;
  z-index: 2;
  position: relative;
}

@media (max-width: 900px) {
  #shopify-section-{{ section.id }} .sub-uv-content {
    padding: 32px;
  }
}

#shopify-section-{{ section.id }} .card-badge {
  background: rgba(232, 157, 70, 0.15);
  border: 1px solid rgba(232, 157, 70, 0.4);
  backdrop-filter: blur(8px);
  color: var(--illu-accent-amber, #E89D46);
  padding: 6px 14px;
  border-radius: 99px;
  font-size: 0.83rem;
  font-weight: 700;
  letter-spacing: 0.05em;
  margin-bottom: 24px;
}

#shopify-section-{{ section.id }} .sub-uv-title {
  font-size: clamp(1.8rem, 3vw, 2.5rem);
  color: var(--illu-text-light, #F9F9F9);
  font-weight: 800;
  line-height: 1.2;
  margin-bottom: 1.5rem;
}

#shopify-section-{{ section.id }} .sub-uv-description {
  font-size: 1.24rem;
  line-height: 1.7;
  color: rgba(249, 249, 249, 0.7);
  margin-bottom: 2.5rem;
}

#shopify-section-{{ section.id }} .btn-explore-pill {
  display: inline-flex;
  align-items: center;
  gap: 12px;
  background: var(--illu-accent-amber, #E89D46);
  color: var(--illu-bg-night, #081A32);
  padding: 14px 28px;
  border-radius: 99px;
  font-weight: 700;
  text-decoration: none;
  width: fit-content;
  transition: all 0.3s ease;
  font-size: 1.1rem;
}

#shopify-section-{{ section.id }} .btn-explore-pill svg {
  transition: transform 0.3s ease;
}

#shopify-section-{{ section.id }} .btn-explore-pill:hover {
  box-shadow: 0 0 30px rgba(232, 157, 70, 0.4);
  transform: scale(1.03);
}

#shopify-section-{{ section.id }} .btn-explore-pill:hover svg {
  transform: translateX(4px);
}

/* Help Banner */
#shopify-section-{{ section.id }} .sub-uv-help-banner {
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 32px;
  padding: 32px 48px;
  display: flex;
  align-items: flex-start;
  gap: 24px;
  margin-top: 40px;
}

@media (max-width: 768px) {
  #shopify-section-{{ section.id }} .sub-uv-help-banner {
    flex-direction: column;
    padding: 32px;
    align-items: center;
    text-align: center;
  }
}

#shopify-section-{{ section.id }} .help-icon-wrap {
  flex-shrink: 0;
  width: 56px;
  height: 56px;
  background: rgba(232, 157, 70, 0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--illu-accent-amber, #E89D46);
}

#shopify-section-{{ section.id }} .help-content {
  flex: 1;
}

#shopify-section-{{ section.id }} .help-title {
  color: var(--illu-text-light, #F9F9F9);
  font-size: 1.25rem;
  font-weight: 700;
  margin-bottom: 0.5rem;
}

#shopify-section-{{ section.id }} .help-text {
  color: rgba(249, 249, 249, 0.6);
  font-size: 1.1rem;
  line-height: 1.6;
}
</style>

<div class="sf-stitch sub-uv-section">
  <div class="sub-uv-container">
    
    <div class="sub-uv-header">
      {% if section.settings.label != blank %}
        <div class="sub-uv-label">{{ section.settings.label }}</div>
      {% endif %}
      <h2 class="sub-uv-main-title">{{ section.settings.title }}</h2>
      {% if section.settings.description != blank %}
        <p class="sub-uv-main-desc">{{ section.settings.description }}</p>
      {% endif %}
    </div>

    <div class="sub-uv-cards-wrap">
      {% for block in section.blocks %}
        <div class="sub-uv-card" {{ block.shopify_attributes }}>
          <div class="sub-uv-media">
            {% if block.settings.image %}
              <img src="{{ block.settings.image | image_url: width: 1200 }}" class="sub-uv-img" alt="{{ block.settings.title | escape }}" loading="lazy">
            {% else %}
              <div class="sub-uv-img" style="display: flex; align-items: center; justify-content: center; background: #111E2F;">
                <svg style="width: 80px; height: 80px; opacity: 0.1; color: white;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>
              </div>
            {% endif %}
          </div>
          
          <div class="sub-uv-content">
            {% if block.settings.badge != blank %}
              <div class="card-badge">{{ block.settings.badge }}</div>
            {% endif %}
            
            <h3 class="sub-uv-title">{{ block.settings.title }}</h3>
            
            {% if block.settings.description != blank %}
              <p class="sub-uv-description">{{ block.settings.description }}</p>
            {% endif %}
            
            <a href="{{ block.settings.btn_link | default: '#' }}" class="btn-explore-pill">
              {{ block.settings.btn_text }}
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </a>
          </div>
        </div>
      {% endfor %}
    </div>
    
    {% if section.settings.show_help %}
      <div class="sub-uv-help-banner">
        <div class="help-icon-wrap">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="9" y1="18" x2="15" y2="18"></line>
            <line x1="10" y1="22" x2="14" y2="22"></line>
            <path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"></path>
          </svg>
        </div>
        <div class="help-content">
          <h4 class="help-title">{{ section.settings.help_title }}</h4>
          <p class="help-text">{{ section.settings.help_text }}</p>
        </div>
      </div>
    {% endif %}

  </div>
</div>

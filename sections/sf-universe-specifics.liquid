{% schema %}
{
  "name": "Expertise Univers",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "NOTRE APPROCHE"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Heading",
      "default": "Une expertise qui s'adapte à<br>vos besoins."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Découvrez comment Illuminées transforme chaque espace grâce à une lumière pensée pour votre mode de vie."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Main Button",
      "default": "Explorer tous nos univers"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Link"
    }
  ],
  "blocks": [
    {
      "type": "universe",
      "name": "Universe Card",
      "limit": 3,
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "lamp", "label": "Desk Lamp (Quotidien)" },
            { "value": "gamepad", "label": "Gamepad (Visuel)" },
            { "value": "moon", "label": "Moon (Cocon)" }
          ],
          "default": "lamp"
        },
        {
          "type": "textarea",
          "id": "custom_svg",
          "label": "Custom SVG (Overrides Icon Select)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Espace Quotidien"
        },
        {
          "type": "text",
          "id": "tags",
          "label": "Tags (Separated by •)",
          "default": "CLARTÉ • FONCTIONNALITÉ • SOBRIÉTÉ"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Une approche pragmatique pour vos espaces de travail et de vie, alliant efficacité lumineuse et design épuré pour un quotidien simplifié."
        },
        {
          "type": "text",
          "id": "link_text",
          "label": "Link Text",
          "default": "Découvrir l'approche Quotidien →"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link Target"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Expertise Univers",
      "blocks": [
        { "type": "universe", "settings": { "icon": "lamp", "title": "Espace Quotidien", "tags": "CLARTÉ • FONCTIONNALITÉ • SOBRIÉTÉ", "description": "Une approche pragmatique pour vos espaces de travail et de vie, alliant efficacité lumineuse et design épuré pour un quotidien simplifié.", "link_text": "Découvrir l'approche Quotidien →" } },
        { "type": "universe", "settings": { "icon": "gamepad", "title": "Univers Visuel", "tags": "AMBIANCE • EXPRESSION • IDENTITÉ", "description": "Pour les passionnés de pop-culture et de gaming, nous créons des atmosphères immersives et uniques qui affirment votre style personnel.", "link_text": "Découvrir l'approche Visuelle →" } },
        { "type": "universe", "settings": { "icon": "moon", "title": "Petit Cocon", "tags": "DOUCEUR • SÉCURITÉ • SÉRÉNITÉ", "description": "Une conception pensée pour la tranquillité des parents et le bien-être des enfants, utilisant des matériaux sûrs et une lumière apaisante.", "link_text": "Découvrir l'approche Cocon →" } }
      ]
    }
  ]
}
{% endschema %}

<style>
/* CSS Compilé Final */
.universe-specifics-section {
  background-color: #081A32;
  padding: 100px 4rem 140px 4rem; /* Padding bottom extra for CTA */
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

.universe-specifics-header {
  text-align: center;
  max-width: 800px;
  margin: 0 auto 5rem auto;
}

.universe-badge {
  display: inline-block;
  color: #E89D46;
  font-size: 0.83rem;
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  margin-bottom: 2rem;
  padding: 8px 24px;
  border-radius: 99px;
  border: 1px solid rgba(232, 157, 70, 0.3);
  background: rgba(232, 157, 70, 0.05); 
  backdrop-filter: blur(8px);
}

.universe-h2 {
  font-size: clamp(2.75rem, 5.5vw, 4.4rem);
  color: #F9F9F9;
  font-weight: 700;
  line-height: 1.1;
  margin-bottom: 1.5rem;
  letter-spacing: -0.02em;
}

.universe-desc {
  font-size: 1.26rem;
  color: rgba(249, 249, 249, 0.7);
  line-height: 1.6;
  max-width: 650px;
  margin: 0 auto;
}

/* Grille des Univers */
.universe-specifics-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2.5rem; /* ~40px */
  max-width: 1400px;
  margin: 0 auto;
}

/* Style de Carte Expert */
.universe-card-expert {
  /* Match mockup color (#17212F approx or slightly lighter than bg) */
  background: #17212F; 
  border: 1px solid rgba(255, 255, 255, 0.05);
  border-radius: 32px;
  padding: 48px 40px;
  text-align: left; /* Text aligns left on the mockup */
  transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  display: flex;
  flex-direction: column;
  align-items: flex-start; /* Align elements left */
  box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2);
  text-decoration: none;
  color: inherit;
}

.universe-card-expert:hover {
  transform: translateY(-12px);
  border-color: rgba(232, 157, 70, 0.3);
  background: #1A2636;
  /* Contrast Enhancement as requested */
  filter: contrast(1.05); 
}

/* Icon Container */
.universe-card-icon-box {
  width: 56px;
  height: 56px;
  border-radius: 16px;
  background: rgba(232, 157, 70, 0.08); /* Amber subtle */
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 2.5rem;
}

.universe-card-icon-box svg {
  width: 32px;
  height: 32px;
  color: #E89D46;
  /* Lueur de Badge / Icon glow */
  filter: drop-shadow(0 0 12px rgba(232, 157, 70, 0.25));
  transition: all 0.3s ease;
}

.universe-card-expert:hover .universe-card-icon-box svg {
  filter: drop-shadow(0 0 15px rgba(232, 157, 70, 0.5));
}

/* Card Text */
.universe-card-expert h3 {
  color: #F9F9F9;
  font-size: 1.76rem;
  font-weight: 600;
  margin: 0 0 0.75rem 0;
  letter-spacing: -0.01em;
}

.universe-tags {
  color: #E89D46;
  font-size: 0.83rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  margin-bottom: 1.5rem;
  text-transform: uppercase;
}

.universe-card-expert p {
  color: rgba(249, 249, 249, 0.65);
  font-size: 1.1rem;
  line-height: 1.6;
  margin: 0;
  flex-grow: 1; 
  padding-bottom: 3rem; /* Push the link down */
}

/* Footer Link */
.universe-link {
  margin-top: auto;
  color: #E89D46;
  font-weight: 700;
  font-size: 0.99rem;
  text-decoration: none;
  transition: opacity 0.3s ease;
  display: inline-flex;
  align-items: center;
}

.universe-card-expert:hover .universe-link {
  opacity: 0.8;
  text-decoration: underline;
}

/* Main Call To Action Button at the very bottom */
.universe-cta-container {
  display: flex;
  justify-content: center;
  margin-top: 6rem;
}

.btn-pill-amber-main {
  background: #E89D46;
  color: #081A32;
  border: 1px solid #E89D46;
  padding: 18px 40px;
  border-radius: 99px;
  font-weight: 700;
  font-size: 1.21rem;
  text-decoration: none;
  transition: all 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
  box-shadow: 0 10px 25px rgba(232, 157, 70, 0.2);
  display: inline-flex;
  align-items: center;
  gap: 12px;
}

.btn-pill-amber-main svg {
  width: 18px;
  height: 18px;
  stroke: #081A32;
  fill: none;
  stroke-width: 2;
}

.btn-pill-amber-main:hover {
  transform: translateY(-5px);
  background: #F0A956;
  border-color: #F0A956;
  box-shadow: 0 15px 35px rgba(232, 157, 70, 0.35);
}

/* Responsive */
@media screen and (max-width: 1024px) {
  .universe-specifics-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media screen and (max-width: 768px) {
  .universe-specifics-section {
    padding: 80px 2rem;
  }
  .universe-specifics-grid {
    grid-template-columns: 1fr;
    gap: 24px;
  }
  .universe-h2 {
    font-size: 2.75rem;
  }
}
</style>

<section class="universe-specifics-section">
  
  <div class="universe-specifics-header">
    {% if section.settings.badge_text != blank %}
      <div class="universe-badge">{{ section.settings.badge_text }}</div>
    {% endif %}
    
    {% if section.settings.title != blank %}
      <h2 class="universe-h2">{{ section.settings.title }}</h2>
    {% endif %}
    
    {% if section.settings.description != blank %}
      <p class="universe-desc">{{ section.settings.description }}</p>
    {% endif %}
  </div>

  <div class="universe-specifics-grid">
    {% for block in section.blocks %}
      <a href="{{ block.settings.link_url | default: '#' }}" class="universe-card-expert" {{ block.shopify_attributes }}>
        
        <div class="universe-card-icon-box">
          {% if block.settings.custom_svg != blank %}
            {{ block.settings.custom_svg }}
          {% else %}
            {% case block.settings.icon %}
              {% when 'lamp' %}
                <!-- Solid Desk Lamp style -->
                <svg viewBox="0 0 256 256" fill="currentColor">
                  <path d="M232,208H24a8,8,0,0,0,0,16H232a8,8,0,0,0,0-16Zm-64-16a8,8,0,0,0,8-8V93.57A72.07,72.07,0,0,0,105.77,21.68l-1.5,0a71.93,71.93,0,0,0-63.51,65L32,96a8,8,0,0,0,8,8h24v80a8,8,0,0,0,8,8H168ZM48.24,88A56,56,0,0,1,104.09,37.66h1.16A56.05,56.05,0,0,1,160,92.51V96l-111.9.09C48.1,93.41,48.15,90.7,48.24,88Z"></path>
                </svg>
              {% when 'gamepad' %}
                <!-- Solid Gamepad style -->
                <svg viewBox="0 0 256 256" fill="currentColor">
                  <path d="M239.81,114.71,216.79,53.25A24,24,0,0,0,194.32,36C186,34.49,158.41,32,128,32s-58,2.49-66.32,4-20.84,15.65-22.47,24l-23,61.45A31.84,31.84,0,0,0,44.91,161.9L65.48,185.9a16,16,0,0,0,15,5.1l20.45-4.48A91.43,91.43,0,0,1,128,184a91.43,91.43,0,0,1,27.08,2.52l20.45,4.48a16,16,0,0,0,15-5.1l20.57-24A31.83,31.83,0,0,0,239.81,114.71ZM176,112a12,12,0,1,1,12-12A12,12,0,0,1,176,112ZM72,112H64v8a8,8,0,0,1-16,0v-8H40a8,8,0,0,1,0-16h8V88a8,8,0,0,1,16,0v8h8a8,8,0,0,1,0,16Zm136-24a12,12,0,1,1-12-12A12,12,0,0,1,208,88Z"></path>
                </svg>
              {% when 'moon' %}
                <!-- Solid Moon style -->
                <svg viewBox="0 0 256 256" fill="currentColor">
                  <path d="M216.7,152.62A104,104,0,1,1,103.38,39.3a8,8,0,0,1,10.6,10.6,88,88,0,0,0,113.31,113.31,8,8,0,0,1,10.6,10.6Z"></path>
                </svg>
            {% endcase %}
          {% endif %}
        </div>
        
        <h3>{{ block.settings.title }}</h3>
        <div class="universe-tags">{{ block.settings.tags }}</div>
        <p>{{ block.settings.description }}</p>
        
        <span class="universe-link">
          {{ block.settings.link_text }}
        </span>
      </a>
    {% endfor %}
  </div>

  <div class="universe-cta-container">
    {% if section.settings.cta_text != blank %}
      <a href="{{ section.settings.cta_link | default: '#' }}" class="btn-pill-amber-main">
        {{ section.settings.cta_text }}
        <!-- Grid Icon -->
        <svg viewBox="0 0 24 24">
          <rect x="3" y="3" width="7" height="7" rx="1"></rect>
          <rect x="14" y="3" width="7" height="7" rx="1"></rect>
          <rect x="14" y="14" width="7" height="7" rx="1"></rect>
          <rect x="3" y="14" width="7" height="7" rx="1"></rect>
        </svg>
      </a>
    {% endif %}
  </div>
  
</section>

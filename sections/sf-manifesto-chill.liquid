{% schema %}
{
  "name": "Philosophie Manifesto",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "PHILOSOPHIE"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Heading",
      "default": "Une lumière qui <span class=\"amber-text\">s'assume.</span>",
      "info": "Use <span class=\"amber-text\">text</span> to highlight in amber with glow."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Nous ne cherchons pas à proposer des lumières neutres ou invisibles. Dans l'univers Visuel, la lumière fait partie intégrante de l'ambiance : elle est visible, ressentie, assumée, tout en restant confortable pour les yeux."
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Pillar",
      "limit": 3,
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "bulb", "label": "Bulb" },
            { "value": "eye-crossed", "label": "Eye Crossed" },
            { "value": "sparkle", "label": "Sparkle" }
          ],
          "default": "bulb"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Présence Affirmée"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Une luminosité qui sculpte l'espace et définit le ton de la pièce."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Philosophie Manifesto",
      "blocks": [
        { "type": "card", "settings": { "icon": "bulb", "title": "Présence Affirmée", "text": "Une luminosité qui sculpte l'espace et définit le ton de la pièce." } },
        { "type": "card", "settings": { "icon": "eye-crossed", "title": "Confort Absolu", "text": "Douceur pour le regard, sans éblouissement ni fatigue." } },
        { "type": "card", "settings": { "icon": "sparkle", "title": "Signature Visuelle", "text": "L'esthétique de la lumière devient aussi importante que l'objet." } }
      ]
    }
  ]
}
{% endschema %}

<style>
.manifesto-chill-section {
  background-color: #081A32;
  padding: 120px 4rem;
  display: flex;
  justify-content: center;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

.manifesto-glass-card {
  max-width: 1000px;
  width: 100%;
  background: rgba(255, 255, 255, 0.02);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: 32px;
  border: 1px solid rgba(255, 255, 255, 0.05);
  padding: 80px 60px;
  text-align: center;
  position: relative;
  overflow: hidden;
}

/* Lueur de Fond */
.manifesto-glass-card::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(232, 157, 70, 0.1) 0%, transparent 50%);
  z-index: -1;
  mix-blend-mode: plus-lighter;
  pointer-events: none;
}

/* Header Content */
.manifesto-badge-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16px;
  margin-bottom: 2.5rem;
}

.manifesto-badge-line {
  height: 1px;
  width: 40px;
  background-color: rgba(232, 157, 70, 0.3);
}

.manifesto-badge {
  color: #E89D46;
  font-size: 0.83rem;
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
}

.manifesto-h2 {
  font-size: clamp(2.75rem, 4.4vw, 3.85rem);
  color: #F9F9F9;
  font-weight: 600;
  line-height: 1.1;
  letter-spacing: -0.02em;
  margin-bottom: 2rem;
}

/* Saturation Texte */
.amber-text {
  color: #E89D46;
  text-shadow: 0 0 20px rgba(232, 157, 70, 0.3);
}

.manifesto-desc {
  font-size: 1.26rem;
  color: rgba(249, 249, 249, 0.85); /* Legérement plus vif basé sur la maquette */
  line-height: 1.6;
  max-width: 800px;
  margin: 0 auto;
}

/* Pillars Grid */
.manifesto-pillars-flex {
  display: flex;
  justify-content: center;
  gap: 4rem;
  margin-top: 5rem;
  border-top: 1px solid rgba(255, 255, 255, 0.05);
  padding-top: 4rem;
}

.pillar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.pillar-icon {
  width: 56px;
  height: 56px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.02);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 1.5rem;
  /* Lueur d'icone très douce (sur la maquette, on voit un léger halo clair) */
  box-shadow: inset 0 0 0 1px rgba(255,255,255,0.05), 0 0 20px rgba(255,255,255,0.02);
}

.pillar-icon svg {
  width: 24px;
  height: 24px;
  stroke: #E89D46;
  fill: none;
  stroke-width: 1.8;
  stroke-linecap: round;
  stroke-linejoin: round;
}

.pillar-item h3 {
  color: #F9F9F9;
  font-size: 1.38rem;
  font-weight: 600;
  margin: 0 0 0.75rem 0;
}

.pillar-item p {
  color: rgba(249, 249, 249, 0.5);
  font-size: 1.05rem;
  line-height: 1.5;
  margin: 0;
  max-width: 220px;
}

@media screen and (max-width: 900px) {
  .manifesto-pillars-flex {
    flex-direction: column;
    gap: 3rem;
  }
  .pillar-item {
    max-width: 400px;
    margin: 0 auto;
  }
}

@media screen and (max-width: 768px) {
  .manifesto-chill-section {
    padding: 80px 2rem;
  }
  .manifesto-glass-card {
    padding: 60px 24px;
  }
  .manifesto-pillars-flex {
    margin-top: 4rem;
    padding-top: 3rem;
  }
}
</style>

<section class="manifesto-chill-section">
  <div class="manifesto-glass-card">
    
    <div class="manifesto-badge-wrapper">
      <div class="manifesto-badge-line"></div>
      {% if section.settings.badge_text != blank %}
        <span class="manifesto-badge">{{ section.settings.badge_text }}</span>
      {% endif %}
      <div class="manifesto-badge-line"></div>
    </div>
    
    {% if section.settings.title != blank %}
      <h2 class="manifesto-h2">{{ section.settings.title }}</h2>
    {% endif %}
    
    {% if section.settings.description != blank %}
      <p class="manifesto-desc">{{ section.settings.description }}</p>
    {% endif %}
    
    <div class="manifesto-pillars-flex">
      {% for block in section.blocks %}
        <div class="pillar-item" {{ block.shopify_attributes }}>
          <div class="pillar-icon">
            {% case block.settings.icon %}
              {% when 'bulb' %}
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 2v20 M2 12h20" opacity="0.3" stroke-width="1"/>
                  <polygon points="12 3 14.6 8.5 21 9.4 16.4 13.9 17.5 20.2 12 17.2 6.5 20.2 7.6 13.9 3 9.4 9.4 8.5"/>
                  <circle cx="12" cy="12" r="1.5" fill="currentColor" stroke="none"/>
                </svg>
              {% when 'eye-crossed' %}
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 2v20 M2 12h20" opacity="0.3" stroke-width="1"/>
                  <path d="M2.5 12s3.5-6.5 9.5-6.5 9.5 6.5 9.5 6.5-3.5 6.5-9.5 6.5S2.5 12 2.5 12z"/>
                  <circle cx="12" cy="12" r="3"/>
                  <circle cx="12" cy="12" r="1" fill="currentColor" stroke="none"/>
                </svg>
              {% when 'sparkle' %}
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 2v20 M2 12h20" opacity="0.3" stroke-width="1"/>
                  <polygon points="12 4.5 19.5 12 12 19.5 4.5 12"/>
                  <circle cx="12" cy="4.5" r="1" fill="currentColor" stroke="none"/>
                  <circle cx="19.5" cy="12" r="1" fill="currentColor" stroke="none"/>
                  <circle cx="12" cy="19.5" r="1" fill="currentColor" stroke="none"/>
                  <circle cx="4.5" cy="12" r="1" fill="currentColor" stroke="none"/>
                  <circle cx="12" cy="12" r="1.5" fill="currentColor" stroke="none"/>
                </svg>
            {% endcase %}
          </div>
          <h3>{{ block.settings.title }}</h3>
          <p>{{ block.settings.text }}</p>
        </div>
      {% endfor %}
    </div>
    
  </div>
</section>

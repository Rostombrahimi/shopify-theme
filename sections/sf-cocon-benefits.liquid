{% schema %}
{
  "name": "Bénéfices Cocon",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titre principal",
      "default": "Ce que cette ambiance apporte"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Sous-titre",
      "default": "Plongez dans un cocon de sérénité nocturne."
    }
  ],
  "blocks": [
    {
      "type": "benefit_row",
      "name": "Ligne Bénéfice",
      "limit": 3,
      "settings": [
        {
          "type": "html",
          "id": "icon",
          "label": "Icône SVG"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titre du bénéfice",
          "default": "Titre du bénéfice"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Description du bénéfice apporté."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bénéfices Cocon",
      "blocks": [
        {
          "type": "benefit_row",
          "settings": {
            "icon": "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M2 12h4\"/><path d=\"M18 12h4\"/><path d=\"M12 2v4\"/><path d=\"M12 18v4\"/><rect width=\"8\" height=\"8\" x=\"8\" y=\"8\" rx=\"2\"/></svg>",
            "title": "Clarté ciblée",
            "text": "Une clarté ciblée qui respecte l'obscurité environnante pour ne pas briser l'isolement."
          }
        },
        {
          "type": "benefit_row",
          "settings": {
            "icon": "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z\"/><circle cx=\"12\" cy=\"12\" r=\"3\"/><path d=\"m2 2 20 20\"/></svg>",
            "title": "Fatigue réduite",
            "text": "Un spectre ambré doux qui réduit la fatigue visuelle, que vos yeux soient sur une page ou fermés pour écouter."
          }
        },
        {
          "type": "benefit_row",
          "settings": {
            "icon": "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M14 4v10.54a4 4 0 1 1-4 0V4a2 2 0 0 1 4 0Z\"/><path d=\"M12 9v4\"/><path d=\"M16 8h2\"/><path d=\"M16 14h2\"/></svg>",
            "title": "Équilibre thermique",
            "text": "Un équilibre thermique pour une atmosphère calme, propice au flow et à la déconnexion."
          }
        }
      ]
    }
  ]
}
{% endschema %}

<style>
/* Section Bénéfices Cocon - sf-cocon-benefits.css */

#shopify-section-{{ section.id }} .cocon-benefits-section {
  background-color: #081A32; /* illu-night */
  padding: 100px 0;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

/* En-tête */
#shopify-section-{{ section.id }} .cocon-benefits-header {
  text-align: left;
  max-width: 900px; /* Aligné sur la grille des lignes */
  margin: 0 auto 3.5rem auto;
  padding: 0 4rem;
}

#shopify-section-{{ section.id }} .cocon-title {
  font-size: clamp(2rem, 4vw, 2.5rem);
  color: #F9F9F9;
  font-weight: 800;
  margin: 0 0 0.75rem 0;
  letter-spacing: -0.01em;
}

#shopify-section-{{ section.id }} .cocon-subtitle {
  font-size: clamp(1rem, 2vw, 1.15rem);
  color: #9CA3AF;
  font-weight: 400;
  margin: 0;
}

/* Conteneur des lignes */
#shopify-section-{{ section.id }} .cocon-benefits-list {
  display: flex;
  flex-direction: column;
  gap: 20px;
  max-width: 900px;
  margin: 0 auto;
  padding: 0 4rem;
}

/* Ligne (Row) */
#shopify-section-{{ section.id }} .cocon-benefit-row {
  display: flex;
  align-items: center;
  gap: 32px;
  background: rgba(255, 255, 255, 0.02);
  border: 1px solid rgba(255, 255, 255, 0.04);
  border-radius: 20px; /* Slightly smaller radius for horizontal rows */
  padding: 32px 40px;
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
}

#shopify-section-{{ section.id }} .cocon-benefit-row:hover {
  transform: translateX(8px); /* Hover glissant vers la droite */
  border-color: rgba(232, 157, 70, 0.2);
  background: rgba(255, 255, 255, 0.04);
}

/* Icônes */
#shopify-section-{{ section.id }} .cocon-icon-wrapper {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 56px;
  height: 56px;
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.05);
  border-radius: 16px;
  color: #E89D46;
  flex-shrink: 0;
  transition: all 0.4s ease;
  filter: drop-shadow(0 0 8px rgba(232, 157, 70, 0.25));
}

#shopify-section-{{ section.id }} .cocon-icon-wrapper svg {
  width: 24px !important;
  height: 24px !important;
  min-width: 24px;
  min-height: 24px;
  display: block;
  flex-shrink: 0;
}

#shopify-section-{{ section.id }} .cocon-benefit-row:hover .cocon-icon-wrapper {
  color: #F9F9F9;
  background: #E89D46;
  border-color: #E89D46;
  filter: drop-shadow(0 0 12px rgba(232, 157, 70, 0.4));
  transform: scale(1.05);
}

/* Textes */
#shopify-section-{{ section.id }} .cocon-text-content {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

#shopify-section-{{ section.id }} .cocon-benefit-title {
  color: #F9F9F9;
  font-size: 1.15rem;
  font-weight: 700;
  margin: 0;
  letter-spacing: -0.01em;
}

#shopify-section-{{ section.id }} .cocon-benefit-desc {
  color: #9CA3AF;
  font-size: 0.95rem;
  line-height: 1.6;
  margin: 0;
  max-width: 650px;
}

/* MOBILE RESPONSIVE - SNAP CAROUSEL */
@media screen and (max-width: 768px) {
  #shopify-section-{{ section.id }} .cocon-benefits-section {
    padding: 80px 0;
  }
  
  #shopify-section-{{ section.id }} .cocon-benefits-header {
    padding: 0 1.5rem;
    margin-bottom: 2.5rem;
  }
  
  #shopify-section-{{ section.id }} .cocon-title {
    font-size: 1.8rem;
  }

  /* Slider Snap Logic */
  #shopify-section-{{ section.id }} .cocon-benefits-list-wrapper {
    width: 100vw;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding-bottom: 2rem;
  }

  #shopify-section-{{ section.id }} .cocon-benefits-list-wrapper::-webkit-scrollbar {
    display: none;
  }

  #shopify-section-{{ section.id }} .cocon-benefits-list {
    display: flex;
    flex-direction: row;
    width: max-content;
    padding: 0 1.5rem;
    margin: 0;
    gap: 1.25rem;
  }
  
  #shopify-section-{{ section.id }} .cocon-benefit-row {
    scroll-snap-align: center;
    width: 85vw;
    max-width: 320px;
    flex-direction: column;
    align-items: flex-start;
    padding: 28px 24px;
    gap: 20px;
    flex-shrink: 0;
    /* Prevent hover translation jumping issues on mobile touch */
    transition: transform 0.3s ease, background 0.3s ease, border-color 0.3s ease;
  }

  #shopify-section-{{ section.id }} .cocon-benefit-row:active {
    transform: translateY(-4px); /* Petit bond au clic (mobile) au lieu du slide right */
  }
}
</style>

<section class="cocon-benefits-section sf-stitch">
  
  <div class="cocon-benefits-header">
    {% if section.settings.title != blank %}
      <h2 class="cocon-title">{{ section.settings.title }}</h2>
    {% endif %}
    {% if section.settings.subtitle != blank %}
      <p class="cocon-subtitle">{{ section.settings.subtitle }}</p>
    {% endif %}
  </div>

  {% if section.blocks.size > 0 %}
    <div class="cocon-benefits-list-wrapper">
      <div class="cocon-benefits-list">
        {% for block in section.blocks %}
          <div class="cocon-benefit-row" {{ block.shopify_attributes }}>
            <div class="cocon-icon-wrapper">
              {% if block.settings.icon != blank %}
                {{ block.settings.icon }}
              {% endif %}
            </div>
            <div class="cocon-text-content">
              <h3 class="cocon-benefit-title">{{ block.settings.title }}</h3>
              <p class="cocon-benefit-desc">{{ block.settings.text }}</p>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  {% endif %}

</section>

{% schema %}
{
  "name": "Conclusion Approche",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "NOTRE PHILOSOPHIE"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Heading",
      "default": "Pourquoi la curation est une élévation"
    },
    {
      "type": "textarea",
      "id": "cta_text_above",
      "label": "Text above CTA",
      "default": "Prêt à illuminer votre intérieur avec discernement ?"
    },
    {
      "type": "text",
      "id": "cta_button_text",
      "label": "CTA Button Text",
      "default": "Découvrir nos univers lumineux →"
    },
    {
      "type": "url",
      "id": "cta_button_link",
      "label": "CTA Button Link"
    }
  ],
  "blocks": [
    {
      "type": "difference",
      "name": "Différence Card",
      "limit": 4,
      "settings": [
        {
          "type": "textarea",
          "id": "custom_svg",
          "label": "Custom SVG (Overrides default icon)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Moins de choix"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Parce que la clarté commence par l'épure."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Conclusion Approche",
      "blocks": [
        { "type": "difference", "settings": { "title": "Moins de choix", "description": "Parce que la clarté commence par l'épure." } },
        { "type": "difference", "settings": { "title": "Meilleure expérience", "description": "Un accompagnement expert à chaque étape." } },
        { "type": "difference", "settings": { "title": "Décisions plus simples", "description": "Fini le paradoxe du choix, place au ressenti." } },
        { "type": "difference", "settings": { "title": "Produits plus durables", "description": "Une sélection pensée pour durer, pas pour être remplacée." } }
      ]
    }
  ]
}
{% endschema %}

<style>
/* CSS Compilé Final */
.approach-conclusion-section {
  background-color: #081A32;
  padding: 100px 4rem 120px 4rem;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

.conclusion-header {
  text-align: left;
  max-width: 1400px;
  margin: 0 auto 4rem auto;
}

.conclusion-badge {
  display: inline-block;
  color: #E89D46;
  font-size: 0.83rem;
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  margin-bottom: 1.5rem;
}

.conclusion-h2 {
  font-size: clamp(2.2rem, 4.4vw, 3.3rem);
  color: #F9F9F9;
  font-weight: 700;
  line-height: 1.1;
  margin: 0;
  letter-spacing: -0.02em;
}

/* Grille de 4 cartes */
.difference-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 2rem;
  max-width: 1400px;
  margin: 0 auto;
}

.diff-card {
  /* Darker blueish grey, similar to mockup */
  background: #111C2C; 
  border-radius: 32px;
  padding: 40px 32px;
  text-align: left;
  border: 1px solid rgba(255, 255, 255, 0.05);
  transition: all 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
  display: flex;
  flex-direction: column;
}

.diff-card:hover {
  border-color: rgba(232, 157, 70, 0.3);
  transform: translateY(-8px);
  background: #152233;
}

/* Icon Box inside card */
.diff-icon-box {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.03);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 2rem;
  border: 1px solid rgba(255, 255, 255, 0.05);
  transition: all 0.3s ease;
}

.diff-card:hover .diff-icon-box {
  background: rgba(232, 157, 70, 0.08);
  border-color: rgba(232, 157, 70, 0.2);
}

.diff-icon-box svg {
  width: 24px;
  height: 24px;
  color: #E89D46;
  fill: #E89D46;
  stroke: none;
  transition: all 0.3s ease;
}

.diff-card:hover .diff-icon-box svg {
  filter: drop-shadow(0 0 8px rgba(232, 157, 70, 0.4));
}

.diff-title {
  color: #F9F9F9;
  font-weight: 600;
  font-size: 1.25rem;
  margin: 0 0 1rem 0;
  line-height: 1.3;
}

.diff-text {
  color: rgba(249, 249, 249, 0.6);
  font-size: 1.05rem;
  line-height: 1.5;
  margin: 0;
}

/* CTA Section at bottom */
.conclusion-cta-area {
  text-align: center;
  margin-top: 6rem;
  max-width: 800px;
  margin-left: auto;
  margin-right: auto;
  padding-top: 6rem; /* extra space from grid */
}

.conclusion-cta-text {
  color: #F9F9F9;
  font-size: 1.21rem;
  font-weight: 600;
  margin-bottom: 2rem;
}

.btn-pill-amber-conclusion {
  background: #E89D46;
  color: #081A32;
  border: none;
  padding: 18px 40px;
  border-radius: 99px;
  font-weight: 700;
  font-size: 1.1rem;
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  transition: all 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
  /* Permanent glow to show it's "on" */
  filter: drop-shadow(0 0 15px rgba(232, 157, 70, 0.4));
}

.btn-pill-amber-conclusion:hover {
  transform: translateY(-4px);
  background: #F0A956;
  filter: drop-shadow(0 0 25px rgba(232, 157, 70, 0.6));
}

/* Responsive */
@media screen and (max-width: 1200px) {
  .difference-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media screen and (max-width: 768px) {
  .approach-conclusion-section {
    padding: 80px 2rem;
  }
  .difference-grid {
    grid-template-columns: 1fr;
  }
  .conclusion-h2 {
    font-size: 2.42rem;
  }
}
</style>

<section class="approach-conclusion-section">
  
  <div class="conclusion-header">
    {% if section.settings.badge_text != blank %}
      <div class="conclusion-badge">{{ section.settings.badge_text }}</div>
    {% endif %}
    {% if section.settings.title != blank %}
      <h2 class="conclusion-h2">{{ section.settings.title }}</h2>
    {% endif %}
  </div>

  <div class="difference-grid">
    {% for block in section.blocks %}
      <div class="diff-card" {{ block.shopify_attributes }}>
        
        <div class="diff-icon-box">
          {% if block.settings.custom_svg != blank %}
            {{ block.settings.custom_svg }}
          {% else %}
            {% if forloop.index == 1 %}
              <!-- Solid Focus icon for Moins de choix -->
              <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 8c-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4-1.79-4-4-4zm-7 7H3v4c0 1.1.9 2 2 2h4v-2H5v-4zM5 5h4V3H5c-1.1 0-2 .9-2 2v4h2V5zm14-2h-4v2h4v4h2V5c0-1.1-.9-2-2-2zm0 16h-4v2h4c1.1 0 2-.9 2-2v-4h-2v4z"/>
              </svg>
            {% elsif forloop.index == 2 %}
              <!-- Solid Infinity icon for Meilleure expérience -->
              <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                <path d="M18.69 7.57c-1.63 0-3 1.05-3.81 2.38l-3.35 5.47c-.43.69-1.17 1.13-2 1.13-1.49 0-2.7-1.21-2.7-2.7 0-1.49 1.21-2.7 2.7-2.7.62 0 1.21.21 1.68.58l1.34-2.2c-.91-1.11-1.92-1.73-3.02-1.73-3.34 0-6.03 2.71-6.03 6.05s2.69 6.05 6.03 6.05c1.63 0 3-1.05 3.81-2.38l3.35-5.47c.43-.69 1.17-1.13 2-1.13 1.49 0 2.7 1.21 2.7 2.7 0 1.49-1.21 2.7-2.7 2.7-.62 0-1.21-.21-1.68-.58l-1.34 2.2c.91 1.11 1.92 1.73 3.02 1.73 3.34 0 6.03-2.71 6.03-6.05s-2.69-6.05-6.03-6.05z"/>
              </svg>
            {% elsif forloop.index == 3 %}
              <!-- Solid Check Circle icon for Décisions simples -->
              <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
              </svg>
            {% else %}
              <!-- Solid Diamond icon for Produits durables -->
              <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                <path d="M19 3H5L2 9l10 12L22 9l-3-6zM9.62 19L5 10.66 8.35 5h3.27L12 11.23 9.62 19zM11 5l2.4 6.7L9.5 5h1.5zm1.38 14L12 11.23l.35-5.67H15.65L19 10.66 12.38 19z"/>
              </svg>
            {% endif %}
          {% endif %}
        </div>

        <h3 class="diff-title">{{ block.settings.title }}</h3>
        <p class="diff-text">{{ block.settings.description }}</p>
      
      </div>
    {% endfor %}
  </div>

  <div class="conclusion-cta-area">
    {% if section.settings.cta_text_above != blank %}
      <div class="conclusion-cta-text">{{ section.settings.cta_text_above }}</div>
    {% endif %}
    {% if section.settings.cta_button_text != blank %}
      <a href="{{ section.settings.cta_button_link | default: '#' }}" class="btn-pill-amber-conclusion">
        {{ section.settings.cta_button_text }}
      </a>
    {% endif %}
  </div>

</section>

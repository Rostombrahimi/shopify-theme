{% schema %}
{
  "name": "Conclusion Approche",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "NOTRE PHILOSOPHIE"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Heading",
      "default": "Pourquoi la curation est une élévation"
    },
    {
      "type": "textarea",
      "id": "cta_text_above",
      "label": "Text above CTA",
      "default": "Prêt à illuminer votre intérieur avec discernement ?"
    },
    {
      "type": "text",
      "id": "cta_button_text",
      "label": "CTA Button Text",
      "default": "Découvrir nos univers lumineux →"
    },
    {
      "type": "url",
      "id": "cta_button_link",
      "label": "CTA Button Link"
    }
  ],
  "blocks": [
    {
      "type": "difference",
      "name": "Différence Card",
      "limit": 4,
      "settings": [
        {
          "type": "textarea",
          "id": "custom_svg",
          "label": "Custom SVG (Overrides default icon)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Moins de choix"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Parce que la clarté commence par l'épure."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Conclusion Approche",
      "blocks": [
        { "type": "difference", "settings": { "title": "Moins de choix", "description": "Parce que la clarté commence par l'épure." } },
        { "type": "difference", "settings": { "title": "Meilleure expérience", "description": "Un accompagnement expert à chaque étape." } },
        { "type": "difference", "settings": { "title": "Décisions plus simples", "description": "Fini le paradoxe du choix, place au ressenti." } },
        { "type": "difference", "settings": { "title": "Produits plus durables", "description": "Une sélection pensée pour durer, pas pour être remplacée." } }
      ]
    }
  ]
}
{% endschema %}

<style>
/* CSS Compilé Final */
.approach-conclusion-section {
  background-color: #081A32;
  padding: 100px 4rem 120px 4rem;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

.conclusion-header {
  text-align: left;
  max-width: 1400px;
  margin: 0 auto 4rem auto;
}

.conclusion-badge {
  display: inline-block;
  color: #E89D46;
  font-size: 0.83rem;
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  margin-bottom: 1.5rem;
}

.conclusion-h2 {
  font-size: clamp(2.2rem, 4.4vw, 3.3rem);
  color: #F9F9F9;
  font-weight: 700;
  line-height: 1.1;
  margin: 0;
  letter-spacing: -0.02em;
}

/* Grille de 4 cartes */
.difference-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 2rem;
  max-width: 1400px;
  margin: 0 auto;
}

.diff-card {
  /* Darker blueish grey, similar to mockup */
  background: #111C2C; 
  border-radius: 32px;
  padding: 40px 32px;
  text-align: left;
  border: 1px solid rgba(255, 255, 255, 0.05);
  transition: all 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
  display: flex;
  flex-direction: column;
}

.diff-card:hover {
  border-color: rgba(232, 157, 70, 0.3);
  transform: translateY(-8px);
  background: #152233;
}

/* Icon Box inside card */
.diff-icon-box {
  width: 48px;
  height: 48px;
  border-radius: 12px;
  background: rgba(255, 255, 255, 0.03);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 2rem;
  border: 1px solid rgba(255, 255, 255, 0.05);
  transition: all 0.3s ease;
}

.diff-card:hover .diff-icon-box {
  background: rgba(232, 157, 70, 0.08);
  border-color: rgba(232, 157, 70, 0.2);
}

.diff-icon-box svg {
  width: 24px;
  height: 24px;
  color: #E89D46;
  transition: all 0.3s ease;
}

.diff-icon-box svg.illu-solid-svg {
  stroke: none !important;
  fill: currentColor !important;
}

.diff-card:hover .diff-icon-box svg {
  filter: drop-shadow(0 0 8px rgba(232, 157, 70, 0.4));
}

.diff-title {
  color: #F9F9F9;
  font-weight: 600;
  font-size: 1.25rem;
  margin: 0 0 1rem 0;
  line-height: 1.3;
}

.diff-text {
  color: rgba(249, 249, 249, 0.6);
  font-size: 1.05rem;
  line-height: 1.5;
  margin: 0;
}

/* CTA Section at bottom */
.conclusion-cta-area {
  text-align: center;
  margin-top: 6rem;
  max-width: 800px;
  margin-left: auto;
  margin-right: auto;
  padding-top: 6rem; /* extra space from grid */
}

.conclusion-cta-text {
  color: #F9F9F9;
  font-size: 1.21rem;
  font-weight: 600;
  margin-bottom: 2rem;
}

.btn-pill-amber-conclusion {
  background: #E89D46;
  color: #081A32;
  border: none;
  padding: 18px 40px;
  border-radius: 99px;
  font-weight: 700;
  font-size: 1.1rem;
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  transition: all 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
  /* Permanent glow to show it's "on" */
  filter: drop-shadow(0 0 15px rgba(232, 157, 70, 0.4));
}

.btn-pill-amber-conclusion:hover {
  transform: translateY(-4px);
  background: #F0A956;
  filter: drop-shadow(0 0 25px rgba(232, 157, 70, 0.6));
}

/* Responsive */
@media screen and (max-width: 1200px) {
  .difference-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media screen and (max-width: 768px) {
  .approach-conclusion-section {
    padding: 80px 2rem;
  }
  .difference-grid {
    grid-template-columns: 1fr;
  }
  .conclusion-h2 {
    font-size: 2.42rem;
  }
}
</style>

<section class="approach-conclusion-section">
  
  <div class="conclusion-header">
    {% if section.settings.badge_text != blank %}
      <div class="conclusion-badge">{{ section.settings.badge_text }}</div>
    {% endif %}
    {% if section.settings.title != blank %}
      <h2 class="conclusion-h2">{{ section.settings.title }}</h2>
    {% endif %}
  </div>

  <div class="difference-grid">
    {% for block in section.blocks %}
      <div class="diff-card" {{ block.shopify_attributes }}>
        
        <div class="diff-icon-box">
          {% if block.settings.custom_svg != blank %}
            {{ block.settings.custom_svg }}
          {% else %}
            {% if forloop.index == 1 %}
              <!-- Solid Scan icon for Moins de choix -->
              <svg class="illu-solid-svg" viewBox="0 0 256 256" fill="currentColor">
                <path d="M216,40H176a8,8,0,0,0,0,16h32V88a8,8,0,0,0,16,0V48A8,8,0,0,0,216,40ZM88,200H48V168a8,8,0,0,0-16,0v40a8,8,0,0,0,8,8H88a8,8,0,0,0,0-16Zm128-40a8,8,0,0,0-8,8v32H176a8,8,0,0,0,0,16h40a8,8,0,0,0,8-8V168A8,8,0,0,0,216,160ZM48,88V56H88a8,8,0,0,0,0-16H40a8,8,0,0,0-8,8V88a8,8,0,0,0,16,0Zm80,8a32,32,0,1,0,32,32A32,32,0,0,0,128,96Zm0,48a16,16,0,1,1,16-16A16,16,0,0,1,128,144Z"></path>
              </svg>
            {% elsif forloop.index == 2 %}
              <!-- Solid Infinity icon for Meilleure expérience -->
              <svg class="illu-solid-svg" viewBox="0 0 256 256" fill="currentColor">
                <path d="M248,128c0,28.8-21.78,56-55.8,56a64.57,64.57,0,0,1-43.76-17C137.6,156.45,128.53,144,128,144s-9.6,12.45-20.44,23C96.78,177.58,80.12,184,63.8,184C29.78,184,8,156.8,8,128S29.78,72,63.8,72a64.57,64.57,0,0,1,43.76,17C118.4,99.55,127.47,112,128,112s9.6-12.45,20.44-23c10.78-10.55,27.44-17,43.76-17C226.22,72,248,99.2,248,128Z"></path>
              </svg>
            {% elsif forloop.index == 3 %}
              <!-- Solid Check Circle icon for Décisions simples -->
              <svg class="illu-solid-svg" viewBox="0 0 256 256" fill="currentColor">
                <path d="M128,24A104,104,0,1,0,232,128,104.11,104.11,0,0,0,128,24Zm45.66,85.66-56,56a8,8,0,0,1-11.32,0l-24-24a8,8,0,0,1,11.32-11.32L112,148.69l50.34-50.35a8,8,0,0,1,11.32,11.32Z"></path>
              </svg>
            {% else %}
              <!-- Solid Diamond icon for Produits durables -->
              <svg class="illu-solid-svg" viewBox="0 0 256 256" fill="currentColor">
                <path d="M236.21,80.79l-40-56A15.93,15.93,0,0,0,183.18,16H72.82a15.93,15.93,0,0,0-13,8.79l-40,56a16,16,0,0,0-.72,17.72l96,136a16,16,0,0,0,25.84,0l96-136A16,16,0,0,0,236.21,80.79ZM64.51,64H191.49L208.63,88H47.37Z"></path>
              </svg>
            {% endif %}
          {% endif %}
        </div>

        <h3 class="diff-title">{{ block.settings.title }}</h3>
        <p class="diff-text">{{ block.settings.description }}</p>
      
      </div>
    {% endfor %}
  </div>

  <div class="conclusion-cta-area">
    {% if section.settings.cta_text_above != blank %}
      <div class="conclusion-cta-text">{{ section.settings.cta_text_above }}</div>
    {% endif %}
    {% if section.settings.cta_button_text != blank %}
      <a href="{{ section.settings.cta_button_link | default: '#' }}" class="btn-pill-amber-conclusion">
        {{ section.settings.cta_button_text }}
      </a>
    {% endif %}
  </div>

</section>

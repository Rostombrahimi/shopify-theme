<style>
  .visual-impact-section {
    background-color: var(--illu-bg-night, #081A32);
    padding: 80px 4rem;
  }

  .visual-impact-header {
    max-width: 1300px;
    margin: 0 auto 48px auto;
    text-align: left;
  }

  .visual-impact-badge {
    display: inline-block;
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(10px);
    padding: 8px 20px;
    border-radius: 99px;
    color: var(--illu-accent-amber, #E89D46);
    font-size: 0.94rem;
    letter-spacing: 0.15em;
    margin-bottom: 2rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    text-transform: uppercase;
    font-weight: 700;
  }

  .visual-impact-title {
    font-size: clamp(2.5rem, 6vw, 5.5rem) !important;
    font-weight: 800;
    margin: 0 0 16px 0;
    font-family: var(--font-heading-family);
    letter-spacing: -0.02em;
    line-height: 1.05;
    color: var(--illu-accent-amber, #E89D46);
    text-shadow: 0 0 15px rgba(232, 157, 70, 0.45);
  }

  .visual-impact-description {
    color: rgba(249, 249, 249, 0.85);
    font-size: 1.24rem;
    margin: 0;
    font-family: var(--font-body-family);
    line-height: 1.6;
    max-width: 600px;
  }

  .impact-grid-container {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    max-width: 1300px;
    margin: 0 auto;
  }

  .impact-card-expert {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 32px;
    padding: 40px;
    text-align: left;
    backdrop-filter: blur(12px);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    /* Micro-vignette fallback if radial isn't perfect, but keeping it subtle */
    background-image: radial-gradient(circle at center, transparent 0%, rgba(0,0,0,0.15) 100%);
  }

  .impact-card-expert:hover {
    transform: translateY(-8px);
    border-color: rgba(232, 157, 70, 0.3);
    background-color: rgba(255, 255, 255, 0.04);
  }

  .impact-card-icon {
    margin-bottom: 24px;
    display: inline-flex;
    color: var(--illu-accent-amber, #E89D46);
  }
  
  .impact-card-icon svg {
    filter: drop-shadow(0 0 10px rgba(232, 157, 70, 0.3));
    width: 40px;
    height: 40px;
  }

  .impact-card-title {
    color: var(--illu-text-cream, #F9F9F9);
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0 0 16px 0;
    font-family: var(--font-heading-family);
    line-height: 1.3;
  }

  .impact-card-text {
    color: rgba(249, 249, 249, 0.7);
    font-size: 0.95rem;
    line-height: 1.6;
    margin: 0;
    font-family: var(--font-body-family);
  }

  @media screen and (max-width: 990px) {
    .impact-grid-container {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .visual-impact-section {
      padding: 60px 20px;
    }
    .visual-impact-title {
      font-size: 2rem;
    }
  }
</style>

<div class="sf-stitch visual-impact-section" style="background-color: {{ section.settings.bg_color }};">
  <div class="visual-impact-header">
    {%- if section.settings.subtitle != blank -%}
      <div class="visual-impact-badge">{{ section.settings.subtitle }}</div>
    {%- endif -%}
    {%- if section.settings.title != blank -%}
      <h1 class="visual-impact-title h1">{{ section.settings.title }}</h1>
    {%- endif -%}
    {%- if section.settings.description != blank -%}
      <p class="visual-impact-description">{{ section.settings.description }}</p>
    {%- endif -%}
  </div>

  <div class="impact-grid-container">
    {%- for block in section.blocks -%}
      <div class="impact-card-expert" {{ block.shopify_attributes }}>
        {%- if block.settings.custom_svg != blank -%}
          <div class="impact-card-icon">
            {{ block.settings.custom_svg }}
          </div>
        {%- endif -%}
        {%- if block.settings.title != blank -%}
          <h3 class="impact-card-title h3">{{ block.settings.title }}</h3>
        {%- endif -%}
        {%- if block.settings.text != blank -%}
          <p class="impact-card-text">{{ block.settings.text }}</p>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{

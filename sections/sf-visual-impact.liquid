<style>
  .visual-impact-section {
    background-color: var(--illu-bg-night, #081A32);
    padding: 80px 4rem;
  }

  .visual-impact-header {
    max-width: 1300px;
    margin: 0 auto 48px auto;
    text-align: left;
  }

  .visual-impact-subtitle {
    color: var(--illu-text-cream, #F9F9F9);
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 32px;
    font-family: var(--font-heading-family);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .visual-impact-title {
    color: var(--illu-text-cream, #F9F9F9);
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 800;
    margin: 0 0 16px 0;
    font-family: var(--font-heading-family);
    letter-spacing: -0.02em;
  }

  .visual-impact-description {
    color: rgba(249, 249, 249, 0.7);
    font-size: 1.24rem;
    margin: 0;
    font-family: var(--font-body-family);
    line-height: 1.6;
  }

  .impact-grid-container {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    max-width: 1300px;
    margin: 0 auto;
  }

  .impact-card-expert {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 32px;
    padding: 40px;
    text-align: left;
    backdrop-filter: blur(12px);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    /* Micro-vignette fallback if radial isn't perfect, but keeping it subtle */
    background-image: radial-gradient(circle at center, transparent 0%, rgba(0,0,0,0.15) 100%);
  }

  .impact-card-expert:hover {
    transform: translateY(-8px);
    border-color: rgba(232, 157, 70, 0.3);
    background-color: rgba(255, 255, 255, 0.04);
  }

  .impact-card-icon {
    margin-bottom: 24px;
    display: inline-flex;
  }
  
  .impact-card-icon svg {
    filter: drop-shadow(0 0 10px rgba(232, 157, 70, 0.3));
    width: 40px;
    height: 40px;
  }

  .impact-card-title {
    color: var(--illu-text-cream, #F9F9F9);
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0 0 16px 0;
    line-height: 1.3;
    font-family: var(--font-heading-family);
  }

  .impact-card-text {
    color: rgba(249, 249, 249, 0.7);
    font-size: 0.95rem;
    line-height: 1.6;
    margin: 0;
    font-family: var(--font-body-family);
  }

  @media screen and (max-width: 990px) {
    .impact-grid-container {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .visual-impact-section {
      padding: 60px 20px;
    }
    .visual-impact-title {
      font-size: 2rem;
    }
  }
</style>

<div class="sf-stitch visual-impact-section" style="background-color: {{ section.settings.bg_color }};">
  <div class="visual-impact-header">
    {%- if section.settings.subtitle != blank -%}
      <p class="visual-impact-subtitle">{{ section.settings.subtitle }}</p>
    {%- endif -%}
    {%- if section.settings.title != blank -%}
      <h2 class="visual-impact-title">{{ section.settings.title }}</h2>
    {%- endif -%}
    {%- if section.settings.description != blank -%}
      <p class="visual-impact-description">{{ section.settings.description }}</p>
    {%- endif -%}
  </div>

  <div class="impact-grid-container">
    {%- for block in section.blocks -%}
      <div class="impact-card-expert" {{ block.shopify_attributes }}>
        {%- if block.settings.custom_svg != blank -%}
          <div class="impact-card-icon">
            {{ block.settings.custom_svg }}
          </div>
        {%- endif -%}
        {%- if block.settings.title != blank -%}
          <h3 class="impact-card-title">{{ block.settings.title }}</h3>
        {%- endif -%}
        {%- if block.settings.text != blank -%}
          <p class="impact-card-text">{{ block.settings.text }}</p>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "⚡ Impact Visuel (Bento)",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Couleur de fond",
      "default": "#081A32"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Sur-titre",
      "default": "Ce que cette ambiance permet"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titre principal",
      "default": "Impact Visuel"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Découvrez les bénéfices de l'Univers Visuel pour sublimer vos espaces."
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Bénéfice",
      "limit": 3,
      "settings": [
        {
          "type": "html",
          "id": "custom_svg",
          "label": "Code SVG de l'icône"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titre de la carte",
          "default": "Mettre en valeur une collection"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Texte de la carte",
          "default": "Mettre en valeur une collection pour révéler chaque détail de vos pièces favorites."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "⚡ Impact Visuel (Bento)",
      "blocks": [
        {
          "type": "benefit",
          "settings": {
            "title": "Mettre en valeur une collection",
            "text": "Mettre en valeur une collection pour révéler chaque détail de vos pièces favorites.",
            "custom_svg": "<svg width=\"40\" height=\"40\" viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M12 2v3M12 19v3M4.22 4.22l2.12 2.12M17.66 17.66l2.12 2.12M2 12h3M19 12h3M4.22 19.78l2.12-2.12M17.66 6.34l2.12-2.12\" stroke=\"#E89D46\" stroke-width=\"1.5\" stroke-linecap=\"round\"/><rect x=\"9\" y=\"9\" width=\"6\" height=\"6\" rx=\"1\" stroke=\"#E89D46\" stroke-width=\"1.2\"/></svg>"
          }
        },
        {
          "type": "benefit",
          "settings": {
            "title": "Renforcer les couleurs et les contrastes",
            "text": "Renforcer les couleurs et les contrastes pour une immersion visuelle totale.",
            "custom_svg": "<svg width=\"40\" height=\"40\" viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"><circle cx=\"8\" cy=\"12\" r=\"6\" stroke=\"#E89D46\" stroke-width=\"1.5\"/><circle cx=\"16\" cy=\"12\" r=\"6\" stroke=\"#E89D46\" stroke-width=\"1.5\" stroke-dasharray=\"2 2\" opacity=\"0.6\"/><path d=\"M12 12l2-2m0 4l-2-2\" stroke=\"#E89D46\" stroke-width=\"1.5\" stroke-linecap=\"round\"/></svg>"
          }
        },
        {
          "type": "benefit",
          "settings": {
            "title": "Donner une identité visuelle forte",
            "text": "Donner une identité visuelle forte à un espace qui vous ressemble vraiment.",
            "custom_svg": "<svg width=\"40\" height=\"40\" viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M16 4h2a2 2 0 012 2v14a2 2 0 01-2 2H6a2 2 0 01-2-2V6a2 2 0 012-2h2\" stroke=\"#E89D46\" stroke-width=\"1.5\" stroke-linecap=\"round\"/><path d=\"M12 2v4M9 12l2 2 4-4\" stroke=\"#E89D46\" stroke-width=\"1.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>"
          }
        }
      ]
    }
  ]
}
{% endschema %}

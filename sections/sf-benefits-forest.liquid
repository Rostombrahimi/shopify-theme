{% schema %}
{
  "name": "Bénéfices Forêt",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "BÉNÉFICES CONCRETS"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Une Lumière Qui Rassure"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Découvrez comment nos veilleuses transforment la nuit de votre enfant en un moment de calme et de sérénité grâce à une conception pensée pour le bien-être."
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Bénéfice",
      "limit": 3,
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "sun", "label": "Lumière Constante" },
            { "value": "fox", "label": "Formes Repères" },
            { "value": "aura", "label": "Présence Apaisante" }
          ],
          "default": "sun"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Lumière Constante"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Une lumière constante et non agressive pour un repos sans interruption."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bénéfices Forêt",
      "blocks": [
        {
          "type": "benefit",
          "settings": {
            "icon": "sun",
            "title": "Lumière Constante",
            "text": "Une lumière constante et non agressive pour un repos sans interruption."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon": "fox",
            "title": "Formes Repères",
            "text": "Des formes reconnaissables qui deviennent des repères rassurants dans la nuit."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon": "aura",
            "title": "Présence Apaisante",
            "text": "Une présence visuelle apaisante, même dans l'obscurité la plus totale."
          }
        }
      ]
    }
  ]
}
{% endschema %}

<style>
/* Section 3 - Bénéfices Forest */
.forest-benefits-section {
  background-color: #081A32;
  padding: 100px 4rem;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

.forest-benefits-container {
  max-width: 1440px;
  margin: 0 auto;
}

.forest-benefits-header {
  margin-bottom: 4rem;
  max-width: 800px;
}

.benefits-badge {
  color: #E89D46;
  font-size: 0.94rem;
  font-weight: 700;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  margin-bottom: 1rem;
  display: block;
}

.forest-benefits-h2 {
  font-size: clamp(2.2rem, 3.85vw, 3.3rem);
  color: #F9F9F9;
  font-weight: 700;
  margin: 0 0 1.5rem 0;
  letter-spacing: -0.02em;
}

.forest-benefits-description {
  font-size: 1.26rem;
  color: rgba(249, 249, 249, 0.7);
  line-height: 1.6;
  max-width: 700px;
}

.benefits-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 32px;
}

.benefit-card {
  background: rgba(255, 255, 255, 0.02);
  border: 1px solid rgba(255, 255, 255, 0.05);
  border-radius: 32px;
  padding: 40px;
  text-align: left; /* Alignement à gauche selon la maquette */
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  transition: all 0.4s cubic-bezier(0.25, 1, 0.5, 1);
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
  display: flex;
  flex-direction: column;
}

.benefit-card:hover {
  transform: translateY(-8px);
  border-color: rgba(232, 157, 70, 0.3);
  background: rgba(255, 255, 255, 0.04);
  box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
}

.benefit-icon {
  margin-bottom: 2rem;
  width: 60px;
  height: 60px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(232, 157, 70, 0.1);
  color: #E89D46;
  filter: drop-shadow(0 0 10px rgba(232, 157, 70, 0.3));
  transition: filter 0.3s ease;
}

.benefit-card:hover .benefit-icon {
  filter: drop-shadow(0 0 20px rgba(232, 157, 70, 0.6));
}

.benefit-icon svg {
  width: 28px;
  height: 28px;
}

.benefit-title {
  color: #F9F9F9;
  font-size: 1.25rem;
  font-weight: 600;
  margin: 0 0 1rem 0;
}

.benefit-text {
  color: rgba(249, 249, 249, 0.7);
  font-size: 1.1rem;
  line-height: 1.6;
  margin: 0;
}

@media screen and (max-width: 1024px) {
  .benefits-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media screen and (max-width: 768px) {
  .forest-benefits-section {
    padding: 80px 2rem;
  }
  .benefits-grid {
    grid-template-columns: 1fr;
  }
  .benefit-card {
    padding: 32px;
  }
}
</style>

<section class="forest-benefits-section">
  <div class="forest-benefits-container">
    
    <div class="forest-benefits-header">
      {% if section.settings.badge_text != blank %}
        <span class="benefits-badge">{{ section.settings.badge_text }}</span>
      {% endif %}
      
      {% if section.settings.title != blank %}
        <h2 class="forest-benefits-h2">{{ section.settings.title }}</h2>
      {% endif %}
      
      {% if section.settings.description != blank %}
        <p class="forest-benefits-description">{{ section.settings.description }}</p>
      {% endif %}
    </div>

    <div class="benefits-grid">
      {% for block in section.blocks %}
        <div class="benefit-card" {{ block.shopify_attributes }}>
          <div class="benefit-icon">
            {% case block.settings.icon %}
              {% when 'sun' %}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
                  <circle cx="12" cy="12" r="4"/>
                  <path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/>
                </svg>
              {% when 'fox' %}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
                  <circle cx="11" cy="4" r="2"/><circle cx="18" cy="8" r="2"/><circle cx="20" cy="16" r="2"/>
                  <path d="M9 10a5 5 0 0 1 5 5v3.5a3.5 3.5 0 0 1-6.84 1.045Q6.52 17.48 4.46 16.84A3.5 3.5 0 0 1 5.5 10Z"/>
                </svg>
              {% when 'aura' %}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
                  <circle cx="12" cy="5" r="1"/><circle cx="19" cy="5" r="1"/><circle cx="5" cy="5" r="1"/>
                  <circle cx="12" cy="12" r="1"/><circle cx="19" cy="12" r="1"/><circle cx="5" cy="12" r="1"/>
                  <circle cx="12" cy="19" r="1"/><circle cx="19" cy="19" r="1"/><circle cx="5" cy="19" r="1"/>
                </svg>
            {% endcase %}
          </div>
          
          <h3 class="benefit-title">{{ block.settings.title }}</h3>
          <p class="benefit-text">{{ block.settings.text }}</p>
        </div>
      {% endfor %}
    </div>

  </div>
</section>

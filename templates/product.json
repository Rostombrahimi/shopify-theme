{
    "sections": {
        "main": {
            "type": "main-product",
            "blocks": {
                "vendor": {
                    "type": "text",
                    "settings": {
                        "text": "{{ product.vendor }}",
                        "text_style": "uppercase"
                    }
                },
                "title": {
                    "type": "title",
                    "settings": {}
                },
                "price": {
                    "type": "price",
                    "settings": {}
                },
                "variant_picker": {
                    "type": "variant_picker",
                    "settings": {
                        "picker_type": "button",
                        "swatch_shape": "circle"
                    }
                },
                "quantity_selector": {
                    "type": "quantity_selector",
                    "settings": {}
                },
                "buy_buttons": {
                    "type": "buy_buttons",
                    "settings": {
                        "show_dynamic_checkout": true,
                        "show_gift_card_recipient": true
                    }
                },
                "illuminations_path": {
                    "type": "illuminations_path",
                    "settings": {}
                },
                "description": {
                    "type": "description",
                    "settings": {}
                },
                "share": {
                    "type": "share",
                    "settings": {
                        "share_label": "Share"
                    }
                }
            },
            "block_order": [
                "vendor",
                "title",
                "price",
                "variant_picker",
                "quantity_selector",
                "buy_buttons",
                "light_path",
                "description",
                "share"
            ],
            "settings": {
                "enable_sticky_info": true,
                "color_scheme": "scheme-1",
                "media_size": "large",
                "constrain_to_viewport": true,
                "media_fit": "contain",
                "gallery_layout": "stacked",
                "mobile_thumbnails": "hide",
                "media_position": "left",
                "image_zoom": "lightbox",
                "hide_variants": true,
                "enable_video_looping": false,
                "padding_top": 36,
                "padding_bottom": 12
            }
        },
        "related-products": {
            "type": "related-products",
            "settings": {
                "heading": "You may also like",
                "heading_size": "h2",
                "products_to_show": 4,
                "columns_desktop": 4,
                "columns_mobile": "2",
                "color_scheme": "scheme-1",
                "image_ratio": "square",
                "image_shape": "default",
                "show_secondary_image": true,
                "show_vendor": false,
                "show_rating": false,
                "padding_top": 36,
                "padding_bottom": 28
            }
        },
        "echo_lumineux": {
            "type": "sf-echo-lumineux",
            "blocks": {
                "universe_1": {
                    "type": "universe_rule",
                    "settings": {
                        "trigger_tag": "cocon",
                        "block_title": "Pour compléter son cocon de douceur"
                    }
                },
                "universe_2": {
                    "type": "universe_rule",
                    "settings": {
                        "trigger_tag": "pro",
                        "block_title": "Pour optimiser votre configuration de travail"
                    }
                },
                "universe_3": {
                    "type": "universe_rule",
                    "settings": {
                        "trigger_tag": "setup",
                        "block_title": "Pour pousser l'immersion un cran plus loin"
                    }
                }
            },
            "block_order": [
                "universe_1",
                "universe_2",
                "universe_3"
            ],
            "settings": {
                "title_default": "Sublimez votre univers avec ces essentiels",
                "bg_color": "#0A1428",
                "product_limit": 4,
                "show_add_button": true,
                "add_button_text": "Ajouter au panier"
            }
        }
    },
    "order": [
        "main",
        "echo_lumineux",
        "related-products"
    ]
}